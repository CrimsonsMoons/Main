function Controller:PushLog(text)
	text = tostring(text or "")
	if text == "" then return end

	local now = os.clock()
	if self.lastLoggedStatus == text and now - self.lastLoggedAt < 0.8 then
		return
	end

	self.lastLoggedStatus = text
	self.lastLoggedAt = now

	local stamp = os.date("%H:%M:%S")
	table.insert(self.ActionLog, 1, "[" .. stamp .. "] " .. text)

	while #self.ActionLog > self.MAX_ACTION_LOG do
		table.remove(self.ActionLog)
	end
end

function Controller:SetStatus(text)
	self.status.lastAction = text
	self:PushLog(text)
end

function Controller:SetAutoSellStatus(text, notifyUser)
	text = tostring(text or "Idle")
	self.AutoSellStatusText = text
	self:SetStatus(text)

	if notifyUser then
		self:Notify(text)
	end
end

function Controller:GetActionLogText()
