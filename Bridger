	return self.Character:FindFirstChild("HumanoidRootPart")
		or self.Character:FindFirstChild("UpperTorso")
		or self.Character:FindFirstChild("Torso")
end

function Controller:ComputeLeftCFrameFrom(cf)
	local leftPosition = cf.Position - (cf.RightVector * self.PositionEnforcerMoveDistance)
	local rotationOnly = cf - cf.Position
	return CFrame.new(leftPosition) * rotationOnly
