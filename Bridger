function Controller:StartHoldingE()
	if not self.AutoFishingEnabled then return end
	if self.interactState.holding then return end
	if os.clock() < self.interactLockoutUntil then return end
	if os.clock() - self.lastInteractHoldTime < self.INTERACT_RETRIGGER_DELAY then return end

	self.interactHoldToken += 1
	local token = self.interactHoldToken

	self.interactState.holding = true
	self.lastInteractHoldTime = os.clock()
	self:SetStatus("Holding E prompt")

	task.spawn(function()
		if not self.AutoFishingEnabled or token ~= self.interactHoldToken then
			self.interactState.holding = false
			return
		end

		self.interactState.autoKeyDown = true

		pcall(function()
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
		end)

		local start = os.clock()

		while os.clock() - start < self.INTERACT_HOLD_TIME do
			if not self.AutoFishingEnabled then break end
			if token ~= self.interactHoldToken then break end
			if not self.interactState.gui then break end
			task.wait(0.05)
		end

		self:ReleaseAutoInteractKey()

		if token ~= self.interactHoldToken then return end

		self.interactState.holding = false
		self.interactLockoutUntil = os.clock() + self.INTERACT_CLEAR_LOCKOUT

		if self.AutoFishingEnabled then
			self:SetStatus("Finished holding E")
		end
	end)
end

function Controller:ReleaseAutoInteractKey()
	-- Only release E if THIS script pressed it.
	-- This prevents Auto Fish OFF from breaking normal/manual E interactions.
	if not self.interactState or not self.interactState.autoKeyDown then
		return
	end

	self.interactState.autoKeyDown = false

	pcall(function()
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
	end)
end

function Controller:StopHoldingE()
	local wasActive = self.interactState.holding or self.interactState.gui ~= nil or self.interactState.autoKeyDown

	if not wasActive then
		self.interactState.holding = false
		self.interactState.gui = nil
		return
	end

	self.interactHoldToken += 1
	self:ReleaseAutoInteractKey()

	self.interactState.holding = false
	self.interactState.gui = nil
	self.interactLockoutUntil = os.clock() + self.INTERACT_CLEAR_LOCKOUT

	if not self.AutoFishingEnabled then
		return
	end

	self:SetStatus("Interaction cleared, normal recast")

	task.spawn(function()
		task.wait(0.75)

		if not self.AutoFishingEnabled then return end
		if self.interactState.holding or self.interactState.gui then return end
		if self.fishingState.minigameActive then return end
		if self:HasNearbyCurrentBobber() then return end
		if self.clickedRecently or self.usingBaitAfterCatch then return end
		if not self:CanRecast() then return end

		self.lastRecastTime = os.clock()
		self:SetStatus("Interaction recast")
		self:ResetFishingState()
		self:StartReliableCast("interaction recast")
	end)
end

function Controller:TryStuckCastRecovery()
	if not self.AutoFishingEnabled then return end
	if self.CastInProgress or os.clock() < self.CastLockUntil then return end
	if self.clickedRecently then return end
	if self.usingBaitAfterCatch then return end
	if self.interactState.holding then return end
	if self.interactState.gui then return end
	if self.fishingState.minigameActive then return end
	if self.fishingState.recastQueued then return end

	if self:HasNearbyCurrentBobber() then
		self.awaitingBobberAfterCast = false
		self.lastBobberSeenTime = os.clock()
		self.lastValidFishingAction = os.clock()
		return
	end

	if self.awaitingBobberAfterCast then
		local timeSinceCast = os.clock() - self.lastCastAttemptTime

		if timeSinceCast < self.NO_BOBBER_RETRY_TIME then return end

		if self:CanRecast() then
			self:SetStatus("No bobber found, recasting")
			self:QueueRecast("no bobber found")
		end

		return
	end

	local idleTime = os.clock() - self.lastValidFishingAction

	if idleTime >= self.IDLE_RECAST_TIME and self:CanRecast() then
		self:SetStatus("Fishing idle, recasting")
		self:QueueRecast("idle recovery")
	end
end

function Controller:IsGuiActuallyVisible(guiObject)
	if not guiObject then return false end

	local current = guiObject
	while current and current ~= PlayerGui do
		if current:IsA("GuiObject") and not current.Visible then
			return false
		end
		current = current.Parent
	end

	return true
end

function Controller:IsHoldETextObject(obj)
	if not obj then
		return false
	end

	if not (obj:IsA("TextLabel") or obj:IsA("TextButton")) then
		return false
	end

	if not self:IsGuiActuallyVisible(obj) then
		return false
	end

	local text = tostring(obj.Text or ""):upper()
	text = text:gsub("%s+", " ")
	text = text:match("^%s*(.-)%s*$") or text

	-- Keep this strict. A plain "INTERACT" match caused false E-holds
	-- when no chest was actually inside range.
	if text == "HOLD E" then return true end
	if text == "HOLD [E]" then return true end
	if text == "E TO INTERACT" then return true end
	if text == "HOLD E TO INTERACT" then return true end
	if text == "PRESS E" then return true end
	if text == "PRESS E TO INTERACT" then return true end

	return text:find("HOLD%s*%[?E%]?") ~= nil
		or text:find("%[?E%]?%s*TO%s*INTERACT") ~= nil
		or text:find("PRESS%s*%[?E%]?") ~= nil
end

function Controller:FindHoldEGui()
	for _, obj in ipairs(PlayerGui:GetDescendants()) do
		if self:IsHoldETextObject(obj) then
			return obj
		end
	end

	return nil
end

