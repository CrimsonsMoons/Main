function Controller:GetTreeBark(tree)
	if not tree then
		return nil
	end

	if tree:IsA("BasePart") and tree.Name == "TreeBark" then
		return tree
	end

	local direct = tree:FindFirstChild("TreeBark")
	if direct and direct:IsA("BasePart") then
		return direct
	end

	local deep = tree:FindFirstChild("TreeBark", true)
	if deep and deep:IsA("BasePart") then
		return deep
	end

	return nil
end

function Controller:IsValidTree(tree)
	if not tree or not tree.Parent then
		return false
	end

	local bark = self:GetTreeBark(tree)

	if not bark or not bark.Parent or not bark:IsDescendantOf(workspace) then
		return false
	end

	if bark:IsA("BasePart") and bark.Transparency >= 1 then
		return false
	end

	return true
end

function Controller:GetNearestFallbackTreeCFrame()
	if not self:IsAlive() or not self.AutoTreeFallbackCFrames or #self.AutoTreeFallbackCFrames == 0 then
		return nil, math.huge, nil
	end

	local bestIndex = nil
	local bestCFrame = nil
	local bestDistance = math.huge
	local rootPosition = self.RootPart.Position

	for index, cf in ipairs(self.AutoTreeFallbackCFrames) do
		local distance = (cf.Position - rootPosition).Magnitude

		if distance < bestDistance then
			bestDistance = distance
			bestCFrame = cf
			bestIndex = index
		end
	end

	return bestCFrame, bestDistance, bestIndex
end

function Controller:FindTreeNearCFrame(cf)
	if not cf then
		return nil, nil, math.huge
	end

	local folder = self:GetForestTreesFolder()
	if not folder then
		return nil, nil, math.huge
	end

	local bestTree = nil
	local bestBark = nil
	local bestDistance = math.huge

	for _, tree in ipairs(folder:GetChildren()) do
		local bark = self:GetTreeBark(tree)

		if bark and bark.Parent and bark:IsDescendantOf(workspace) and bark.Transparency < 1 then
			local distance = (bark.Position - cf.Position).Magnitude

			if distance < bestDistance then
				bestDistance = distance
				bestTree = tree
				bestBark = bark
			end
		end
	end

	if bestDistance <= self.AutoTreeFallbackLinkDistance then
		return bestTree, bestBark, bestDistance
	end

	return nil, nil, bestDistance
end

function Controller:FindSpawnedTreeCFrameFromCurrent()
	if not self.AutoTreeFallbackCFrames or #self.AutoTreeFallbackCFrames == 0 then
		return nil
	end

	if os.clock() - self.AutoTreeLastCFrameSpawnCheck < self.AutoTreeCFrameSpawnCheckRate then
		return self:GetCurrentFallbackTreeCFrame()
	end

	self.AutoTreeLastCFrameSpawnCheck = os.clock()

	local count = #self.AutoTreeFallbackCFrames
	local tries = 0

	while tries < count do
		local cf = self:GetCurrentFallbackTreeCFrame()
		local tree, bark = self:FindTreeNearCFrame(cf)

		if tree and bark then
			self.AutoTreeFallbackLinkedTree = tree
			self.AutoTreeFallbackLinkedBark = bark
			return cf
		end

		self:AdvanceFallbackTreeCFrame()
		tries += 1
	end

	self.AutoTreeFallbackLinkedTree = nil
	self.AutoTreeFallbackLinkedBark = nil
	return self:GetCurrentFallbackTreeCFrame()
end

function Controller:BindFallbackTreeToCurrentCFrame()
	local cf = self:GetCurrentFallbackTreeCFrame()

	self.AutoTreeFallbackLinkedTree = nil
	self.AutoTreeFallbackLinkedBark = nil

	if not cf then
		return
	end

	local tree, bark = self:FindTreeNearCFrame(cf)

	self.AutoTreeFallbackLinkedTree = tree
	self.AutoTreeFallbackLinkedBark = bark
end

function Controller:IsFallbackLinkedTreeAlive()
	if not self.AutoTreeFallbackLinkedTree or not self.AutoTreeFallbackLinkedBark then
		return false
	end

	if not self.AutoTreeFallbackLinkedTree.Parent then
		return false
	end

	local bark = self.AutoTreeFallbackLinkedBark

	if not bark.Parent or not bark:IsDescendantOf(workspace) then
		return false
	end

	if bark:IsA("BasePart") and bark.Transparency >= 1 then
		return false
	end

	return true
end

function Controller:GetCurrentFallbackTreeCFrame()
	if not self.AutoTreeFallbackCFrames or #self.AutoTreeFallbackCFrames == 0 then
		return nil
	end

	if self.AutoTreeFallbackIndex > #self.AutoTreeFallbackCFrames then
		self.AutoTreeFallbackIndex = 1
	end

	return self.AutoTreeFallbackCFrames[self.AutoTreeFallbackIndex]
end

function Controller:AdvanceFallbackTreeCFrame()
	if not self.AutoTreeFallbackCFrames or #self.AutoTreeFallbackCFrames == 0 then
		return
	end

	local count = #self.AutoTreeFallbackCFrames

	if count <= 1 then
		self.AutoTreeFallbackIndex = 1
		self.AutoTreeFallbackDirection = 1
		return
	end

	self.AutoTreeFallbackIndex += self.AutoTreeFallbackDirection

	if self.AutoTreeFallbackIndex >= count then
		self.AutoTreeFallbackIndex = count
		self.AutoTreeFallbackDirection = -1
	elseif self.AutoTreeFallbackIndex <= 1 then
		self.AutoTreeFallbackIndex = 1
		self.AutoTreeFallbackDirection = 1
	end
end

function Controller:GetNearestTree()
	if not self:IsAlive() then
		return nil, nil, math.huge
	end

	local folder = self:GetForestTreesFolder()
	if not folder then
		return nil, nil, math.huge
	end

	local bestTree = nil
	local bestBark = nil
	local bestScore = math.huge
	local bestDistance = math.huge
	local rootPosition = self.RootPart.Position

	for _, tree in ipairs(folder:GetChildren()) do
		local bark = self:GetTreeBark(tree)

		if bark and bark.Parent and bark:IsDescendantOf(workspace) and bark.Transparency < 1 then
			local offset = bark.Position - rootPosition
			local distance = offset.Magnitude
			local verticalPenalty = math.abs(offset.Y) * 0.35
			local score = distance + verticalPenalty

			if score < bestScore then
				bestScore = score
				bestDistance = distance
				bestTree = tree
				bestBark = bark
			end
		end
	end

	return bestTree, bestBark, bestDistance
end



function Controller:DisconnectAutoTreeNoclipWatcher()
	if self.AutoTreeNoClipConnections then
		for _, connection in ipairs(self.AutoTreeNoClipConnections) do
			if connection then
				pcall(function()
					connection:Disconnect()
				end)
			end
		end

		table.clear(self.AutoTreeNoClipConnections)
	end

	self.AutoTreeNoclipWatchedCharacter = nil
end

function Controller:ApplyAutoTreeNoclipToPart(part)
	if not part or not part:IsA("BasePart") then
		return
	end

	if not self.AutoTreeNoclipEnabled then
		return
	end

	if self.AutoTreeNoClipOriginal[part] == nil then
		self.AutoTreeNoClipOriginal[part] = {
			CanCollide = part.CanCollide,
			CanTouch = part.CanTouch,
			CanQuery = part.CanQuery,
		}
	end

	if part.CanCollide ~= false then
		part.CanCollide = false
	end

	if self.AutoTreeNoclipDisableTouch and part.CanTouch ~= false then
		part.CanTouch = false
	end

	if self.AutoTreeNoclipDisableQuery and part.CanQuery ~= false then
		part.CanQuery = false
	end
end

function Controller:RestoreAutoTreeNoclipPart(part)
	if not part or not part:IsA("BasePart") then
		return
	end

	local old = self.AutoTreeNoClipOriginal[part]

	if old then
		pcall(function()
			part.CanCollide = old.CanCollide
			part.CanTouch = old.CanTouch
			part.CanQuery = old.CanQuery
		end)
	else
		pcall(function()
			part.CanCollide = true
		end)
	end
end

function Controller:BindAutoTreeNoclipWatcher()
	if not self.Character or self.AutoTreeNoclipWatchedCharacter == self.Character then
		return
	end

	self:DisconnectAutoTreeNoclipWatcher()
	self.AutoTreeNoclipWatchedCharacter = self.Character

	table.insert(self.AutoTreeNoClipConnections, self.Character.DescendantAdded:Connect(function(descendant)
		if not self.AutoTreeEnabled or not self.AutoTreeNoclipEnabled then
			return
		end

		if descendant:IsA("BasePart") then
			task.defer(function()
				if self.AutoTreeEnabled and self.AutoTreeNoclipEnabled then
					self:ApplyAutoTreeNoclipToPart(descendant)
				end
			end)
		end
	end))
end

function Controller:SetCharacterNoclip(state)
	-- Noclip is locked to Auto Tree.
	-- Any attempt to turn noclip off while Auto Tree is running gets ignored.
	if self.AutoTreeEnabled and not state then
		state = true
	end

	self.AutoTreeNoclipEnabled = state and true or false

	if not self.Character then
		return
	end

	if self.AutoTreeNoclipEnabled then
		self:BindAutoTreeNoclipWatcher()

		for _, obj in ipairs(self.Character:GetDescendants()) do
			if obj:IsA("BasePart") then
				self:ApplyAutoTreeNoclipToPart(obj)
			end
		end

		return
	end

	for part in pairs(self.AutoTreeNoClipOriginal) do
		self:RestoreAutoTreeNoclipPart(part)
	end

	table.clear(self.AutoTreeNoClipOriginal)
	self:DisconnectAutoTreeNoclipWatcher()
end

function Controller:MaintainAutoTreeNoclip()
	if not self.AutoTreeEnabled then
		if self.AutoTreeNoclipEnabled then
			self:SetCharacterNoclip(false)
		end

		return
	end

	-- Always force noclip while Auto Tree is enabled.
	self.AutoTreeNoclipEnabled = true

	local now = os.clock()

	if now - self.AutoTreeLastNoclip < self.AutoTreeNoclipRate then
		return
	end

	self.AutoTreeLastNoclip = now

	if not self:IsAlive() then
		return
	end

	self:SetCharacterNoclip(true)

	local root = self.RootPart
	if root then
		root.AssemblyAngularVelocity = Vector3.zero
	end
end

function Controller:MaintainAutoTreeAntiPhysics()
	if not self.AutoTreeEnabled then
		return
	end

	if os.clock() - self.AutoTreeLastAntiPhysics < self.AutoTreeAntiPhysicsRate then
		return
	end

	self.AutoTreeLastAntiPhysics = os.clock()

	if not self:IsAlive() then
		return
	end

	local root = self.RootPart
	local hum = self.Humanoid

	if not root or not hum then
		return
	end

	if self.AutoTreeAntiKnockback then
		local velocity = root.AssemblyLinearVelocity
		local horizontal = Vector3.new(velocity.X, 0, velocity.Z)

		if horizontal.Magnitude > self.AutoTreeMaxVelocity or math.abs(velocity.Y) > self.AutoTreeMaxVelocity then
			root.AssemblyLinearVelocity = Vector3.zero
		end

		if root.AssemblyAngularVelocity.Magnitude > self.AutoTreeMaxAngularVelocity then
			root.AssemblyAngularVelocity = Vector3.zero
		end
	end

	if self.AutoTreeAntiBadStates then
		pcall(function()
			hum.PlatformStand = false
			hum.Sit = false
			hum.AutoRotate = true
		end)

		local state = hum:GetState()

		if state == Enum.HumanoidStateType.Ragdoll
			or state == Enum.HumanoidStateType.FallingDown
			or state == Enum.HumanoidStateType.Physics
			or state == Enum.HumanoidStateType.PlatformStanding
			or state == Enum.HumanoidStateType.Seated then
			pcall(function()
				hum:ChangeState(Enum.HumanoidStateType.GettingUp)
			end)

			task.defer(function()
				if self.AutoTreeEnabled and self:IsAlive() then
					pcall(function()
						self.Humanoid:ChangeState(Enum.HumanoidStateType.Running)
					end)
				end
			end)
		end
	end
end

function Controller:ResetAutoTreePointTween()
	self.AutoTreePointTweenActive = false
	self.AutoTreePointTweenStartedAt = 0
	self.AutoTreePointTweenStartCFrame = nil
	self.AutoTreePointTweenGoalCFrame = nil
	self.AutoTreePointTweenKind = nil
	self.AutoTreePointTweenRef = nil
end

function Controller:GetAutoTreeLookCFrame(holdPosition, facePosition, fallbackLookVector)
	local lookAt

	if facePosition then
		lookAt = Vector3.new(facePosition.X, holdPosition.Y, facePosition.Z)
	elseif fallbackLookVector then
		lookAt = holdPosition + fallbackLookVector
	end

	if lookAt and (lookAt - holdPosition).Magnitude > 0.1 then
		return CFrame.lookAt(holdPosition, lookAt)
	end

	if fallbackLookVector and fallbackLookVector.Magnitude > 0.01 then
		return CFrame.lookAt(holdPosition, holdPosition + fallbackLookVector)
	end

	return CFrame.new(holdPosition)
end

function Controller:StartAutoTreePointTween(kind, ref, goalCFrame)
	if not self.AutoTreeTeleportToPointEnabled then
		return false
	end

	if not self:IsAlive() or not goalCFrame then
		return false
	end

	if self.AutoTreePointTweenKind == kind and self.AutoTreePointTweenRef == ref then
		return false
	end

	local root = self.RootPart
	local lift = self.AutoTreeTeleportPointLift or 2.35
	local startPosition = goalCFrame.Position + Vector3.new(0, lift, 0)
	local startCFrame = CFrame.lookAt(startPosition, startPosition + goalCFrame.LookVector)

	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	root.CFrame = startCFrame

	self.AutoTreePointTweenActive = true
	self.AutoTreePointTweenStartedAt = os.clock()
	self.AutoTreePointTweenStartCFrame = startCFrame
	self.AutoTreePointTweenGoalCFrame = goalCFrame
	self.AutoTreePointTweenKind = kind
	self.AutoTreePointTweenRef = ref
	self.AutoTreeIsMoving = true
	self.AutoTreeArrivedAtTarget = 0

	return true
end

function Controller:StepAutoTreePointTween(goalCFrame)
	if not self.AutoTreePointTweenActive then
		return false
	end

	if not self:IsAlive() then
		self:ResetAutoTreePointTween()
		return false
	end

	local root = self.RootPart
	local startCFrame = self.AutoTreePointTweenStartCFrame or root.CFrame
	local currentGoal = goalCFrame or self.AutoTreePointTweenGoalCFrame

	if not currentGoal then
		self:ResetAutoTreePointTween()
		return false
	end

	self.AutoTreePointTweenGoalCFrame = currentGoal

	local duration = math.max(self.AutoTreeTeleportTweenDuration or 0.18, 0.03)
	local alpha = math.clamp((os.clock() - (self.AutoTreePointTweenStartedAt or os.clock())) / duration, 0, 1)
	local eased = 1 - ((1 - alpha) ^ 3)

	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	root.CFrame = startCFrame:Lerp(currentGoal, eased)

	if alpha >= 1 then
		root.CFrame = currentGoal
		self.AutoTreePointTweenActive = false
		self.AutoTreeIsMoving = false
		self.AutoTreeArrivedAtTarget = os.clock()
		return true
	end

	self.AutoTreeIsMoving = true
	self.AutoTreeArrivedAtTarget = 0
	return false
end

function Controller:ClearAutoTreeTarget(reason)
	self:ResetAutoTreePointTween()
	self.AutoTreeTarget = nil
	self.AutoTreeTargetBark = nil
	self.AutoTreeUsingFallback = false
	self.AutoTreeFallbackTargetCFrame = nil
	self.AutoTreeIsMoving = false
	self.AutoTreeArrivedAtTarget = 0
	self.AutoTreeLastScan = 0
	self.AutoTreeLastTargetRefresh = 0
	self.AutoTreeLastBrokenAt = os.clock()

	if reason and os.clock() - self.AutoTreeLastStatus >= self.AutoTreeStatusRate then
		self.AutoTreeLastStatus = os.clock()
		self:SetStatus(reason)
	end
end

function Controller:GetWoodQuantity()
	local backpack = self.Backpack or self.Player:FindFirstChild("Backpack")
	if not backpack then
		return 0
	end

	local wood = backpack:FindFirstChild("Wood")
	if not wood then
		return 0
	end

	local quantity = wood:FindFirstChild("Quantity")
	if quantity and quantity:IsA("ValueBase") then
		return tonumber(quantity.Value) or 0
	end

	return 0
end

function Controller:BindWoodQuantityWatcher()
	if self.WoodQuantityConnection then
		self.WoodQuantityConnection:Disconnect()
		self.WoodQuantityConnection = nil
	end

	local backpack = self.Backpack or self.Player:FindFirstChild("Backpack")
	if not backpack then
		return
	end

	local function hookWood(wood)
		if not wood or wood.Name ~= "Wood" then
			return
		end

		local quantity = wood:FindFirstChild("Quantity")

		if not quantity or not quantity:IsA("ValueBase") then
			return
		end

		if self.WoodQuantityConnection then
			self.WoodQuantityConnection:Disconnect()
			self.WoodQuantityConnection = nil
		end

		self.WoodQuantityConnection = quantity:GetPropertyChangedSignal("Value"):Connect(function()
			if self.AutoSellWoodEnabled and self.AutoSellWoodInstant and (tonumber(quantity.Value) or 0) >= self.AutoSellWoodMinimum then
				self:AutoTreeSellWood(true)
			end
		end)

		if self.AutoSellWoodEnabled and self.AutoSellWoodInstant and (tonumber(quantity.Value) or 0) >= self.AutoSellWoodMinimum then
			self:AutoTreeSellWood(true)
		end
	end

	local existingWood = backpack:FindFirstChild("Wood")
	if existingWood then
		hookWood(existingWood)
	end

	table.insert(self.BackpackConnections, backpack.ChildAdded:Connect(function(child)
		if child.Name == "Wood" then
			task.wait(0.05)
			hookWood(child)
		end
	end))
end

function Controller:GetAutoSellWoodNPC()
	local npcFolder = workspace:FindFirstChild("NPC")
	local npc = npcFolder and npcFolder:FindFirstChild(self.AutoSellWoodNPCName or "ChuckB")

	if not npc then
		return nil, nil
	end

	local npcPart = nil

	if npc:IsA("BasePart") then
		npcPart = npc
	elseif npc:IsA("Model") then
		-- Use the torso first so the sell click aims at ChuckB's body, not a random part.
		npcPart = npc:FindFirstChild("Torso", true)
			or npc:FindFirstChild("UpperTorso", true)
			or npc:FindFirstChild("HumanoidRootPart", true)
			or npc.PrimaryPart
			or npc:FindFirstChildWhichIsA("BasePart", true)
	elseif npc:IsA("Folder") then
		npcPart = npc:FindFirstChild("Torso", true)
			or npc:FindFirstChild("UpperTorso", true)
			or npc:FindFirstChild("HumanoidRootPart", true)
			or npc:FindFirstChildWhichIsA("BasePart", true)
	end

	return npc, npcPart
end

