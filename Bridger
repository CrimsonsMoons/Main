	return workspace:FindFirstChild("Chests")
end

function Controller:IsPromptInsideChest(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then
		return false
	end

	local folder = self:GetChestFolder()
	if not folder then
		return false
	end

	return prompt:IsDescendantOf(folder)
end

function Controller:SetChestPromptInstant(prompt)
	if not self.InstantChestPromptsEnabled then
		return false
	end

	if not self.AutoFishingEnabled then
		return false
	end

	if not self:IsPromptInsideChest(prompt) then
		return false
	end

	if self.InstantChestPromptOriginalHold[prompt] == nil then
		self.InstantChestPromptOriginalHold[prompt] = prompt.HoldDuration
	end

	if prompt.HoldDuration ~= 0 then
		pcall(function()
			prompt.HoldDuration = 0
		end)
	end

	return true
end

function Controller:RestoreInstantChestPrompts()
	if not self.InstantChestPromptOriginalHold then
		return
	end

	for prompt, oldHold in pairs(self.InstantChestPromptOriginalHold) do
		if prompt and prompt.Parent then
			pcall(function()
				prompt.HoldDuration = oldHold
			end)
		end

		self.InstantChestPromptOriginalHold[prompt] = nil
	end
end

function Controller:UpdateInstantChestPrompts(force)
	if not self.InstantChestPromptsEnabled then
		return
	end

	if not self.AutoFishingEnabled then
		self:RestoreInstantChestPrompts()
		return
	end

	local now = os.clock()
	if not force and now - (self.LastInstantChestPromptUpdate or 0) < (self.InstantChestPromptUpdateRate or 0.25) then
		return
	end

	self.LastInstantChestPromptUpdate = now

	local folder = self:GetChestFolder()
	if not folder then
		return
	end

	for _, obj in ipairs(folder:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			self:SetChestPromptInstant(obj)
		end
	end
end

function Controller:BindInstantChestPrompts()
	self:UpdateInstantChestPrompts(true)

	table.insert(self.Connections, workspace.DescendantAdded:Connect(function(obj)
		if not obj:IsA("ProximityPrompt") then
			return
		end

		task.defer(function()
			task.wait(0.03)

			if self.AutoFishingEnabled then
				self:SetChestPromptInstant(obj)
			end
		end)
	end))

	table.insert(self.Connections, workspace.DescendantRemoving:Connect(function(obj)
		if obj:IsA("ProximityPrompt") and self.InstantChestPromptOriginalHold then
			self.InstantChestPromptOriginalHold[obj] = nil
		end
	end))
end

