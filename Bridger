function Controller:CreateBobberDetectionBox()
	if not self:IsAlive() or not self.RootPart then
		return
	end

	local root = self.RootPart
	local objects = self.BobberDetectionBoxObjects

	-- Old version moved 4 anchored workspace parts every update.
	-- This version attaches the box to HumanoidRootPart so Roblox follows smoothly.
	if objects.Attachments and objects.RootPart == root then
		return
	end

	self:DestroyBobberDetectionBox()

	local folder = Instance.new("Folder")
	folder.Name = "_BobberDetectionBox"
	folder.Parent = workspace

	local attachments = {}

	for i = 1, 4 do
		local attachment = Instance.new("Attachment")
		attachment.Name = "BobberBoxA" .. tostring(i)
		attachment.Parent = root
		attachments[i] = attachment
	end

	local beams = {}

	for i = 1, 4 do
		local beam = Instance.new("Beam")
		beam.Name = "BoxLine" .. tostring(i)
		beam.Attachment0 = attachments[i]
		beam.Attachment1 = attachments[(i % 4) + 1]
		beam.FaceCamera = true
		beam.Width0 = 0.06
		beam.Width1 = 0.06
		beam.LightEmission = 0.75
		beam.Transparency = NumberSequence.new(0.18)
		beam.Color = ColorSequence.new(self.BobberDetectionBoxColor)
		beam.Enabled = false
		beam.Parent = folder
		beams[i] = beam
	end

	self.BobberDetectionBoxObjects = {
		Folder = folder,
		RootPart = root,
		Attachments = attachments,
		Beams = beams,
		LastRange = nil,
		LastYOffset = nil,
		LastColorKey = nil,
	}
end


function Controller:SetBobberDetectionBoxVisible(visible)
	local objects = self.BobberDetectionBoxObjects

	if objects.Beams then
		for _, beam in ipairs(objects.Beams) do
			if beam.Enabled ~= visible then
				beam.Enabled = visible
			end
		end
	end
end


function Controller:DestroyBobberDetectionBox()
	self.BobberDetectionBoxLastPositions = nil

	local objects = self.BobberDetectionBoxObjects

	if objects.Beams then
		for _, beam in ipairs(objects.Beams) do
			if beam and beam.Parent then
				beam:Destroy()
			end
		end
	end

	if objects.Attachments then
		for _, attachment in ipairs(objects.Attachments) do
			if attachment and attachment.Parent then
				attachment:Destroy()
			end
		end
	end

	if objects.Folder and objects.Folder.Parent then
		objects.Folder:Destroy()
	end

	self.BobberDetectionBoxObjects = {}
end

function Controller:GetBobberBoxYLevel()
	local root = self.RootPart
	if not root then
		return nil
	end

	return root.Position.Y - 1
end



function Controller:UpdateBobberDetectionBox()
	if not self.BobberDetectionBoxEnabled or not self.AutoFishingEnabled or not self:IsAlive() then
		self:SetBobberDetectionBoxVisible(false)
		return
	end

	self:CreateBobberDetectionBox()

	local objects = self.BobberDetectionBoxObjects
	if not objects.Attachments or objects.RootPart ~= self.RootPart then
		self:DestroyBobberDetectionBox()
		self:CreateBobberDetectionBox()
		objects = self.BobberDetectionBoxObjects
	end

	if not objects.Attachments then
		return
	end

	local root = self.RootPart
	local range = self.MAX_BOBBER_DISTANCE
	local yLevel = self:GetBobberBoxYLevel()

	if not root or not yLevel then
		self:SetBobberDetectionBoxVisible(false)
		return
	end

	-- Local attachment positions. Since they are parented to HumanoidRootPart,
	-- the box follows the player smoothly without moving anchored parts every frame.
	local yOffset = math.clamp(yLevel - root.Position.Y, -8, 8)

	if objects.LastRange ~= range or objects.LastYOffset ~= yOffset then
		local positions = {
			Vector3.new(-range, yOffset, range),
			Vector3.new(range, yOffset, range),
			Vector3.new(range, yOffset, -range),
			Vector3.new(-range, yOffset, -range),
		}

		for i, attachment in ipairs(objects.Attachments) do
			if attachment and attachment.Parent then
				attachment.Position = positions[i]
			end
		end

		objects.LastRange = range
		objects.LastYOffset = yOffset
	end

	local waiting = self:HasNearbyCurrentBobber()
	local colorKey = waiting and "Waiting" or "Normal"
	local color = waiting and self.FishingVisualizerWaitingColor or self.BobberDetectionBoxColor

	if objects.LastColorKey ~= colorKey and objects.Beams then
		local sequence = ColorSequence.new(color)

		for _, beam in ipairs(objects.Beams) do
			if beam and beam.Parent then
				beam.Color = sequence
			end
		end

		objects.LastColorKey = colorKey
	end

	self:SetBobberDetectionBoxVisible(true)
end

function Controller:GetFishingVisualizerColor()
	if not self.AutoFishingEnabled then
		return self.FishingVisualizerBlockedColor, "AUTO FISH OFF"
	end

	if self.awaitingBobberAfterCast then
