function Controller:GetAutoSellWoodPostSellClickPoint()
	local x = tonumber(self.AutoSellWoodPostSellClickX) or 1458
	local y = tonumber(self.AutoSellWoodPostSellClickY) or 1138
	return x, y
end

function Controller:ClickAutoSellWoodPostSellSpot()
	local x, y = self:GetAutoSellWoodPostSellClickPoint()
	local repeats = math.max(1, math.floor(tonumber(self.AutoSellWoodPostSellClickRepeats) or 2))

	local ok = pcall(function()
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default

		-- Move to the exact post-sell spot first and let Roblox register the new mouse position.
		VirtualInputManager:SendMouseMoveEvent(x, y, game)
		task.wait(self.AutoSellWoodPostSellMoveSettle or 0.12)

		-- Right click once to lock/set the new mouse position.
		VirtualInputManager:SendMouseButtonEvent(x, y, 1, true, game, 1)
		task.wait(self.AutoSellWoodPostSellRightClickHold or 0.08)
		VirtualInputManager:SendMouseButtonEvent(x, y, 1, false, game, 1)

		task.wait(self.AutoSellWoodPostSellAfterRightClickDelay or 0.18)

		-- Move again after the right click, then left click the same exact point.
		for _ = 1, repeats do
			VirtualInputManager:SendMouseMoveEvent(x, y, game)
			task.wait(0.025)
			VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
			task.wait(self.AutoSellWoodPostSellLeftClickHold or 0.06)
			VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
			task.wait(0.06)
		end
	end)

	if ok then
		self:SetStatus("Post wood sell right-click locked and clicked")
	else
		self:SetStatus("Post wood sell click failed")
	end

	return ok
end

function Controller:WaitForAutoSellWoodToFinish(previousWood, timeout)
	timeout = timeout or self.AutoSellWoodSoldWaitTimeout or 1.65
	local startedAt = os.clock()
	local minimum = self.AutoSellWoodMinimum or 1

	while os.clock() - startedAt < timeout do
		local currentWood = self:GetWoodQuantity()

		if currentWood < math.max(1, minimum) then
			return true
		end

		if previousWood and currentWood < previousWood then
			return true
		end

		if not self:IsWoodSellDialogueOpen() and currentWood <= 0 then
			return true
		end

		task.wait(0.05)
	end

	return false
end

function Controller:SpamAutoSellWoodDialogueSpotUntil(stopCheck, timeout)
	timeout = timeout or self.AutoSellWoodDialogueSpamTimeout or 2.4
	local startedAt = os.clock()
	local clicked = false

	self:RightClickLockAutoSellWoodDialogueSpot()

	while self.AutoSellWoodBusy and os.clock() - startedAt < timeout do
		if type(stopCheck) == "function" then
			local shouldStop = false
			pcall(function()
				shouldStop = stopCheck() == true
			end)

			if shouldStop then
				return clicked
			end
		end

		if self:ClickAutoSellWoodAbsoluteDialogueSpot() then
			clicked = true
		end

		if type(stopCheck) == "function" then
			local shouldStopAfterClick = false
			pcall(function()
				shouldStopAfterClick = stopCheck() == true
			end)

			if shouldStopAfterClick then
				return clicked
			end
		end

		task.wait(self.AutoSellWoodDialogueSpamRate or 0.05)
	end

	return clicked
end

function Controller:ClickGuiObjectCenter(guiObject)
	if not guiObject or not guiObject:IsA("GuiObject") then
		return false
	end

	local x, y = self:GetGuiObjectClickPoint(guiObject)
	if not x or not y then
		return false
	end

	-- Main click: exact center of the matched top-level dialogue row.
	local clicked = self:ClickGuiObjectAtPoint(guiObject, x, y)
	if clicked then
		return true
	end

	-- Fallback: if a scaled UI/executor still clicks a little high, nudge lower
	-- inside the same row instead of hitting the row above it.
	local size = guiObject.AbsoluteSize
	return self:ClickGuiObjectAtPoint(guiObject, x, y + math.floor(math.max(4, size.Y * 0.18)))
end

function Controller:KeyboardActivateGuiObject(guiObject)
	if not self.AutoSellWoodUseKeyboardFallback then
		return false
	end

	if not guiObject or not guiObject:IsA("GuiObject") then
		return false
	end

	local ok = pcall(function()
		local guiService = game:GetService("GuiService")
		guiService.SelectedObject = guiObject
		task.wait(0.03)
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
		task.wait(0.045)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
		task.wait(0.03)
		guiService.SelectedObject = nil
	end)

	return ok
end

function Controller:KeyboardWoodSellFallback()
	if not self.AutoSellWoodUseKeyboardFallback then
		return false
	end

	local ok = pcall(function()
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Down, false, game)
		task.wait(0.035)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Down, false, game)
		task.wait(0.055)
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
		task.wait(0.045)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
	end)

	return ok
end

function Controller:ActivateWoodSellChoiceText(expectedText, timeout)
	local choice = self:WaitForWoodSellChoiceByText(expectedText, timeout or 1.5)

	if choice then
		-- Primary path: mouse-click the exact middle of the matching dialogue row.
		local clickX, clickY = self:GetGuiObjectClickPoint(choice)
		local clicked = false

		if clickX and clickY then
			clicked = self:ClickGuiObjectAtPoint(choice, clickX, clickY)
		end

		if not clicked then
			local size = choice.AbsoluteSize
			if clickX and clickY and size then
				clicked = self:ClickGuiObjectAtPoint(choice, clickX, clickY + math.floor(math.max(4, size.Y * 0.18)))
			end
		end

		if clicked then
			-- If the first dialogue click is correct, reuse this exact screen spot
			-- for the next dialogue instead of recalculating and hitting the row above.
			if self:NormalizeDialogueText(expectedText) == self:NormalizeDialogueText(self.AutoSellWoodFirstChoiceText or "I have some wood to sell.") and clickX and clickY then
				self.AutoSellWoodLastDialogueClickX = clickX
				self.AutoSellWoodLastDialogueClickY = clickY
			end

			return true
		end

		-- Backup only if the mouse click fails.
		return self:KeyboardActivateGuiObject(choice)
	end

	return false
end

function Controller:ActivateWoodSellChoiceSameSpot(expectedText, timeout)
	local clickX = self.AutoSellWoodLastDialogueClickX
	local clickY = self.AutoSellWoodLastDialogueClickY

	if not clickX or not clickY then
		return false
	end

	timeout = timeout or 1.5

	-- Do not click instantly after the first option. Wait until the second option
	-- is actually present and stable, then click the same screen coordinate that
	-- worked for the first dialogue.
	local expectedChoice = expectedText and self:WaitForWoodSellChoiceStableByText(
		expectedText,
		timeout,
		self.AutoSellWoodSecondChoiceStableTime or 0.28
	) or nil

	if expectedChoice then
		task.wait(self.AutoSellWoodBeforeSecondClickDelay or 0.12)
		return self:ClickGuiObjectAtPoint(expectedChoice, clickX, clickY)
	end

	-- Last-resort fallback: if the dialogue is visible but text search failed,
	-- wait a small beat before reusing the same working spot.
	if self:IsWoodSellDialogueOpen() then
		task.wait(self.AutoSellWoodBeforeSecondClickDelay or 0.12)
		return self:ClickGuiObjectAtPoint(nil, clickX, clickY)
	end

	return false
end

function Controller:ActivateWoodSellChoice2(timeout)
	local choice = self:WaitForWoodSellChoice2(timeout or 1.5)

	if choice then
		local clicked = self:ClickGuiObjectCenter(choice)

		if clicked then
			return true
		end

		return self:KeyboardActivateGuiObject(choice)
	end

	return self:KeyboardWoodSellFallback()
end

function Controller:GetAutoSellWoodStandCFrame(npcPart)
	if not npcPart then
		return nil
	end

	local distance = self.AutoSellWoodNPCDistance or 2.15
	local heightOffset = self.AutoSellWoodNPCHeightOffset or 0
	local forward = npcPart.CFrame.LookVector

	-- Teleport/lock once directly in front of ChuckB and face his torso.
	local targetPosition = npcPart.Position + (forward * distance) + Vector3.new(0, heightOffset, 0)
	local lookAt = npcPart.Position

	if (lookAt - targetPosition).Magnitude > 0.1 then
		return CFrame.lookAt(targetPosition, lookAt)
	end

	return CFrame.new(targetPosition)
end

function Controller:ApplyAutoSellWoodCameraLock()
	if not self:IsAlive() then
		return false
	end

	local _, npcPart = self:GetAutoSellWoodNPC()
	local camera = workspace.CurrentCamera or Camera

	if not npcPart or not camera then
		return false
	end

	if not self.AutoSellWoodSavedCameraState then
		self.AutoSellWoodSavedCameraState = {
			CameraType = camera.CameraType,
			CameraSubject = camera.CameraSubject,
			CFrame = camera.CFrame,
			FieldOfView = camera.FieldOfView,
			CameraMode = self.Player.CameraMode,
			CameraMinZoomDistance = self.Player.CameraMinZoomDistance,
			CameraMaxZoomDistance = self.Player.CameraMaxZoomDistance,
			MouseBehavior = UserInputService.MouseBehavior,
		}
	end

	local root = self.RootPart
	local cameraPosition = root.Position + Vector3.new(0, 1.45, 0)
	local torsoPosition = npcPart.Position

	pcall(function()
		self.Player.CameraMinZoomDistance = 0.5
		self.Player.CameraMaxZoomDistance = 0.5
		self.Player.CameraMode = Enum.CameraMode.LockFirstPerson
		camera.CameraType = Enum.CameraType.Scriptable
		camera.FieldOfView = self.AutoSellWoodCameraFOV or 35
		camera.CFrame = CFrame.lookAt(cameraPosition, torsoPosition)
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	end)

	return true
end

function Controller:RestoreAutoSellWoodCameraLock()
	local state = self.AutoSellWoodSavedCameraState
	if not state then
		return
	end

	local camera = workspace.CurrentCamera or Camera

	pcall(function()
		if camera then
			camera.CameraType = state.CameraType or Enum.CameraType.Custom
			camera.CameraSubject = state.CameraSubject
			camera.FieldOfView = state.FieldOfView or 70
			if state.CFrame then
				camera.CFrame = state.CFrame
			end
		end

		self.Player.CameraMode = state.CameraMode or Enum.CameraMode.Classic
		self.Player.CameraMinZoomDistance = state.CameraMinZoomDistance or 0.5
		self.Player.CameraMaxZoomDistance = state.CameraMaxZoomDistance or 128
		UserInputService.MouseBehavior = state.MouseBehavior or Enum.MouseBehavior.Default
	end)

	self.AutoSellWoodSavedCameraState = nil
end

function Controller:StartAutoSellWoodPositionLock()
	if not self:IsAlive() then
		return false
	end

	local _, npcPart = self:GetAutoSellWoodNPC()
	local standCFrame = npcPart and self:GetAutoSellWoodStandCFrame(npcPart)

	if not standCFrame then
		return false
	end

	self.AutoSellWoodPositionLockToken += 1
	local token = self.AutoSellWoodPositionLockToken
	self.AutoSellWoodPositionLockActive = true

	-- Initial one-time teleport into the front spot.
	self.RootPart.CFrame = standCFrame
	self.RootPart.AssemblyLinearVelocity = Vector3.zero
	self.RootPart.AssemblyAngularVelocity = Vector3.zero
	self:ApplyAutoSellWoodCameraLock()

	task.spawn(function()
		while self.AutoSellWoodBusy and self.AutoSellWoodPositionLockActive and self.AutoSellWoodPositionLockToken == token do
			if not self:IsAlive() then
				break
			end

			local _, liveNpcPart = self:GetAutoSellWoodNPC()
			local liveStandCFrame = liveNpcPart and self:GetAutoSellWoodStandCFrame(liveNpcPart)

			if not liveStandCFrame then
				break
			end

			self.RootPart.CFrame = liveStandCFrame
			self.RootPart.AssemblyLinearVelocity = Vector3.zero
			self.RootPart.AssemblyAngularVelocity = Vector3.zero
			self:ApplyAutoSellWoodCameraLock()
			task.wait(0.015)
		end
	end)

	return true
end

function Controller:StopAutoSellWoodPositionLock()
	self.AutoSellWoodPositionLockActive = false
	self.AutoSellWoodPositionLockToken += 1
	self:RestoreAutoSellWoodCameraLock()
end

function Controller:TeleportToAutoSellWoodNPC()
	if not self:IsAlive() then
