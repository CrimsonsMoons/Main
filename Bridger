function Controller:GetFlatDirection(vector, fallback)
	local flat = Vector3.new(vector.X, 0, vector.Z)
	if flat.Magnitude <= 0.01 then
		return fallback
	end
	return flat.Unit
end

function Controller:RespawnWalkTo(targetPosition, timeout, facingDirection)
	if not self:IsAlive() then
		return false
	end

	timeout = tonumber(timeout) or self.RespawnWalkStepTimeout or 2.25
	local tolerance = tonumber(self.RespawnWalkMoveTolerance) or 2.25
	local humanoid = self.Humanoid
	local root = self.RootPart
	local reached = false
	local startedAt = os.clock()
	local flatFace = self:GetFlatDirection(facingDirection or root.CFrame.LookVector, Vector3.new(0, 0, -1))

	pcall(function()
		humanoid.PlatformStand = false
		humanoid.Sit = false
		humanoid.AutoRotate = true
		humanoid:ChangeState(Enum.HumanoidStateType.Running)
	end)

	-- Hold jump like a real player while walking. No CFrame teleport fallback here.
	pcall(function()
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
	end)

	while self:IsAlive() and os.clock() - startedAt < timeout do
		local currentPosition = root.Position
		local offset = Vector3.new(
			targetPosition.X - currentPosition.X,
			0,
			targetPosition.Z - currentPosition.Z
		)

		local distance = offset.Magnitude
		if distance <= tolerance then
			reached = true
			break
		end

		local moveDirection = offset.Unit

		pcall(function()
			humanoid:Move(moveDirection, false)

			if self.RespawnWalkJumpSpamEnabled then
				humanoid.Jump = true
			end
		end)

		task.wait(0.03)
	end

	pcall(function()
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
	end)

	if self:IsAlive() then
		pcall(function()
			humanoid:Move(Vector3.zero, false)
			humanoid.Jump = false
			root.AssemblyAngularVelocity = Vector3.zero

			local finalPosition = root.Position
			root.CFrame = CFrame.lookAt(finalPosition, finalPosition + flatFace)
		end)
	end

	return reached
end

function Controller:StartRespawnWalkRoutine()
	if self.RespawnWalkBusy then
		return
	end

	-- Only do the respawn auto-walk when Auto Tree was actually enabled.
	-- This keeps normal fishing / CFrame Speed / other features from being interrupted.
	if self.RespawnWalkOnlyWhenAutoTreeEnabled ~= false and not self.AutoTreeEnabled then
		return
	end

	self.RespawnWalkToken += 1
	local token = self.RespawnWalkToken

	self:PauseEffectsForRespawnWalk()

	task.spawn(function()
		task.wait(self.RespawnWalkStartDelay or 0.55)

		if token ~= self.RespawnWalkToken or not self:IsAlive() then
			self:RestoreEffectsAfterRespawnWalk()
			return
		end

		local startCFrame = self.RootPart.CFrame
		local forward = self:GetFlatDirection(startCFrame.LookVector, Vector3.new(0, 0, -1))
		local right = self:GetFlatDirection(startCFrame.RightVector, Vector3.new(1, 0, 0))

		self:SetStatus("Respawn pause: walking 25 forward + jump spam")
		self:RespawnWalkTo(self.RootPart.Position + (forward * (self.RespawnWalkForwardStuds or 25)), self.RespawnWalkStepTimeout, forward)

		if token ~= self.RespawnWalkToken or not self:IsAlive() then
			self:RestoreEffectsAfterRespawnWalk()
			return
		end

		task.wait(0.08)
		self:SetStatus("Respawn pause: walking 25 right + jump spam")
		self:RespawnWalkTo(self.RootPart.Position + (right * (self.RespawnWalkRightStuds or 25)), self.RespawnWalkStepTimeout, forward)

		if self:IsAlive() then
			pcall(function()
				local finalPosition = self.RootPart.Position
				self.RootPart.CFrame = CFrame.lookAt(finalPosition, finalPosition + forward)
				self.RootPart.AssemblyLinearVelocity = Vector3.zero
				self.RootPart.AssemblyAngularVelocity = Vector3.zero
			end)
		end

		task.wait(0.12)
		self:RestoreEffectsAfterRespawnWalk()
	end)
end

