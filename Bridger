function Controller:StartFishingCycle()
	if not self.AutoFishingEnabled then return end
	if not self:IsAlive() then return end
	if not self:CanRecast() then return end

	self:SetStatus("Starting cast")
	self.lastRecastTime = os.clock()

	if not self:StartReliableCast("start cycle") then
		task.delay(self.CastRetryDelay, function()
			if self.AutoFishingEnabled and not self.awaitingBobberAfterCast and self:CanRecast() then
				self:QueueRecast("start retry")
			end
		end)
	end
end

function Controller:ToggleAutoFishing(forceState)
	local nextState

	if typeof(forceState) == "boolean" then
		nextState = forceState
	else
		nextState = not self.AutoFishingEnabled
	end

	if self.AutoFishingEnabled == nextState then
		self:RefreshToggleButtons()
		return
	end

	self.AutoFishingEnabled = nextState

	if not self.AutoFishingEnabled then
		self:ReleaseAutoInteractKey()

		self.interactHoldToken += 1
		self.interactState.holding = false
		self.interactState.gui = nil
		self.usingBaitAfterCatch = false
		self.fishingState.recastQueued = false
		self.fishingState.currentBobber = nil
		self.awaitingBobberAfterCast = false
		self.clickedRecently = false
		self.CastInProgress = false
		self.CastLockUntil = 0
		self:ResetFishingState()
		self:SetFishingVisualizerVisible(false)
		self:SetBobberDetectionBoxVisible(false)
		self:RestoreInstantChestPrompts()
		self:SetStatus("Auto fishing OFF")
		self:Notify("Auto fishing OFF")
	else
		self.clickedRecently = false
		self.fishingState.recastQueued = false
		self.awaitingBobberAfterCast = false
		self.lastRecastTime = 0
		self.lastValidFishingAction = os.clock()
		self:SetStatus("Auto fishing ON")
		self:UpdateInstantChestPrompts(true)
		self:Notify("Auto fishing ON")

		task.spawn(function()
			self:WaitUntilCharacterStable()
			if self.AutoFishingEnabled then
				self:StartFishingCycle()
			end
		end)
	end

	self:RefreshToggleButtons()
end


function Controller:IsSaintsPointLightTarget(obj)
	if not obj or not obj:IsA("BasePart") then
		return false
	end

	if obj.Parent ~= workspace then
		return false
	end

	if not tostring(obj.Name):match("^Saints") then
		return false
	end

	if not obj:FindFirstChild("PointLight") then
		return false
	end

	if obj.Transparency >= 1 then
		return false
	end

	return true
end

function Controller:CreateSaintsPointLightTextESP(part)
	if not self:IsSaintsPointLightTarget(part) then
		return
	end

	if self.CreateTextESP then
		self:CreateTextESP(part, self.SaintsPointLightTextESPObjects, "SaintsLight")
	end
end

function Controller:RemoveSaintsPointLightTextESP(part)
	if self.RemoveTextESP then
		self:RemoveTextESP(part, self.SaintsPointLightTextESPObjects)
		return
	end

	local data = self.SaintsPointLightTextESPObjects[part]
	if data then
		for _, obj in pairs(data) do
			if typeof(obj) == "Instance" and obj.Parent then
				obj:Destroy()
			end
		end
	end

	self.SaintsPointLightTextESPObjects[part] = nil
end

function Controller:CreateSaintsPointLightESP(part)
	if not self:IsSaintsPointLightTarget(part) then
		return
	end

	local pointLight = part:FindFirstChild("PointLight")
	if not pointLight then
		return
	end

	pointLight.Enabled = true
	pointLight.Color = self.SaintsPointLightESPColor
	pointLight.Brightness = self.SaintsPointLightESPBrightness
	pointLight.Range = self.SaintsPointLightESPRange
	pointLight.Shadows = false

	self.SaintsPointLightESPObjects[part] = pointLight
	self:CreateSaintsPointLightTextESP(part)
end

function Controller:RemoveSaintsPointLightESP(part)
	local light = self.SaintsPointLightESPObjects[part]

	if light and light.Parent then
		light.Enabled = false
	end

	self.SaintsPointLightESPObjects[part] = nil
	self:RemoveSaintsPointLightTextESP(part)
end

function Controller:UpdateSaintsPointLightESP()
	if not self.SaintsPointLightESPEnabled then
		for part in pairs(self.SaintsPointLightESPObjects) do
			self:RemoveSaintsPointLightESP(part)
		end

		return
	end

	if os.clock() - self.lastSaintsPointLightESPUpdate < self.SaintsPointLightESPRate then
		return
	end

	self.lastSaintsPointLightESPUpdate = os.clock()

	for _, part in ipairs(workspace:GetChildren()) do
		if self:IsSaintsPointLightTarget(part) then
			self:CreateSaintsPointLightESP(part)
		end
	end

	for part in pairs(self.SaintsPointLightESPObjects) do
		if not self:IsSaintsPointLightTarget(part) then
			self:RemoveSaintsPointLightESP(part)
		end
	end

	if self.UpdateTextESP then
		self:UpdateTextESP(self.SaintsPointLightTextESPObjects)
	end
end


function Controller:UpdateStatusGui()
	if not self.GuiObjects.ScreenGui or not self.GuiObjects.ScreenGui.Parent then
		self.GuiObjects = {}
		self:CreateStatusGui()
	end

	local now = os.clock()
	if now - self.lastStatusUpdate < self.statusUpdateInterval then
		return
	end

	self.lastStatusUpdate = now
	self:ApplyResponsiveGui(false)
	self:UpdateAutoTreeStopOverlay()

	if not self.GuiObjects.StatusLabel or not self.GuiObjects.StatusLabel.Parent then
		return
	end

	local currentState = "Idle"

	if not self.AutoFishingEnabled then
		currentState = "Paused"
	elseif self.usingBaitAfterCatch then
		currentState = "Using Bait"
	elseif self.interactState.holding then
		currentState = "Interact"
	elseif self.fishingState.minigameActive then
		currentState = "Minigame"
	elseif self:HasNearbyCurrentBobber() then
		currentState = "Bobber Active"
	elseif self.fishingState.recastQueued then
		currentState = "Recast Queued"
	elseif self.awaitingBobberAfterCast then
		currentState = "Waiting Bobber"
	end

	local velocity = 0
	if self.RootPart then
		velocity = math.floor(self.RootPart.AssemblyLinearVelocity.Magnitude + 0.5)
	end

	local bobberText = self:HasNearbyCurrentBobber() and "Yes" or "No"
	local baitText = self:HasBait() and "Yes" or "No"
	self:RecountFish()
	local woodAmount = self:GetWoodQuantity()

	local fishMinimum = tonumber(self.AutoSellFishMinimumEach) or 15
	local codAmount = tonumber(self.FishCounts.Cod) or 0
	local snapperAmount = tonumber(self.FishCounts.Snapper) or 0
	local bassAmount = tonumber(self.FishCounts.Bass) or 0
	local codNeeded = math.max(0, fishMinimum - codAmount)
	local snapperNeeded = math.max(0, fishMinimum - snapperAmount)
	local bassNeeded = math.max(0, fishMinimum - bassAmount)
	local fishReadyToSell = codNeeded <= 0 and snapperNeeded <= 0 and bassNeeded <= 0
	local fishNeededText

	if fishReadyToSell then
		fishNeededText = "READY | Cod " .. tostring(codAmount) .. "/" .. tostring(fishMinimum) .. " | Snapper " .. tostring(snapperAmount) .. "/" .. tostring(fishMinimum) .. " | Bass " .. tostring(bassAmount) .. "/" .. tostring(fishMinimum)
	else
		fishNeededText = "Need Cod " .. tostring(codNeeded) .. " | Snapper " .. tostring(snapperNeeded) .. " | Bass " .. tostring(bassNeeded)
	end

	local woodMinimum = tonumber(self.AutoSellWoodMinimum) or 50
	local woodNeeded = math.max(0, woodMinimum - (tonumber(woodAmount) or 0))
	local woodNeededText = woodNeeded <= 0
		and ("READY | Wood " .. tostring(woodAmount) .. "/" .. tostring(woodMinimum))
		or ("Need " .. tostring(woodNeeded) .. " more wood | " .. tostring(woodAmount) .. "/" .. tostring(woodMinimum))

	self.GuiObjects.StatusLabel.Text =
		"Auto Fish: " .. tostring(self.AutoFishingEnabled) .. "\n" ..
		"Sell Fish: " .. tostring(self.AutoSellEnabled) .. " | Sell Wood: " .. tostring(self.AutoSellWoodEnabled) .. "\n" ..
		"Fish Needed: " .. fishNeededText .. "\n" ..
		"Wood Needed: " .. woodNeededText .. "\n" ..
		"Sell Status: " .. tostring(self.AutoSellStatusText or "Idle") .. "\n" ..
		"Last Fish Sell: " .. tostring(self.AutoSellLastFishSoldText or "None yet") .. "\n" ..
		"Last Wood Sell: " .. tostring(self.AutoSellLastWoodSoldText or "None yet") .. "\n" ..
		"Buy Bait: " .. tostring(self.AutoBuyBaitEnabled) .. "\n" ..
		"Use Bait: " .. tostring(self.AutoUseBaitAfterCatchEnabled) .. "\n" ..
		"Chest/Saints: " .. tostring(self.ChestESPEnabled) .. " | Entity ESP: " .. tostring(self.EntityESPEnabled) .. "\n" ..
		"CFrame Speed: " .. tostring(self.CFrameSpeedEnabled) .. " (65) | Position Lock: " .. tostring(self.PositionEnforcerEnabled) .. " | Visualizer: " .. tostring(self.FishingVisualizerEnabled) .. "\n" ..
		"State: " .. currentState .. "\n" ..
		"Action: " .. tostring(self.status.lastAction) .. "\n" ..
		"Cod: " .. tostring(codAmount) .. " | Snapper: " .. tostring(snapperAmount) .. " | Bass: " .. tostring(bassAmount) .. "\n" ..
		"Fish Total: " .. tostring(self.FishCounts.Total) .. "\n" ..
		"Bait: " .. baitText .. "\n" ..
		"Bobber: " .. bobberText .. "\n" ..
		"Velocity: " .. tostring(velocity) .. "\n" ..
		"Keys: RightCtrl GUI | L Fish | K Chest\n" ..
		"Keys: J Entity | B CFrame Speed | P Lock\n" ..
		"Auto Tree Stop: F"

	if self.GuiObjects.LogLabel then
		self.GuiObjects.LogLabel.Text = self:GetActionLogText()
	end

	self:RefreshToggleButtons()
end

function Controller:BindFishing()
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Sound") then
			self:HookSound(obj)
		end
	end

	table.insert(self.Connections, workspace.DescendantAdded:Connect(function(obj)
		if obj:IsA("Sound") then
			task.wait(0.05)
			self:HookSound(obj)
		end
	end))

	table.insert(self.Connections, PlayerGui.DescendantAdded:Connect(function(obj)
		if obj.Name == "MashingSystem" or obj.Name == "Container" or obj.Name == "Circle" or obj.Name == "KeyLabel" then
			task.wait(0.05)
			self:RefreshMashGuiRefs()
		end
	end))

	table.insert(self.Connections, PlayerGui.DescendantRemoving:Connect(function(obj)
		if self.mashGuiRefs and (
			obj == self.mashGuiRefs.mashingSystem
			or obj == self.mashGuiRefs.container
			or obj == self.mashGuiRefs.circle
			or obj == self.mashGuiRefs.keyLabel
		) then
			self.mashGuiRefs = nil
		end

		if self.interactState.gui and obj == self.interactState.gui then
			self.interactState.gui = nil

			if self.AutoFishingEnabled or self.interactState.autoKeyDown then
				self:StopHoldingE()
			else
				self.interactState.holding = false
			end
		end
	end))

	table.insert(self.Connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if input.KeyCode == self.AUTO_TREE_STOP_KEY and self.AutoTreeEnabled then
			if UserInputService:GetFocusedTextBox() then return end
			self:SetAutoTreeEnabled(false)
			self:SetStatus("Auto Tree stopped with F")
			return
		end

		if gameProcessed then return end

		if input.KeyCode == self.GUI_TOGGLE_KEY then
			self:ToggleStatusGui()
		elseif input.KeyCode == self.FISH_TOGGLE_KEY then
			self:ToggleAutoFishing()
		elseif input.KeyCode == self.CHEST_ESP_TOGGLE_KEY then
			self:ToggleChestESP()
		elseif input.KeyCode == self.ENTITY_ESP_TOGGLE_KEY then
			self:ToggleEntityESP()
		elseif input.KeyCode == self.CFRAME_SPEED_TOGGLE_KEY then
			self:ToggleCFrameSpeed()
		elseif input.KeyCode == self.POSITION_ENFORCER_TOGGLE_KEY then
			self:TogglePositionEnforcer()
		end
	end))
end

function Controller:OnStep(dt)
	dt = dt or 0

	if not self.Enabled or not self:IsAlive() then
		return
	end

	if self.RespawnWalkBusy then
		self:UpdateStatusGui()
		return
	end

	if tick() < self.RespawnGraceUntil then
		self:UpdateStatusGui()
		return
	end

	local anyExtraEnabled =
		self.AutoFishingEnabled
		or self.AutoSellEnabled
		or self.AutoSellWoodEnabled
		or self.ChestESPEnabled
		or self.EntityESPEnabled
		or self.CFrameSpeedEnabled
		or self.PositionEnforcerEnabled
		or self.AutoTreeEnabled

	if not anyExtraEnabled then
		self:UpdateStatusGui()
		return
	end

	self:UpdateCFrameSpeed(dt)
	self:UpdatePositionEnforcer(dt)
	self:UpdateAutoTree(dt)

	if self.AutoFishingEnabled then
		local now = os.clock()

		if now - self.lastMaintenanceUpdate >= self.MaintenanceUpdateRate then
			self.lastMaintenanceUpdate = now
			self:SetBadStatesDisabled()
			self:RemoveForces(false)
			self:UpdateSafePosition()
			self:ClampMovement()
			self:HardAntiKnockback()
			self:AntiFall()
			self:ForceStand()
		end
	else
		self:UpdateSafePosition()
	end

	self:ClearFarBobberIfNeeded()
	self:RefreshNearbyBobber()

	if not self.mashGuiRefs or not self.mashGuiRefs.keyLabel or not self.mashGuiRefs.keyLabel.Parent then
		self:RefreshMashGuiRefs()
	end

	if self.AutoFishingEnabled then
		-- Chest interaction is object-based now.
		-- Do NOT scan PlayerGui:GetDescendants() for Hold E every frame; that was the lag spike.
		self.interactState.gui = nil

		if not self.interactState.holding and not self.AutoChestInteractBusy and not self.interactState.autoKeyDown then
			local mashVisible = self:IsMashVisible()

			if mashVisible then
				self.fishingState.minigameActive = true
				self.fishingState.minigameSeen = true
				self:SetStatus("Mashing minigame")
			end

			if self.fishingState.minigameActive and not mashVisible then
				self.fishingState.minigameActive = false
				self.fishingState.waitingForCatchFinish = true
				self:SetStatus("Minigame finished - checking chest")
				self:RequestPostMinigameChestReact("minigame finished")

				if not self:HasNearbyCurrentBobber() then
					task.delay(self.PostMinigameRecastDelay, function()
						if not self.AutoFishingEnabled then return end
						if self.fishingState.minigameActive then return end
						if self.AutoChestInteractBusy or self.ChestPositionOverrideActive or self.ChestPositionOverrideReturning then return end
						if self:TryReactToAnyChest("minigame finished") then return end
						if not self:HasNearbyCurrentBobber() then
							self:QueueRecast("minigame finished")
						end
					end)
				end
			end

			local text = self:GetCurrentMashText()
			if text then
				local keyCode = self.VALID_MASH_KEYS[text]
				if keyCode then
					local now = os.clock()
					if now - self.lastMashPressTime >= self.MASH_PRESS_COOLDOWN then
						self.lastMashPressTime = now
						self:SetStatus("Pressing " .. text)

						task.spawn(function()
							self:PressMashKey(keyCode)
						end)
					end
				end
			end
		end
	else
		-- Do not spam E-up while Auto Fish is OFF.
		-- Only clean up if the script itself was holding E.
		if self.interactState.holding or self.interactState.gui or self.interactState.autoKeyDown then
			self:StopHoldingE()
		end
	end

	if self.AutoFishingEnabled then
		if not self.AutoSellFishBusy and not self.AutoSellWoodBusy then
			self:TryStuckCastRecovery()
			self:BuyBaitIfMissing()
		end
	end

	self:UpdateStandaloneAutoSells(false)

	self:UpdateChestPositionOverride(dt)
	self:UpdateInstantChestPrompts(false)
	self:UpdateAutoChestInteract()

	self:UpdateChestESP()
	self:UpdateSaintsPointLightESP()
	self:UpdateEntityESP()
	self:UpdateFishingVisualizer()
	self:UpdateStatusGui()
end

function Controller:BindCharacter(isRespawn)
	self.RespawnGraceUntil = tick() + 1.25

	self:DisconnectAll()
	self:DisconnectBackpackConnections()
	self:DisconnectChestESPConnections()
	self:DisconnectEntityESPConnections()
	self:DestroyFishingVisualizer()
	self:DestroyPositionEnforcerArrow()

	self:CacheCharacter()
	self:CacheBackpack()
	self:RemoveForces(true)

	table.clear(self.CachedEntityAdornees)
	table.clear(self.ChestDangerCache)

	self.trackedBobbers = {}
	self.hookedSounds = {}
	self.lastMashPressTime = 0
	self.AutoTreeTarget = nil
	self.AutoTreeTargetBark = nil
	self.AutoTreeUsingFallback = false
	self.AutoTreeFallbackTargetCFrame = nil
	self.AutoTreeFallbackDirection = 1
	self.AutoTreeLastCFrameSpawnCheck = 0
	self.AutoTreeFallbackLinkedTree = nil
	self.AutoTreeFallbackLinkedBark = nil
	self.AutoTreeFallbackArrivedAt = 0
	self.AutoTreeFallbackSwingCount = 0
	self.AutoTreeIsMoving = false
	self.AutoTreeArrivedAtTarget = 0
	self.AutoSellWoodBusy = false
	self.AutoSellFishBusy = false
	self.AutoSellFishPositionLockActive = false
	self.AutoSellFishPositionLockToken += 1
	self.CastInProgress = false
	self.CastLockUntil = 0
	self.lastMaintenanceUpdate = 0
	self.lastBobberScan = 0
	self.lastHoldGUIScan = 0
		self.clickedRecently = false
	self.mashGuiRefs = nil
	self.interactState.gui = nil
	self.lastCastAttemptTime = os.clock()
	self.lastValidFishingAction = os.clock()
	self.lastBobberSeenTime = 0
	self.lastInteractHoldTime = 0
	self.BaitBoughtThisLife = false
	self.usingBaitAfterCatch = false
	self.interactLockoutUntil = 0
	self.interactHoldToken += 1

	self:StopHoldingE()
	self.awaitingBobberAfterCast = false
	self:ResetFishingState()
	self:RefreshMashGuiRefs()
	self:BindBackpackWatcher()
	self:CreateStatusGui()
	self:BindFishing()
	self:BindInstantChestPrompts()
	self:BindChestESP()
	self:BindEntityESP()
	self:UpdateAutoTreeStopOverlay()

	if isRespawn then
		self:StartRespawnWalkRoutine()
	end

	if self.AutoTreeEnabled then
		task.defer(function()
			task.wait(0.05)
			self.AutoTreeNoclipEnabled = true
			self:BindAutoTreeNoclipWatcher()
			self:SetCharacterNoclip(true)
			self:PickAutoTreeTarget(true)
		end)
	end

	if self.PositionEnforcerDisableOnDeath and self.PositionEnforcerEnabled then
		self:DisablePositionEnforcerOnDeath()
	end

	table.insert(self.Connections, self.Humanoid.StateChanged:Connect(function(_, newState)
		if not self.Enabled then return end

		if self.AutoFishingEnabled and self.BlockedStates[newState] then
			self:ForceStand()
		end
	end))
	table.insert(self.Connections, self.Humanoid.Died:Connect(function()
		if self.PositionEnforcerDisableOnDeath then
			self:DisablePositionEnforcerOnDeath()
		end
	end))


	table.insert(self.Connections, self.Character.DescendantAdded:Connect(function(desc)
		if self.AutoTreeEnabled then
			if desc:IsA("BasePart") then
				if self.AutoTreeNoClipOriginal[desc] == nil then
					self.AutoTreeNoClipOriginal[desc] = {
						CanCollide = desc.CanCollide,
						CanTouch = desc.CanTouch,
						CanQuery = desc.CanQuery,
					}
				end

				desc.CanCollide = false
				desc.CanTouch = false
				desc.CanQuery = false
			elseif self.ForceRemovers[desc.ClassName] then
				pcall(function()
					desc:Destroy()
				end)
			end
		end

		if not self.Enabled or not self.AutoFishingEnabled then
			return
		end

		self:BlockBadDescendants(desc)
	end))

	table.insert(self.Connections, RunService.Heartbeat:Connect(function(dt)
		self:OnStep(dt)
	end))
end

function Controller:Start()
	self:BindCharacter(false)

	if self.CharacterConnection then
		self.CharacterConnection:Disconnect()
	end

	self.CharacterConnection = self.Player.CharacterAdded:Connect(function()
		task.wait(0.15)
		self:BindCharacter(true)
	end)

	self:SetStatus("Auto fishing OFF")
	self:Notify("Auto fishing OFF")
	print("enjoy lowkey")
end

local AntiFish = Controller.new()
AntiFish:Start()
