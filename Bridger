    CRIMMY SCRIPTZ // MAIN SCRIPT AUTH LOCK
    This must stay at the VERY TOP of the main script.
    If the loader did not verify the key first, the script stops here.
    ================================================================
]]

do
    local AUTH_CHANNEL = "__CRIMMY_ACCESS_TERMINAL_V2"
    local EXPECTED_SECRET = "CrimyXD_Key"

    local function getEnv()
        local okEnv, env = pcall(function()
            return getgenv and getgenv()
        end)

        if okEnv and type(env) == "table" then
            return env
        end

        return nil
    end

    local function getAuthSession(env)
        local session = rawget(_G, AUTH_CHANNEL)
        if type(session) == "table" then
            return session
        end

        if type(env) == "table" then
            session = rawget(env, AUTH_CHANNEL)
            if type(session) == "table" then
                return session
            end
        end

        return nil
    end

    local function clearAuthSession(env)
        pcall(function()
            _G[AUTH_CHANNEL] = nil
        end)

        if type(env) == "table" then
            pcall(function()
                env[AUTH_CHANNEL] = nil
            end)
        else
            local freshEnv = getEnv()
            if type(freshEnv) == "table" then
                pcall(function()
                    freshEnv[AUTH_CHANNEL] = nil
                end)
            end
        end
    end

    local function block(reason)
        warn("[CRIMMY SCRIPTZ] Unauthorized load blocked: " .. tostring(reason or "unknown"))
        return false
    end

    local env = getEnv()
    local session = getAuthSession(env)
    local authorized = false

    if type(session) ~= "table" then
        block("missing loader session")
    elseif session.Secret ~= EXPECTED_SECRET then
        block("bad secret")
    elseif session.Verified ~= true then
        block("not verified")
    elseif type(session.Token) ~= "string" or session.Token == "" then
        block("missing token")
    elseif type(session.ExpiresAt) ~= "number" or os.clock() > session.ExpiresAt then
        block("expired session")
    elseif type(session.Consume) ~= "function" then
        block("missing validator")
    else
        local ok, passed, msg = pcall(function()
            return session:Consume(session.Token)
        end)

        if ok and passed == true then
            authorized = true
        else
            block(msg or "validator rejected")
        end
    end

    if not authorized then
        clearAuthSession(env)
        return
    end

    -- Clear after use so the same auth cannot be reused by another direct load.
    clearAuthSession(env)
end

