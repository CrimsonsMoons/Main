function Controller:GetChoiceListSignature()
	local _, mainFrame, choiceList = self:GetWoodSellDialogueObjects()
	if not mainFrame or not choiceList or not self:IsGuiActuallyVisible(mainFrame) then
		return "closed"
	end

	local parts = {}

	for _, child in ipairs(choiceList:GetChildren()) do
		if child:IsA("GuiObject") and self:IsGuiActuallyVisible(child) then
			local textParts = {}

			local function addText(obj)
				if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
					local text = self:NormalizeDialogueText(obj.Text)
					if text ~= "" then
						table.insert(textParts, text)
					end
				end
			end

			addText(child)
			for _, desc in ipairs(child:GetDescendants()) do
				addText(desc)
			end

			table.insert(parts, tostring(child.Name) .. ":" .. table.concat(textParts, "|"))
		end
	end

	return table.concat(parts, "||")
end

function Controller:GetGuiNavigationTarget(guiObject)
	if not guiObject or not guiObject:IsA("GuiObject") then
		return nil
	end

	-- Prefer the top-level row when it is selectable. This avoids selecting a tiny
	-- inner TextLabel/TextButton and accidentally activating the row above or below.
	local row = guiObject
	local _, _, choiceList = self:GetWoodSellDialogueObjects()

	if choiceList then
		local current = guiObject
		while current and current ~= choiceList do
			if current.Parent == choiceList and current:IsA("GuiObject") then
				row = current
				break
			end
			current = current.Parent
		end
	end

	if row and row:IsA("GuiButton") and self:IsGuiActuallyVisible(row) and row.AbsoluteSize.X > 0 and row.AbsoluteSize.Y > 0 then
		return row
	end

	if guiObject:IsA("GuiButton") and self:IsGuiActuallyVisible(guiObject) and guiObject.AbsoluteSize.X > 0 and guiObject.AbsoluteSize.Y > 0 then
		return guiObject
	end

	local bestButton = nil
	local bestArea = -1
	local searchRoot = row or guiObject

	for _, desc in ipairs(searchRoot:GetDescendants()) do
		if desc:IsA("GuiButton") and self:IsGuiActuallyVisible(desc) and desc.AbsoluteSize.X > 0 and desc.AbsoluteSize.Y > 0 then
			local area = desc.AbsoluteSize.X * desc.AbsoluteSize.Y
			if area > bestArea then
				bestArea = area
				bestButton = desc
			end
		end
	end

	if bestButton then
		return bestButton
	end

	-- Last resort: some custom dialogue rows are Frames with Selectable enabled.
	if row and row:IsA("GuiObject") and self:IsGuiActuallyVisible(row) and row.AbsoluteSize.X > 0 and row.AbsoluteSize.Y > 0 then
		return row
	end

	return guiObject
end

function Controller:IsGuiChoiceReady(guiObject)
	if not guiObject or not guiObject:IsA("GuiObject") then
		return false
	end

	if not guiObject.Parent or not self:IsGuiActuallyVisible(guiObject) then
		return false
	end

	local size = guiObject.AbsoluteSize
	return size.X > 4 and size.Y > 4
end

function Controller:WaitForGuiChoiceReady(guiObject, timeout, stableTime)
	timeout = timeout or self.GuiNavReadyTimeout or 1.25
	stableTime = stableTime or self.GuiNavStableTime or 0.08

	local startedAt = os.clock()
	local stableStartedAt = nil

	while os.clock() - startedAt < timeout do
		if self:IsGuiChoiceReady(guiObject) then
			stableStartedAt = stableStartedAt or os.clock()
			if os.clock() - stableStartedAt >= stableTime then
				return true
			end
		else
			stableStartedAt = nil
		end

		task.wait(0.025)
	end

	return false
end

function Controller:PressEnterForGuiNavigation(useSpaceFallback)
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
	task.wait(0.045)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)

	if useSpaceFallback and self.GuiNavUseSpaceFallback then
		task.wait(0.035)
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
		task.wait(0.045)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
	end
end

function Controller:GuiNavigateAndEnterChoice(choice, options)
	options = options or {}

	if not choice or not choice:IsA("GuiObject") or not self:IsGuiActuallyVisible(choice) then
		return false
	end

	local target = self:GetGuiNavigationTarget(choice)
	if not target then
		return false
	end

	if not self:WaitForGuiChoiceReady(target, options.ReadyTimeout or self.GuiNavReadyTimeout, options.StableTime or self.GuiNavStableTime) then
		return false
	end

	local guiService = game:GetService("GuiService")
	local retries = math.max(1, math.floor(tonumber(options.Retries or self.GuiNavRetryCount) or 3))
	local oldSignature = self:GetChoiceListSignature()
	local succeeded = false
	local pressed = false

	for attempt = 1, retries do
		local ok = pcall(function()
			pcall(function()
				target.Selectable = true
				if target:IsA("GuiButton") then
					target.AutoButtonColor = true
				end
			end)

			-- Clear first so Roblox does not keep a stale selected object from the old menu.
			guiService.SelectedObject = nil
			task.wait(0.025)
			guiService.SelectedObject = target
			task.wait(options.SelectSettle or self.GuiNavSelectSettle or 0.08)

			-- If another object stole selection, force it back once before pressing Enter.
			if guiService.SelectedObject ~= target then
				guiService.SelectedObject = target
				task.wait(0.04)
			end

			self:PressEnterForGuiNavigation(attempt >= 2)
		end)

		if ok then
			pressed = true
			local afterWait = options.AfterEnterWait or self.GuiNavAfterEnterWait or 0.18
			local waitUntil = os.clock() + afterWait

			while os.clock() < waitUntil do
				local newSignature = self:GetChoiceListSignature()
				if newSignature ~= oldSignature or not target.Parent or not self:IsGuiActuallyVisible(target) then
					succeeded = true
					break
				end
				task.wait(0.025)
			end

			-- Some menus keep the same button names/text after activation. If the key press
			-- was accepted but the UI did not visibly change yet, still allow one retry.
			if succeeded then
				break
			end
		end

		task.wait(options.RetryDelay or self.GuiNavRetryDelay or 0.08)
	end

	if self.GuiNavClearSelectionAfterPress ~= false then
		pcall(function()
			if guiService.SelectedObject == target then
				guiService.SelectedObject = nil
			end
		end)
	end

	if not succeeded and self.GuiNavUseClickFallback then
		-- Disabled by default, but useful if a specific executor ignores GUI nav Enter.
		succeeded = self:ClickGuiObjectCenter(target)
	end

	return succeeded or pressed
end

function Controller:WaitForWoodSellChoiceByName(choiceName, timeout)
	local startedAt = os.clock()
	timeout = timeout or 1.5

	while os.clock() - startedAt < timeout do
		local choice = self:GetWoodSellChoiceByName(choiceName)

		if choice and choice.Parent and self:IsGuiActuallyVisible(choice) then
			local target = self:GetGuiNavigationTarget(choice)
			if target and self:WaitForGuiChoiceReady(target, 0.35, self.GuiNavStableTime or 0.08) then
				return choice
			end
		end

		task.wait(0.035)
	end

	return nil
end

function Controller:WaitForDialogueChoicePriority(choiceNames, timeout)
	timeout = timeout or 1
	local startedAt = os.clock()

	while os.clock() - startedAt < timeout do
		for _, choiceName in ipairs(choiceNames) do
			local choice = self:GetWoodSellChoiceByName(choiceName)
			if choice then
				local target = self:GetGuiNavigationTarget(choice)
				if target and self:IsGuiChoiceReady(target) then
					return choice, choiceName
				end
			end
		end

		task.wait(0.03)
	end

	return nil, nil
end

function Controller:RunWoodSellGuiNavigationFlow()
	local clickedAnything = false
	local choice2Clicks = 0

	-- The wood dialogue uses Choice_2 twice in a row. Select Choice_2 and press Enter
	-- each time it appears, then use Choice_1 only when Choice_2 is no longer there.
	while self.AutoSellWoodBusy and choice2Clicks < 2 do
		local choice2 = self:WaitForWoodSellChoiceByName("Choice_2", 3)

		if not choice2 then
			break
		end

		self:SetStatus("GUI navigating Choice_2 [" .. tostring(choice2Clicks + 1) .. "/2]")
		if self:GuiNavigateAndEnterChoice(choice2, { Retries = 4, ReadyTimeout = 1.1, SelectSettle = 0.07, AfterEnterWait = 0.16 }) then
			clickedAnything = true
			choice2Clicks += 1
		end

		task.wait(choice2Clicks == 1 and (self.AutoSellWoodAfterFirstChoiceDelay or 0.75) or (self.AutoSellWoodAfterSecondClickDelay or 0.25))
	end

	-- If there is no Choice_2 after those steps, hit Choice_1 as the fallback/close option.
	if self.AutoSellWoodBusy and not self:GetWoodSellChoiceByName("Choice_2") then
		local choice1 = self:WaitForWoodSellChoiceByName("Choice_1", 1.4)
		if choice1 then
			self:SetStatus("GUI navigating Choice_1 fallback")
			if self:GuiNavigateAndEnterChoice(choice1, { Retries = 3, ReadyTimeout = 0.9, SelectSettle = 0.07, AfterEnterWait = 0.16 }) then
				clickedAnything = true
			end
		end
	end

	return clickedAnything, choice2Clicks
end

function Controller:GetWoodSellDialogueObjects()
	local dialogueGui = PlayerGui:FindFirstChild("DialogueGui")
	if not dialogueGui then return nil, nil, nil end

	local mainFrame = dialogueGui:FindFirstChild("MainFrame")
	if not mainFrame then return dialogueGui, nil, nil end

	local choiceList = mainFrame:FindFirstChild("ChoiceList")
	return dialogueGui, mainFrame, choiceList
end

function Controller:IsWoodSellDialogueOpen()
	local _, mainFrame, choiceList = self:GetWoodSellDialogueObjects()
	if not mainFrame or not choiceList then
		return false
	end

	if not self:IsGuiActuallyVisible(mainFrame) then
		return false
	end

	return true
end

function Controller:NormalizeDialogueText(text)
	text = tostring(text or "")
	text = text:gsub("%s+", " ")
	text = text:match("^%s*(.-)%s*$") or text
	return text
end

function Controller:ChoiceHasExactText(choice, expectedText)
	if not choice or not expectedText then
		return false
	end

	local wanted = self:NormalizeDialogueText(expectedText)

	local function checkTextObject(obj)
		if not (obj:IsA("TextButton") or obj:IsA("TextLabel") or obj:IsA("TextBox")) then
			return false
		end

		return self:NormalizeDialogueText(obj.Text) == wanted
	end

	if choice:IsA("TextButton") or choice:IsA("TextLabel") or choice:IsA("TextBox") then
		if checkTextObject(choice) then
			return true
		end
	end

	for _, desc in ipairs(choice:GetDescendants()) do
		if checkTextObject(desc) then
			return true
		end
	end

	return false
end

function Controller:GetWoodSellChoiceClickRoot(guiObject, choiceList)
	if not guiObject or not choiceList then
		return guiObject
	end

	local current = guiObject
	local best = guiObject:IsA("GuiObject") and guiObject or nil

	while current and current ~= choiceList do
		if current:IsA("GuiObject") then
			best = current
		end

		if current.Parent == choiceList then
			return current:IsA("GuiObject") and current or best
		end

		current = current.Parent
	end

	return best
end

function Controller:GetWoodSellChoiceByText(expectedText)
	local _, mainFrame, choiceList = self:GetWoodSellDialogueObjects()
	if not mainFrame or not choiceList then
		return nil
	end

	if not self:IsGuiActuallyVisible(mainFrame) then
		return nil
	end

	-- First pass checks the direct rows. If the text is inside a label, this still
	-- returns the full Choice row instead of the inner label.
	for _, choice in ipairs(choiceList:GetChildren()) do
		if choice:IsA("GuiObject") and self:IsGuiActuallyVisible(choice) and self:ChoiceHasExactText(choice, expectedText) then
			return self:GetWoodSellChoiceClickRoot(choice, choiceList)
		end
	end

	-- Second pass checks nested text objects, then climbs back to the real row.
	for _, desc in ipairs(choiceList:GetDescendants()) do
		if desc:IsA("GuiObject") and self:IsGuiActuallyVisible(desc) and self:ChoiceHasExactText(desc, expectedText) then
			return self:GetWoodSellChoiceClickRoot(desc, choiceList)
		end
	end

	return nil
end

function Controller:WaitForWoodSellChoiceByText(expectedText, timeout)
	local startedAt = os.clock()
	timeout = timeout or 1.5

	while os.clock() - startedAt < timeout do
		local choice = self:GetWoodSellChoiceByText(expectedText)

		if choice and choice.Parent and self:IsGuiActuallyVisible(choice) then
			return choice
		end

		task.wait(0.035)
	end

	return nil
end

function Controller:WaitForWoodSellChoiceStableByText(expectedText, timeout, stableTime)
	local startedAt = os.clock()
	timeout = timeout or 1.5
	stableTime = stableTime or 0.2

	local stableChoice = nil
	local stableStartedAt = nil

	while os.clock() - startedAt < timeout do
		local choice = self:GetWoodSellChoiceByText(expectedText)

		if choice and choice.Parent and self:IsGuiActuallyVisible(choice) then
			if choice ~= stableChoice then
				stableChoice = choice
				stableStartedAt = os.clock()
			elseif stableStartedAt and os.clock() - stableStartedAt >= stableTime then
				return choice
			end
		else
			stableChoice = nil
			stableStartedAt = nil
		end

		task.wait(0.045)
	end

	return nil
end

function Controller:UnequipAutoSellWoodTools()
	if not self:IsAlive() or not self.Humanoid then
		return false
	end

	pcall(function()
		self.Humanoid:UnequipTools()
	end)

	-- Backup for odd executor/game states where UnequipTools does not move the
	-- equipped tool fast enough before clicking ChuckB.
	pcall(function()
		local backpack = self.Backpack or self.Player:FindFirstChild("Backpack")
		if backpack and self.Character then
			for _, child in ipairs(self.Character:GetChildren()) do
				if child:IsA("Tool") then
					child.Parent = backpack
				end
			end
		end
	end)

	task.wait(0.08)
	return true
end

