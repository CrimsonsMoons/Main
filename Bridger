function Controller:ApplyResponsiveGui(force)
	local frame = self.GuiObjects.Frame
	local scale = self.GuiObjects.ResponsiveScale
	local grid = self.GuiObjects.GridLayout
	local statusCard = self.GuiObjects.StatusCard
	local toggleCard = self.GuiObjects.ToggleCard
	local logCard = self.GuiObjects.LogCard

	if not frame or not scale then return end

	local viewport = Camera and Camera.ViewportSize or Vector2.new(1280, 720)

	if not force and self.lastViewportSize and self.lastViewportSize == viewport then
		return
	end

	self.lastViewportSize = viewport

	local compact = viewport.X < 760 or viewport.Y < 560
	local tiny = viewport.X < 520 or viewport.Y < 440

	if tiny then
		frame.Size = UDim2.new(0, 330, 0, 360)

		if not frame:GetAttribute("UserDragged") then
			frame.AnchorPoint = Vector2.new(0, 0)
			frame.Position = UDim2.new(0, 10, 0, 10)
		end

		scale.Scale = math.clamp(math.min(viewport.X / 360, viewport.Y / 360), 0.72, 0.9)

		if statusCard then statusCard.Size = UDim2.new(1, 0, 0, 166) end
		if toggleCard then toggleCard.Size = UDim2.new(1, 0, 0, 166) end
		if logCard then logCard.Size = UDim2.new(1, 0, 0, 72) end
		if grid then grid.CellSize = UDim2.new(0.5, -4, 0, 25) end

	elseif compact then
		frame.Size = UDim2.new(0, 370, 0, 420)

		if not frame:GetAttribute("UserDragged") then
			frame.AnchorPoint = Vector2.new(0, 0.5)
			frame.Position = UDim2.new(0, 14, 0.5, 0)
		end

		scale.Scale = math.clamp(math.min(viewport.X / 780, viewport.Y / 580), 0.82, 0.96)

		if statusCard then statusCard.Size = UDim2.new(1, 0, 0, 190) end
		if toggleCard then toggleCard.Size = UDim2.new(1, 0, 0, 160) end
		if logCard then logCard.Size = UDim2.new(1, 0, 0, 92) end
		if grid then grid.CellSize = UDim2.new(0.5, -4, 0, 28) end

	else
		frame.Size = UDim2.new(0, 430, 0, 645)

		if not frame:GetAttribute("UserDragged") then
			frame.AnchorPoint = Vector2.new(0, 0.5)
			frame.Position = UDim2.new(0, 18, 0.5, 0)
		end

		scale.Scale = 1

		if statusCard then statusCard.Size = UDim2.new(1, 0, 0, 288) end
		if toggleCard then toggleCard.Size = UDim2.new(1, 0, 0, 206) end
		if logCard then logCard.Size = UDim2.new(1, 0, 0, 112) end
		if grid then grid.CellSize = UDim2.new(0.5, -4, 0, 30) end
	end
end

