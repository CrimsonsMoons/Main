function Controller:MoveToEnforcerCFrame(cf, dt)
	if not cf or not self:IsAlive() then
		return false
	end

	local root = self:GetRootFallback()
	if not root then
		return false
	end

	local targetPosition = cf.Position
	local offset = targetPosition - root.Position
	local horizontal = Vector3.new(offset.X, 0, offset.Z)
	local vertical = offset.Y
	local distance = offset.Magnitude
	local horizontalDistance = horizontal.Magnitude

	if distance <= self.PositionEnforcerTweenStopDistance then
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero

		local finalCFrame = CFrame.lookAt(targetPosition, targetPosition + cf.LookVector)

		if self.Character and self.Character.Parent then
			pcall(function()
				self.Character:PivotTo(finalCFrame)
			end)
		else
			root.CFrame = finalCFrame
		end

		self.PositionEnforcerReturning = false
		self.PositionEnforcerReturnTarget = nil
		self:RestoreEffectsAfterPositionReturn()
		return true
	end

	local dtSafe = math.max(dt or 0.016, 0.016)
	local horizontalStep = math.min(horizontalDistance, self.PositionEnforcerTweenSpeed * dtSafe)
	local verticalStep = math.clamp(vertical, -self.PositionEnforcerTweenVerticalSpeed * dtSafe, self.PositionEnforcerTweenVerticalSpeed * dtSafe)

	local move = Vector3.new(0, verticalStep, 0)

	if horizontalDistance > 0.01 then
		move += horizontal.Unit * horizontalStep
	end

	local nextPosition = root.Position + move
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	root.CFrame = CFrame.lookAt(nextPosition, nextPosition + cf.LookVector)

	self.PositionEnforcerReturning = true
	self.PositionEnforcerReturnTarget = cf
	return false
end

function Controller:ReturnToEnforcerCFrame(cf, dt)
	if not cf then
		return
	end

	if self.PositionEnforcerUseTween then
		self:MoveToEnforcerCFrame(cf, dt)
	else
		self:TeleportToEnforcerCFrame(cf)
	end
end

