	end

	if self.fishingState.minigameActive then
		return self.FishingVisualizerWaitingColor, "MINIGAME ACTIVE"
	end

	if self.interactState.holding or self.interactState.gui then
		return self.FishingVisualizerWaitingColor, "INTERACTING"
	end

	if self.clickedRecently then
		return self.FishingVisualizerWaitingColor, "CASTING"
	end

	if self:HasNearbyCurrentBobber() then
