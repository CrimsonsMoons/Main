function Controller:UpdateAutoTreeFPS(dt)
	local now = os.clock()
	local frameDt = dt or (now - (self.AutoTreeLastFrameTime or now))
	self.AutoTreeLastFrameTime = now

	if frameDt and frameDt > 0 then
		self.AutoTreeCurrentFPS = math.floor((1 / frameDt) + 0.5)
	end

	-- Locked universal tween speed.
	-- Movement is already time-based through speed * dt, so this keeps
	-- the same studs-per-second speed for every FPS.
	self.AutoTreeMoveSpeed = self.AutoTreeDefaultMoveSpeed
	self.AutoTreeVerticalSpeed = self.AutoTreeDefaultVerticalSpeed
	self.AutoTreeLowFPSBoostActive = false
	self.AutoTreeSpeedTier = "Locked"
end

function Controller:UpdateAutoTree(dt)
	if not self.AutoTreeEnabled then
		return
	end

	if not self:IsAlive() then
		return
	end

	self:UpdateAutoTreeFPS(dt)
	self:MaintainAutoTreeNoclip()
	self:MaintainAutoTreeAntiPhysics()

	self:AutoTreeSellWood()
	if self.AutoSellWoodBusy or self.AutoSellFishBusy then
		self.AutoTreeIsMoving = false
		return
	end

	if os.clock() - self.AutoTreeLastTargetRefresh >= self.AutoTreeTargetRefreshRate then
		self.AutoTreeLastTargetRefresh = os.clock()
		self:PickAutoTreeTarget(true)
	else
		self:PickAutoTreeTarget(false)
	end

	if self.AutoTreeUsingFallback and self.AutoTreeFallbackTargetCFrame then
		if self.AutoTreeWaitForBreak and not self:IsFallbackLinkedTreeAlive() then
			self:ResetAutoTreePointTween()
			self:AdvanceFallbackTreeCFrame()
			self.AutoTreeFallbackArrivedAt = 0
			self.AutoTreeFallbackSwingCount = 0
			self.AutoTreeFallbackLinkedTree = nil
			self.AutoTreeFallbackLinkedBark = nil

			if self.AutoTreeCheckCFrameSpawn then
				self.AutoTreeLastCFrameSpawnCheck = 0
				self.AutoTreeFallbackTargetCFrame = self:FindSpawnedTreeCFrameFromCurrent()
			else
				self.AutoTreeFallbackTargetCFrame = self:GetCurrentFallbackTreeCFrame()
				self:BindFallbackTreeToCurrentCFrame()
			end

			self:SetStatus("Tree broken, checking next spawn")
			return
		end

		local inRange = self:MoveToFallbackTreePoint(dt)

		if inRange then
			if self.AutoTreeFallbackArrivedAt <= 0 then
				self.AutoTreeFallbackArrivedAt = os.clock()
				self.AutoTreeFallbackSwingCount = 0
			end

			local before = self.AutoTreeLastSwing
			self:AutoTreeUseAxe()

			if self.AutoTreeLastSwing ~= before then
				self.AutoTreeFallbackSwingCount += 1
			end
		else
			self.AutoTreeFallbackArrivedAt = 0
			self.AutoTreeFallbackSwingCount = 0
		end

		return
	end

	self.AutoTreeFallbackArrivedAt = 0
	self.AutoTreeFallbackSwingCount = 0

	if not self.AutoTreeTarget or not self.AutoTreeTargetBark then
		return
	end

	if not self:IsValidTree(self.AutoTreeTarget) then
		self:ClearAutoTreeTarget("Tree broke, finding next")
		self:PickAutoTreeTarget(true)
		return
	end

	local inRange = self:MoveToAutoTreeTarget(dt)

	if inRange then
		self:AutoTreeUseAxe()
	end
end

