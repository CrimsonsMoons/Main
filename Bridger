function Controller:GetESPAdornee(obj)
	if not obj then return nil end

	if obj:IsA("BasePart") then
		return obj
	end

	if obj:IsA("Model") then
		if obj.PrimaryPart then
			return obj.PrimaryPart
		end

		local root = obj:FindFirstChild("HumanoidRootPart", true)
		if root and root:IsA("BasePart") then
			return root
		end

		local part = obj:FindFirstChildWhichIsA("BasePart", true)
		if part then
			return part
		end
	end

	return nil
end

function Controller:IsSelfObject(obj)
	if not obj then return false end
	if obj == self.Character then return true end

	if self.Character and obj:IsDescendantOf(self.Character) then
		return true
	end

	local model = obj:IsA("Model") and obj or obj:FindFirstAncestorOfClass("Model")
	if model and model == self.Character then
		return true
	end

	local playerFromModel = model and Players:GetPlayerFromCharacter(model)
	if playerFromModel and playerFromModel == self.Player then
		return true
	end

	return false
end

function Controller:GetAttributeSource(obj)
	if not obj then
		return nil
	end

	if obj:IsA("Model") then
		return obj
	end

	local model = obj:FindFirstAncestorOfClass("Model")
	return model or obj
end

function Controller:IsBlacklistedEntity(obj)
	if not self.EntityAttributeBlacklistEnabled then
		return false
	end

	local source = self:GetAttributeSource(obj)
	if not source then
		return false
	end

	-- Hard remove/blacklist anything that has Stat_Speed at all.
	-- Value does not matter.
	if source:GetAttribute("Stat_Speed") ~= nil then
		return true
	end

	for attributeName, expectedValue in pairs(self.EntityAttributeBlacklist) do
		if attributeName ~= "Stat_Speed" then
			local actualValue = source:GetAttribute(attributeName)

			if actualValue == nil then
				return false
			end

			if typeof(expectedValue) == "number" then
				if typeof(actualValue) ~= "number" then
					return false
				end

				if math.abs(actualValue - expectedValue) > self.EntityAttributeBlacklistTolerance then
					return false
				end
			else
				if actualValue ~= expectedValue then
					return false
				end
			end
		end
	end

	return true
end

function Controller:IsActuallyVisiblePart(part)
	if not part or not part:IsA("BasePart") then
		return false
	end

	if part.Transparency >= 1 then
		return false
	end

	if not part.Parent then
		return false
	end

	return true
end

function Controller:IsESPObjectVisible(obj)
	if not obj then
		return false
	end

	if obj:IsA("BasePart") then
		return self:IsActuallyVisiblePart(obj)
	end

	if obj:IsA("Model") or obj:IsA("Folder") then
		for _, desc in ipairs(obj:GetDescendants()) do
			if desc:IsA("BasePart") and self:IsActuallyVisiblePart(desc) then
				return true
			end
		end
	end

	return false
end

function Controller:IsCorpsePartObject(obj)
	return obj
		and obj:IsDescendantOf(workspace)
		and self.CorpsePartNames[obj.Name] == true
		and self:IsESPObjectVisible(obj)
end

function Controller:GetVisibleESPAdornee(obj)
	if not obj then
		return nil
	end

	if obj:IsA("BasePart") then
		return self:IsActuallyVisiblePart(obj) and obj or nil
	end

	if obj:IsA("Model") then
		if obj.PrimaryPart and self:IsActuallyVisiblePart(obj.PrimaryPart) then
			return obj.PrimaryPart
		end

		local root = obj:FindFirstChild("HumanoidRootPart", true)
		if root and root:IsA("BasePart") and self:IsActuallyVisiblePart(root) then
			return root
		end
	end

	if obj:IsA("Model") or obj:IsA("Folder") then
		for _, desc in ipairs(obj:GetDescendants()) do
			if desc:IsA("BasePart") and self:IsActuallyVisiblePart(desc) then
				return desc
			end
		end
	end

	return nil
end
function Controller:RefreshEntityCache(force)
	local now = os.clock()

	if not force and now - self.lastEntityCacheUpdate < self.EntityCacheUpdateRate then
		return
	end

	self.lastEntityCacheUpdate = now
	table.clear(self.CachedEntityAdornees)

	local folder = self:GetEntityFolder()
	if not folder then
		return
	end

	for _, entity in ipairs(folder:GetChildren()) do
		if not self:IsSelfObject(entity) and not self:IsBlacklistedEntity(entity) then
			local adornee = self:GetESPAdornee(entity)

			if adornee and adornee.Parent then
				table.insert(self.CachedEntityAdornees, {
					Name = entity.Name,
					Adornee = adornee,
				})
			end
		end
	end
end

function Controller:IsEntityNearPosition(position, range)
	self:RefreshEntityCache(false)

	local nearestName = nil
	local nearestDistance = math.huge

	for _, entry in ipairs(self.CachedEntityAdornees) do
		local adornee = entry.Adornee

		if adornee and adornee.Parent then
			local offset = adornee.Position - position

			if math.abs(offset.X) <= range and math.abs(offset.Y) <= range and math.abs(offset.Z) <= range then
				local distance = offset.Magnitude

				if distance < nearestDistance then
					nearestDistance = distance
					nearestName = entry.Name
				end
			end
		end
	end

	return nearestDistance <= range, nearestName, nearestDistance
end

function Controller:CreateTextESP(obj, espTable, kind)
	if espTable[obj] then return end

	if kind == "Entity" and (self:IsSelfObject(obj) or self:IsBlacklistedEntity(obj)) then
		return
	end

	local sourceAdornee = kind == "Corpse" and self:GetVisibleESPAdornee(obj) or self:GetESPAdornee(obj)
	if not sourceAdornee then return end

	local adornee = sourceAdornee

	local billboard = Instance.new("BillboardGui")
	billboard.Name = kind .. "TextESP"
	billboard.Adornee = adornee
	billboard.AlwaysOnTop = true
	billboard.LightInfluence = 0
	billboard.ResetOnSpawn = false
	billboard.Size = UDim2.new(0, 230, 0, 46)
	billboard.StudsOffset = Vector3.new(0, kind == "Entity" and 4.4 or 3.4, 0)
	billboard.Enabled = false
	billboard.Parent = PlayerGui

	local main = Instance.new("TextLabel")
	main.Name = "Main"
	main.BackgroundTransparency = 1
	main.Size = UDim2.new(1, 0, 0, 24)
	main.Position = UDim2.new(0, 0, 0, 0)
	main.Font = Enum.Font.GothamBold
	main.TextSize = kind == "Entity" and 16 or 14
	main.TextStrokeTransparency = 0.18
	main.TextXAlignment = Enum.TextXAlignment.Center
	main.TextYAlignment = Enum.TextYAlignment.Center
	main.Text = obj.Name
	main.Parent = billboard

	local distance = Instance.new("TextLabel")
	distance.Name = "Distance"
	distance.BackgroundTransparency = 1
	distance.Size = UDim2.new(1, 0, 0, 18)
	distance.Position = UDim2.new(0, 0, 0, 23)
	distance.Font = Enum.Font.GothamSemibold
	distance.TextSize = 12
	distance.TextStrokeTransparency = 0.25
	distance.TextXAlignment = Enum.TextXAlignment.Center
	distance.TextYAlignment = Enum.TextYAlignment.Center
	distance.Text = "0 studs"
	distance.Parent = billboard

	if kind == "Entity" then
		main.TextColor3 = Color3.fromRGB(255, 75, 75)
		main.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		distance.TextColor3 = Color3.fromRGB(255, 185, 185)
		distance.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	else
		main.TextColor3 = self.ChestSafeNameColor
		main.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		distance.TextColor3 = self.ChestSafeDistanceColor
		distance.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	end

	espTable[obj] = {
		Billboard = billboard,
		Main = main,
		Distance = distance,
		Adornee = adornee,
		SourceAdornee = sourceAdornee,
		Kind = kind,
	}
end

function Controller:RemoveTextESP(obj, espTable)
	local data = espTable[obj]
	if not data then return end

	if data.Billboard then
		data.Billboard:Destroy()
	end

	self.ChestDangerCache[obj] = nil

	espTable[obj] = nil
end

function Controller:ClearTextESP(espTable)
	for obj in pairs(espTable) do
		self:RemoveTextESP(obj, espTable)
	end
end

function Controller:ScanChestESP()
	local folder = self:GetChestFolder()

	if not folder then
		self:ClearTextESP(self.ChestESPObjects)
		return
	end

	for _, obj in ipairs(folder:GetChildren()) do
		local part = self:GetChestInteractAdornee(obj)
		local insideBox = part and self:IsChestInsideLineBox(obj, part)

		-- Chest ESP is its own feature, but it should not show chests
		-- that are already inside the yellow box visualizer.
		if insideBox then
			self:RemoveTextESP(obj, self.ChestESPObjects)
		elseif not self.ChestESPObjects[obj] then
			self:CreateTextESP(obj, self.ChestESPObjects, "Chest")
		end
	end

	for obj in pairs(self.ChestESPObjects) do
		local part = self:GetChestInteractAdornee(obj)
		local insideBox = part and self:IsChestInsideLineBox(obj, part)

		if not obj.Parent or not obj:IsDescendantOf(folder) or insideBox then
			self:RemoveTextESP(obj, self.ChestESPObjects)
		end
	end
end

function Controller:ScanEntityESP()
	local folder = self:GetEntityFolder()

	if not folder then
		self:ClearTextESP(self.EntityESPObjects)
		return
	end

	for _, obj in ipairs(folder:GetChildren()) do
		if not self.EntityESPObjects[obj] and not self:IsSelfObject(obj) and not self:IsBlacklistedEntity(obj) then
			self:CreateTextESP(obj, self.EntityESPObjects, "Entity")
		end
	end

	for obj in pairs(self.EntityESPObjects) do
		if not obj.Parent or not obj:IsDescendantOf(folder) or self:IsSelfObject(obj) or self:IsBlacklistedEntity(obj) then
			self:RemoveTextESP(obj, self.EntityESPObjects)
		end
	end
end

function Controller:UpdateESPGroup(espTable, enabled, maxDistance, warningEnabled)
	local nearestEntityName = nil
	local nearestEntityDistance = math.huge

	for obj, data in pairs(espTable) do
		if warningEnabled and (self:IsSelfObject(obj) or self:IsBlacklistedEntity(obj)) then
			self:RemoveTextESP(obj, espTable)
			continue
		end

		if data.Kind == "Corpse" and not self:IsCorpsePartObject(obj) then
			self:RemoveTextESP(obj, espTable)
			continue
		end

		local sourceAdornee = data.Kind == "Corpse" and self:GetVisibleESPAdornee(obj) or self:GetESPAdornee(obj)

		if not sourceAdornee or not sourceAdornee.Parent then
			self:RemoveTextESP(obj, espTable)
			continue
		end

		local adornee = sourceAdornee

		data.SourceAdornee = sourceAdornee
		data.Adornee = adornee

		if data.Billboard then
			data.Billboard.Adornee = adornee
		end

		local distance = 0

		if self.RootPart then
			distance = math.floor((adornee.Position - self.RootPart.Position).Magnitude + 0.5)
		end

		local inRange = enabled and distance <= maxDistance

		if data.Billboard then
			data.Billboard.Enabled = inRange
		end

		if data.Main then
			data.Main.Text = tostring(obj.Name)
		end

		if data.Distance then
			data.Distance.Text = tostring(distance) .. " studs"
		end

		if data.Kind == "Chest" then
			local dangerData = self.ChestDangerCache[obj]
			local now = os.clock()

			if not dangerData or now - dangerData.UpdatedAt >= self.ChestDangerCheckRate then
				local dangerNear, dangerName = self:IsEntityNearPosition(adornee.Position, self.ChestDangerDistance)

				dangerData = {
					Near = dangerNear,
					Name = dangerName,
					UpdatedAt = now,
				}

				self.ChestDangerCache[obj] = dangerData
			end

			if dangerData.Near then
				if data.Main then
					data.Main.TextColor3 = self.ChestDangerNameColor
					data.Main.Text = tostring(obj.Name) .. " ⚠"
				end

				if data.Distance then
					data.Distance.TextColor3 = self.ChestDangerDistanceColor
					data.Distance.Text = tostring(distance) .. " studs | " .. tostring(dangerData.Name) .. " near"
				end
			else
				if data.Main then
					data.Main.TextColor3 = self.ChestSafeNameColor
					data.Main.Text = tostring(obj.Name)
				end

				if data.Distance then
					data.Distance.TextColor3 = self.ChestSafeDistanceColor
					data.Distance.Text = tostring(distance) .. " studs"
				end
			end
		end

		if warningEnabled and inRange and distance < nearestEntityDistance then
			nearestEntityName = obj.Name
			nearestEntityDistance = distance
		end
	end

	if warningEnabled and nearestEntityName and nearestEntityDistance <= self.EntityWarningDistance then
		local now = os.clock()

		if now - self.lastEntityWarningAt >= self.EntityWarningCooldown then
			self.lastEntityWarningAt = now
			self:SetStatus("WARNING: Entity near - " .. nearestEntityName .. " [" .. nearestEntityDistance .. " studs]")
		end
	end
end

function Controller:UpdateChestESP()
	if not self.ChestESPEnabled then return end
	if os.clock() - self.lastChestESPUpdate < self.ChestESPUpdateRate then return end

	self.lastChestESPUpdate = os.clock()
	self:ScanChestESP()
	self:UpdateESPGroup(self.ChestESPObjects, self.ChestESPEnabled, self.ChestESPMaxDistance, false)
end

function Controller:UpdateEntityESP()
	if not self.EntityESPEnabled then return end
	if os.clock() - self.lastEntityESPUpdate < self.EntityESPUpdateRate then return end

	self.lastEntityESPUpdate = os.clock()
	self:RefreshEntityCache(false)
	self:ScanEntityESP()
	self:UpdateESPGroup(self.EntityESPObjects, self.EntityESPEnabled, self.EntityESPMaxDistance, true)
end

function Controller:SetChestESPEnabled(state)
	self.ChestESPEnabled = state and true or false
	self.SaintsPointLightESPEnabled = self.ChestESPEnabled

	if self.ChestESPEnabled then
		self:SetStatus("Chest/Saints ESP ON")
		self:ScanChestESP()
	else
		self:SetStatus("Chest/Saints ESP OFF")
		for _, data in pairs(self.ChestESPObjects) do
			if data.Billboard then data.Billboard.Enabled = false end
		end
	end
end

function Controller:SetEntityESPEnabled(state)
	self.EntityESPEnabled = state and true or false

	if self.EntityESPEnabled then
		self:SetStatus("Entity ESP ON")
		self:ScanEntityESP()
	else
		self:SetStatus("Entity ESP OFF")
		for _, data in pairs(self.EntityESPObjects) do
			if data.Billboard then data.Billboard.Enabled = false end
		end
	end
end

function Controller:ToggleChestESP()
	self:SetChestESPEnabled(not self.ChestESPEnabled)
end

function Controller:ToggleEntityESP()
	self:SetEntityESPEnabled(not self.EntityESPEnabled)
end


function Controller:BindChestESP()
	self:DisconnectChestESPConnections()

	local folder = self:GetChestFolder()
	if not folder then return end

	table.insert(self.ChestESPConnections, folder.ChildAdded:Connect(function(child)
		-- Interaction is priority. Start it immediately when a chest spawns.
		self:RequestFastChestInteract(child)

		task.defer(function()
			if not child.Parent then
				return
			end

			if self.ChestESPEnabled then
				local part = self:GetChestInteractAdornee(child)
				local insideBox = part and self:IsChestInsideLineBox(child, part)

				-- Chest ESP stays outside the yellow box.
				if not insideBox then
					self:CreateTextESP(child, self.ChestESPObjects, "Chest")
				end
			end
		end)
	end))

	table.insert(self.ChestESPConnections, folder.ChildRemoved:Connect(function(child)
		self:RemoveTextESP(child, self.ChestESPObjects)

		if self.CachedChestTarget == child then
			self:ClearChestTargetCache()
		end

		self.ActiveChestReactThreads[child] = nil
	end))
end

function Controller:GetChestInteractAdornee(chest)
	if not chest then
		return nil
	end

	if chest:IsA("BasePart") then
		return chest
	end

	if chest:IsA("Model") then
		if chest.PrimaryPart and chest.PrimaryPart:IsA("BasePart") then
			return chest.PrimaryPart
		end

		local root = chest:FindFirstChild("HumanoidRootPart", true)
		if root and root:IsA("BasePart") then
			return root
		end

		local part = chest:FindFirstChildWhichIsA("BasePart", true)
		if part then
			return part
		end
	end

	if chest:IsA("Folder") then
		return chest:FindFirstChildWhichIsA("BasePart", true)
	end

	return nil
end

function Controller:IsChestInteractSafe(chest, part)
	if not chest or not part then
		return false
	end

	if not part.Parent or not part:IsDescendantOf(workspace) then
		return false
	end

	return true
end

function Controller:GetLineBoxRange()
	return tonumber(self.ChestLineBoxRange) or tonumber(self.MAX_BOBBER_DISTANCE) or 35
end

function Controller:IsWorldPositionInsideLineBox(position)
	if not self.ChestScanOnlyInsideLineBox then
		return true
	end

	if not self.RootPart then
		return false
	end

	local range = self:GetLineBoxRange()
	local localPosition = self.RootPart.CFrame:PointToObjectSpace(position)

	-- Same square footprint as the yellow line/bobber box.
	-- Y is ignored because the visual line box is a flat area.
	return math.abs(localPosition.X) <= range and math.abs(localPosition.Z) <= range
end

function Controller:IsChestInsideLineBox(chest, part)
	if not self.ChestScanOnlyInsideLineBox then
		return true
	end

	part = part or self:GetChestInteractAdornee(chest)
	if not self:IsChestInteractSafe(chest, part) then
		return false
	end

	return self:IsWorldPositionInsideLineBox(part.Position)
end



function Controller:TryReactToAnyChest(reason)
	if not self.AutoFishingEnabled then
		return false
	end

	if self.ChestPositionOverrideActive or self.ChestPositionOverrideReturning then
		return true
	end

	if self.AutoChestInteractBusy then
		return true
	end

	if self.interactState.holding or self.fishingState.minigameActive or self.CastInProgress or self.clickedRecently or self.usingBaitAfterCatch then
		return false
	end

	local chest, part, distance = self:GetNearestChestInInteractRange(true)
	if chest and part then
		self.lastAutoChestInteractCheck = 0
		self:SetStatus("Chest react after " .. tostring(reason or "event"))
		self:HoldChestInteract(chest, part, distance)
		return true
	end

	-- No missed chest teleporting/moving.
	-- If no chest is already in interact range, ignore it.
	return false
end

function Controller:RequestPostMinigameChestReact(reason)
	if not self.AutoFishingEnabled then
		return
	end

	self.PostMinigameChestReactToken += 1
	local token = self.PostMinigameChestReactToken
	self.lastAutoChestInteractCheck = 0
	self:ClearChestTargetCache()

	task.spawn(function()
		local startedAt = os.clock()

		while os.clock() - startedAt <= self.PostMinigameChestReactWindow do
			if token ~= self.PostMinigameChestReactToken then
				return
			end

			if not self.AutoFishingEnabled then
				return
			end

			if self.AutoChestInteractBusy then
				return
			end

			if not self.fishingState.minigameActive then
				if self:TryReactToAnyChest(reason or "minigame") then
					return
				end
			end

			task.wait(self.PostMinigameChestReactStep)
		end
	end)
end



function Controller:RequestFastChestInteract(chest)
	if not chest or not self.AutoFishingEnabled then
		return
	end

	if self.ActiveChestReactThreads[chest] then
		return
	end

	self.ActiveChestReactThreads[chest] = true
	self.lastAutoChestInteractCheck = 0
	self:ClearChestTargetCache()

	local function tryInstantInteract()
		if not self.AutoFishingEnabled or self.AutoChestInteractBusy then
			return true
		end

		if not chest.Parent then
			return true
		end

		if self.interactState.holding or self.fishingState.minigameActive or self.CastInProgress or self.clickedRecently or self.usingBaitAfterCatch then
			return true
		end

		local cooldownUntil = self.AutoChestInteractCooldowns[chest]
		if cooldownUntil and os.clock() < cooldownUntil then
			return true
		end

		local part = self:GetChestInteractAdornee(chest)
		if not part then
			return false
		end

		if not self.RootPart or not self:IsChestInteractSafe(chest, part) then
			return false
		end

		if not self:IsChestInsideLineBox(chest, part) then
			return true
		end

		local offset = part.Position - self.RootPart.Position
		local distanceSq = offset:Dot(offset)
		local range = self.AutoChestInteractRange or 10

		if distanceSq > range * range then
			return true
		end

		local distance = math.sqrt(distanceSq)

		self.CachedChestTarget = chest
		self.CachedChestTargetPart = part
		self.CachedChestTargetDistance = distance
		self.LastChestTargetScan = os.clock()

		self:SetStatus("Instant chest interact")
		self:HoldChestInteract(chest, part, distance)
		return true
	end

	if tryInstantInteract() then
		self.ActiveChestReactThreads[chest] = nil
		return
	end

	task.spawn(function()
		local startedAt = os.clock()

		while os.clock() - startedAt <= (self.AutoChestInstantRetryWindow or 0.25) do
			if tryInstantInteract() then
				break
			end

			task.wait(self.AutoChestInstantRetryStep or 0.015)
		end

		self.ActiveChestReactThreads[chest] = nil
	end)
end

function Controller:GetChestClosestPositionPoint(part)
	if not part then
		return nil, nil, math.huge
	end

	local bestName = nil
	local bestCFrame = nil
	local bestDistance = math.huge

	if self.PositionEnforcerSavedA then
		local distanceA = (part.Position - self.PositionEnforcerSavedA.Position).Magnitude
		if distanceA < bestDistance then
			bestName = "A"
			bestCFrame = self.PositionEnforcerSavedA
			bestDistance = distanceA
		end
	end

	if self.PositionEnforcerSavedB then
		local distanceB = (part.Position - self.PositionEnforcerSavedB.Position).Magnitude
		if distanceB < bestDistance then
			bestName = "B"
			bestCFrame = self.PositionEnforcerSavedB
			bestDistance = distanceB
		end
	end

	return bestName, bestCFrame, bestDistance
end

function Controller:CanUseChestPositionOverride(chest, part, rootDistance)
	if not self.AutoFishingEnabled then
		return false
	end

	if not self.PositionEnforcerEnabled then
		return false
	end

	if self.ChestPositionOverrideActive or self.ChestPositionOverrideReturning then
		return false
	end

	if self.AutoChestInteractBusy then
		return false
	end

	if self.interactState.holding or self.fishingState.minigameActive or self.CastInProgress or self.clickedRecently or self.usingBaitAfterCatch then
		return false
	end

	if not self:IsChestInteractSafe(chest, part) or not self.RootPart then
		return false
	end

	if rootDistance and rootDistance > self.AutoChestOverrideMaxTravelDistance then
		return false
	end

	local pointName, pointCFrame, pointDistance = self:GetChestClosestPositionPoint(part)
	if not pointName or not pointCFrame then
		return false
	end

	return pointDistance <= self.AutoChestOverridePointRange, pointName, pointCFrame, pointDistance
end

function Controller:TryStartChestPositionOverride(chest, part, rootDistance)
	-- Disabled by default: no teleporting/moving to missed chests.
	-- Set AutoChestPositionOverrideEnabled = true only if you want the old behavior back.
	if not self.AutoChestPositionOverrideEnabled then
		return false
	end

	local canOverride, pointName, pointCFrame, pointDistance = self:CanUseChestPositionOverride(chest, part, rootDistance)
	if not canOverride then
		return false
	end

	self:StartChestPositionOverride(chest, part, pointName, pointCFrame, pointDistance)
	return true
end

function Controller:StartChestPositionOverride(chest, part, pointName, pointCFrame, pointDistance)
	if self.ChestPositionOverrideActive or self.ChestPositionOverrideReturning then
		return
	end

	local current = self:GetCurrentEnforcerCFrame()
	local root = self:GetRootFallback()

	self.ChestPositionOverrideActive = true
	self.ChestPositionOverrideReturning = false
	self.ChestPositionOverrideTargetChest = chest
	self.ChestPositionOverrideTargetPart = part
	self.ChestPositionOverrideTargetPoint = pointName
	self.ChestPositionOverrideTargetPointCFrame = pointCFrame
	-- After claiming, return/stay at the saved position closest to the chest.
	-- This means if the chest spawned at the other Position Lock point, we keep you there.
	self.ChestPositionOverrideReturnCFrame = pointCFrame or current or (root and root.CFrame)
	self.ChestPositionOverrideStartedAt = os.clock()

	self.PositionEnforcerReturning = false
	self.PositionEnforcerReturnTarget = nil
	self.lastAutoChestInteractCheck = 0

	self:ReleaseAutoInteractKey()

	self.interactState.holding = false
	self.interactState.gui = nil
	self.fishingState.recastQueued = false
	self.awaitingBobberAfterCast = false
	self.clickedRecently = false
	self.CastInProgress = false
	self.CastLockUntil = 0

	self:SetStatus("Chest spawned near point " .. tostring(pointName) .. " - moving there")
end

function Controller:MoveToPositionFast(targetCFrame, dt, stopDistance)
	if not targetCFrame or not self:IsAlive() then
		return false
	end

	local root = self:GetRootFallback()
	if not root then
		return false
	end

	local targetPosition = targetCFrame.Position
	local offset = targetPosition - root.Position
	local horizontal = Vector3.new(offset.X, 0, offset.Z)
	local vertical = offset.Y
	local distance = offset.Magnitude
	local horizontalDistance = horizontal.Magnitude

	if distance <= (stopDistance or self.AutoChestOverrideStopDistance) then
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
		return true
	end

	local dtSafe = math.max(dt or 0.016, 0.016)
	local horizontalStep = math.min(horizontalDistance, self.AutoChestOverrideMoveSpeed * dtSafe)
	local verticalStep = math.clamp(vertical, -self.AutoChestOverrideVerticalSpeed * dtSafe, self.AutoChestOverrideVerticalSpeed * dtSafe)

	local move = Vector3.new(0, verticalStep, 0)
	if horizontalDistance > 0.01 then
		move += horizontal.Unit * horizontalStep
	end

	local nextPosition = root.Position + move
	local lookTarget = Vector3.new(targetPosition.X, nextPosition.Y, targetPosition.Z)

	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero

	if (lookTarget - nextPosition).Magnitude > 0.1 then
		root.CFrame = CFrame.lookAt(nextPosition, lookTarget)
	else
		root.CFrame = CFrame.new(nextPosition) * (root.CFrame - root.CFrame.Position)
	end

	return false
end


function Controller:SetPositionEnforcerCurrentPoint(pointName)
	if pointName == "A" then
		self.PositionEnforcerMovedToB = false
	elseif pointName == "B" then
		self.PositionEnforcerMovedToB = true
	end
end

function Controller:FinishChestPositionOverride(shouldReturn)
	if not self.ChestPositionOverrideActive and not self.ChestPositionOverrideReturning then
		return
	end

	self.ChestPositionOverrideActive = false
	self.ChestPositionOverrideReturning = shouldReturn ~= false
	self.ChestPositionOverrideTargetChest = nil
	self.ChestPositionOverrideTargetPart = nil
	self.AutoChestInteractBusy = false

	if self.ChestPositionOverrideReturning then
		self:SetStatus("Chest claimed - moving to point " .. tostring(self.ChestPositionOverrideTargetPoint))
	else
		self.ChestPositionOverrideReturnCFrame = nil
		self.ChestPositionOverrideTargetPoint = nil
		self.ChestPositionOverrideTargetPointCFrame = nil
		self:SetStatus("Chest override cleared")
	end
end

function Controller:UpdateChestPositionOverride(dt)
	if not self.ChestPositionOverrideActive and not self.ChestPositionOverrideReturning then
		return
	end

	if not self.AutoFishingEnabled or not self:IsAlive() then
		self:FinishChestPositionOverride(false)
		self:ReleaseAutoInteractKey()
		return
	end

	if self.ChestPositionOverrideReturning then
		local returnCFrame = self.ChestPositionOverrideReturnCFrame or self:GetCurrentEnforcerCFrame()
		if not returnCFrame then
			self.ChestPositionOverrideReturning = false
			self.ChestPositionOverrideTargetPoint = nil
			self.ChestPositionOverrideTargetPointCFrame = nil
			return
		end

		if self:MoveToPositionFast(returnCFrame, dt, self.AutoChestOverrideReturnStopDistance) then
			local landedPoint = self.ChestPositionOverrideTargetPoint
			self:SetPositionEnforcerCurrentPoint(landedPoint)
			self.ChestPositionOverrideReturning = false
			self.ChestPositionOverrideReturnCFrame = nil
			self.ChestPositionOverrideTargetPoint = nil
			self.ChestPositionOverrideTargetPointCFrame = nil
			self.PositionEnforcerNextMoveTime = tick() + self.PositionEnforcerInterval
			self:SetStatus("Position lock resumed at point " .. tostring(landedPoint))
		end

		return
	end

	local chest = self.ChestPositionOverrideTargetChest
	local part = self.ChestPositionOverrideTargetPart

	if not self:IsChestInteractSafe(chest, part) then
		self:FinishChestPositionOverride(true)
		return
	end

	local distance = (part.Position - self.RootPart.Position).Magnitude
	if distance <= self.AutoChestInteractRange then
		self:HoldChestInteract(chest, part, distance)
		return
	end

	self:SetStatus("Moving to chest near point " .. tostring(self.ChestPositionOverrideTargetPoint))
	self:MoveToPositionFast(CFrame.new(part.Position), dt, self.AutoChestOverrideStopDistance)
end

function Controller:GetNearestChestForPositionOverride()
	local folder = self:GetChestFolder()
	if not folder or not self.RootPart then
		return nil, nil, math.huge
	end

	local bestChest = nil
	local bestPart = nil
	local bestDistance = math.huge

	for _, chest in ipairs(folder:GetChildren()) do
		local cooldownUntil = self.AutoChestInteractCooldowns[chest]
		if not cooldownUntil or os.clock() >= cooldownUntil then
			local part = self:GetChestInteractAdornee(chest)
			if self:IsChestInteractSafe(chest, part) and self:IsChestInsideLineBox(chest, part) then
				local distance = (part.Position - self.RootPart.Position).Magnitude
				if distance > self.AutoChestInteractRange and distance < bestDistance then
					if self:CanUseChestPositionOverride(chest, part, distance) then
						bestChest = chest
						bestPart = part
						bestDistance = distance
					end
				end
			end
		end
	end

	return bestChest, bestPart, bestDistance
end


function Controller:ClearChestTargetCache()
	self.CachedChestTarget = nil
	self.CachedChestTargetPart = nil
	self.CachedChestTargetDistance = math.huge
	self.LastChestTargetScan = 0
end

function Controller:IsCachedChestTargetValid()
	local chest = self.CachedChestTarget
	local part = self.CachedChestTargetPart

	if not chest or not part or not self.RootPart then
		return false
	end

	if os.clock() - (self.LastChestTargetScan or 0) > (self.ChestTargetCacheTTL or 0.08) then
		return false
	end

	if not chest.Parent or not part.Parent then
		return false
	end

	local cooldownUntil = self.AutoChestInteractCooldowns[chest]
	if cooldownUntil and os.clock() < cooldownUntil then
		return false
	end

	if not self:IsChestInteractSafe(chest, part) then
		return false
	end

	if not self:IsChestInsideLineBox(chest, part) then
		return false
	end

	local distance = (part.Position - self.RootPart.Position).Magnitude

	if distance > self.AutoChestInteractRange then
		return false
	end

	self.CachedChestTargetDistance = distance
	return true
end



function Controller:GetChestFromDescendant(obj, folder)
	if not obj or not folder then
		return nil
	end

	if obj.Parent == folder then
		return obj
	end

	local current = obj

	while current and current ~= folder do
		if current.Parent == folder then
			return current
		end

		current = current.Parent
	end

	return nil
end

function Controller:GetChestSpatialQueryParts(folder)
	if not self.RootPart or not folder then
		return {}
	end

	local range = (self.AutoChestInteractRange or 10) + (self.ChestSpatialBoxPadding or 5)
	local size = Vector3.new(range * 2, self.ChestSpatialBoxYSize or 34, range * 2)

	local overlap = OverlapParams.new()
	overlap.FilterType = Enum.RaycastFilterType.Include
	overlap.FilterDescendantsInstances = { folder }

	pcall(function()
		overlap.RespectCanCollide = false
	end)

	local ok, parts = pcall(function()
		return workspace:GetPartBoundsInBox(self.RootPart.CFrame, size, overlap)
	end)

	if ok and parts then
		return parts
	end

	return {}
end

function Controller:GetChestInteractAdorneeFast(chest, fallbackPart)
	if fallbackPart and fallbackPart:IsA("BasePart") and fallbackPart.Parent and fallbackPart:IsDescendantOf(workspace) then
		return fallbackPart
	end

	return self:GetChestInteractAdornee(chest)
end


function Controller:GetNearestChestInInteractRange(forceScan)
	if not self.AutoFishingEnabled then
		self:ClearChestTargetCache()
		return nil, nil, math.huge
	end

	local folder = self:GetChestFolder()
	if not folder or not self.RootPart then
		self:ClearChestTargetCache()
		return nil, nil, math.huge
	end

	if not forceScan and self:IsCachedChestTargetValid() then
		return self.CachedChestTarget, self.CachedChestTargetPart, self.CachedChestTargetDistance
	end

	local now = os.clock()
	local ttl = self.ChestTargetCacheTTL or 0.035

	if not forceScan and now - (self.LastChestTargetScan or 0) < ttl then
		return self.CachedChestTarget, self.CachedChestTargetPart, self.CachedChestTargetDistance or math.huge
	end

	self.LastChestTargetScan = now

	local closestChest = nil
	local closestPart = nil
	local closestDistanceSq = math.huge
	local range = self.AutoChestInteractRange or 10
	local rangeSq = range * range
	local seen = {}

	-- Faster than scanning every chest in workspace.Chests:
	-- only parts inside the small interact box around the player are checked.
	for _, hitPart in ipairs(self:GetChestSpatialQueryParts(folder)) do
		if hitPart and hitPart:IsA("BasePart") then
			local chest = self:GetChestFromDescendant(hitPart, folder)

			if chest and not seen[chest] then
				seen[chest] = true

				local cooldownUntil = self.AutoChestInteractCooldowns[chest]

				if not cooldownUntil or now >= cooldownUntil then
					local part = self:GetChestInteractAdorneeFast(chest, hitPart)

					if self:IsChestInteractSafe(chest, part) and self:IsChestInsideLineBox(chest, part) then
						local offset = part.Position - self.RootPart.Position
						local distanceSq = offset:Dot(offset)

						if distanceSq <= rangeSq and distanceSq < closestDistanceSq then
							closestChest = chest
							closestPart = part
							closestDistanceSq = distanceSq
						end
					end
				end
			end
		end
	end

	local closestDistance = closestDistanceSq < math.huge and math.sqrt(closestDistanceSq) or math.huge

	self.CachedChestTarget = closestChest
	self.CachedChestTargetPart = closestPart
	self.CachedChestTargetDistance = closestDistance

	return closestChest, closestPart, closestDistance
end

function Controller:FaceChestInteractTarget(part)
	if not self.RootPart or not part then
		return
	end

	local rootPos = self.RootPart.Position
	local targetPos = Vector3.new(part.Position.X, rootPos.Y, part.Position.Z)

	if (targetPos - rootPos).Magnitude > 0.1 then
		self.RootPart.CFrame = CFrame.lookAt(rootPos, targetPos)
	end
end

function Controller:HoldChestInteract(chest, part, distance)
	if self.AutoChestInteractBusy then
		return
	end

	if not self.AutoFishingEnabled then
		return
	end

	if self.interactState.holding or self.fishingState.minigameActive or self.CastInProgress or self.clickedRecently or self.usingBaitAfterCatch then
		return
	end

	if not part or not part.Parent or not self.RootPart then
		return
	end

	if (part.Position - self.RootPart.Position).Magnitude > self.AutoChestInteractRange then
		return
	end

	self.AutoChestInteractBusy = true
	self.CachedChestTarget = chest
	self.CachedChestTargetPart = part
	self.CachedChestTargetDistance = distance or ((self.RootPart and part) and (part.Position - self.RootPart.Position).Magnitude or math.huge)
	self.LastChestTargetScan = os.clock()
	self.AutoChestInteractCooldowns[chest] = os.clock() + self.AutoChestInteractCooldown

	task.spawn(function()
		if not self.AutoFishingEnabled then
			self.AutoChestInteractBusy = false
			return
		end

		self:SetStatus("Holding E for chest [" .. math.floor(distance + 0.5) .. " studs]")
		self:FaceChestInteractTarget(part)

		self.interactState.autoKeyDown = true
		pcall(function()
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
		end)

		local start = os.clock()

		while os.clock() - start < self.AutoChestInteractHoldTime do
			if not self.AutoFishingEnabled then
				break
			end

			if not self:IsAlive() then
				break
			end

			if not part or not part.Parent then
				break
			end

			if self.RootPart and (part.Position - self.RootPart.Position).Magnitude > self.AutoChestInteractRange + 2 then
				break
			end

			task.wait(0.05)
		end

		self:ReleaseAutoInteractKey()

		if self.ChestPositionOverrideActive and self.ChestPositionOverrideTargetChest == chest then
			task.wait(0.45)
			self:FinishChestPositionOverride(true)
		else
			task.wait(0.15)
			self.AutoChestInteractBusy = false
			self:ClearChestTargetCache()
		end
	end)
end

function Controller:UpdateAutoChestInteract()
	if self.ChestPositionOverrideActive or self.ChestPositionOverrideReturning then
		return
	end

	if not self.AutoFishingEnabled then
		if self.AutoChestInteractBusy then
			self.AutoChestInteractBusy = false
			self:ReleaseAutoInteractKey()
		end

		return
	end

	if self.AutoChestInteractBusy then
		return
	end

	if self.interactState.holding or self.fishingState.minigameActive or self.CastInProgress or self.clickedRecently or self.usingBaitAfterCatch then
		return
	end

	local now = os.clock()

	if now - self.lastAutoChestInteractCheck < self.AutoChestInteractRate then
		return
	end

	self.lastAutoChestInteractCheck = now

	local chest, part, distance = self:GetNearestChestInInteractRange()

	if chest and part then
		self:HoldChestInteract(chest, part, distance)
		return
	end

	-- No missed chest teleporting/moving.
	-- UpdateAutoChestInteract only grabs chests already inside AutoChestInteractRange.
end

function Controller:BindEntityESP()
	self:DisconnectEntityESPConnections()

	local folder = self:GetEntityFolder()
	if not folder then return end

	table.insert(self.EntityESPConnections, folder.ChildAdded:Connect(function(child)
		self.lastEntityCacheUpdate = 0
		task.wait(0.05)
		if self.EntityESPEnabled and not self:IsSelfObject(child) and not self:IsBlacklistedEntity(child) then
			self:CreateTextESP(child, self.EntityESPObjects, "Entity")
		end
	end))

	table.insert(self.EntityESPConnections, folder.ChildRemoved:Connect(function(child)
		self.lastEntityCacheUpdate = 0
		self:RemoveTextESP(child, self.EntityESPObjects)
	end))
end




function Controller:GetRootFallback()
	if self.RootPart and self.RootPart.Parent then
		return self.RootPart
