	end

	local npc, npcPart = self:GetAutoSellWoodNPC()
	if not npc or not npcPart then
		self:SetStatus("ChuckB missing for wood sell")
		return false
	end

	local standCFrame = self:GetAutoSellWoodStandCFrame(npcPart)

	if not standCFrame then
