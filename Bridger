function Controller:UseBaitThenRodAfterCatch()
	if not self.AutoUseBaitAfterCatchEnabled then
		self:SetStatus("Use bait disabled, recasting")
		self:QueueRecast("bait disabled")
		return
	end

	if self.usingBaitAfterCatch then return end
	if not self.AutoFishingEnabled then return end

	self.usingBaitAfterCatch = true

	task.spawn(function()
		self:SetStatus("Using bait after catch")
		task.wait(self.POST_CATCH_BAIT_CLICK_DELAY)

		if self.AutoFishingEnabled and self:EquipTool("Bait") then
			task.wait(0.15)
			self:ClickOnce()
		end

		task.wait(self.POST_BAIT_ROD_DELAY)

		if self.AutoFishingEnabled then
			self:EquipTool("FishingRod")
		end

		self.usingBaitAfterCatch = false
		self:QueueRecast("bait used after catch")
	end)
end

function Controller:StartReliableCast(reason)
	if not self.AutoFishingEnabled then
		return false
	end

	if self.CastInProgress or os.clock() < self.CastLockUntil then
		return false
	end

	if self.interactState.holding or self.interactState.gui then
		return false
	end

	if self.fishingState.minigameActive then
		return false
	end

	if self:HasNearbyCurrentBobber() then
		return false
	end

	if not self:EquipRodForCast() then
		self:SetStatus("FishingRod missing")
		return false
	end

	task.wait(self.CastEquipDelay)

	if not self.AutoFishingEnabled then
		return false
	end

	if self.interactState.holding or self.interactState.gui then
		return false
	end

	if self.fishingState.minigameActive then
		return false
	end

	if self:HasNearbyCurrentBobber() then
		return false
	end

	local casted = self:HoldCastMouse()

	if not casted then
		self:SetStatus("Cast busy")
		return false
	end

	self:SetStatus("Cast released")
	return true
end

function Controller:QueueRecast(reason)
	if self.usingBaitAfterCatch then return end
	if self.fishingState.recastQueued or not self.AutoFishingEnabled then return end

	self.fishingState.recastQueued = true

	task.spawn(function()
		while self.fishingState.minigameActive and self.AutoFishingEnabled do task.wait(0.1) end
		while self.interactState.holding and self.AutoFishingEnabled do task.wait(0.1) end
		while self:HasNearbyCurrentBobber() and self.AutoFishingEnabled do task.wait(0.1) end
		while not self:CanRecast() and self.AutoFishingEnabled do task.wait(0.05) end

		if not self.AutoFishingEnabled then
			self.fishingState.recastQueued = false
			return
		end

		self:SetStatus("Preparing smart recast")
		task.wait(self.SMART_RECAST_DELAY)

		if not self.AutoFishingEnabled then
			self.fishingState.recastQueued = false
			return
		end

		if self.interactState.holding then
			self.fishingState.recastQueued = false
			return
		end

		if self:HasNearbyCurrentBobber() then
			self.fishingState.recastQueued = false
			return
		end

		while self.clickedRecently and self.AutoFishingEnabled do
			task.wait(0.05)
		end

		self:SetStatus("Waiting for stable recast")
		self:WaitUntilCharacterStable()

		if not self.AutoFishingEnabled then
			self.fishingState.recastQueued = false
			return
		end

		self.lastRecastTime = os.clock()
		self:SetStatus("Recasting")
		self:ResetFishingState()

		local casted = self:StartReliableCast(reason)

		self.fishingState.recastQueued = false

		if not casted and self.AutoFishingEnabled then
			task.delay(self.CastRetryDelay, function()
				if self.AutoFishingEnabled and not self.awaitingBobberAfterCast and self:CanRecast() then
					self:QueueRecast("recast retry")
				end
			end)
		end
	end)
end

function Controller:IsFishingSound(sound)
	if not sound:IsA("Sound") then return false end
	if sound.Name ~= "FishBite" then return false end

	local parent = sound.Parent
	if not parent or not parent:IsA("BasePart") then return false end

	return self:IsBobberPart(parent)
end

function Controller:TrackBobber(part)
	if self.trackedBobbers[part] or not self:IsBobberPart(part) then return end

	local state = { removed = false }
	self.trackedBobbers[part] = state

	part.AncestryChanged:Connect(function(_, parent)
		if state.removed then return end

		if parent == nil or not part:IsDescendantOf(workspace) then
			state.removed = true
			self.trackedBobbers[part] = nil

			if self.fishingState.currentBobber == part then
				if self.fishingState.waitingForCatchFinish or self.fishingState.minigameSeen or self.fishingState.biteTriggered then
					self:SetStatus("Catch finished - checking chest")
					self:RequestPostMinigameChestReact("catch finished")
					self:UseBaitThenRodAfterCatch()
				else
					self:ResetFishingState()
				end
			end
		end
	end)
end

function Controller:HookSound(sound)
	if self.hookedSounds[sound] or not self:IsFishingSound(sound) then return end

	self.hookedSounds[sound] = true

	local bobberPart = sound.Parent
	local lastTimePos = sound.TimePosition
	local fired = false

	self:TrackBobber(bobberPart)

	local function trigger(reason)
		if fired then return end
		if not self.AutoFishingEnabled then return end
		if not self:IsBobberNearMe(bobberPart) then return end

		self:OnBobberSeen(bobberPart)
		self.fishingState.biteTriggered = true
		self.fishingState.waitingForCatchFinish = false
		fired = true

		self:SetStatus("Fish bite detected")
		self:TapClick()

		task.delay(2, function()
			fired = false
		end)
	end

	sound:GetPropertyChangedSignal("Playing"):Connect(function()
		if sound.Playing then
			trigger("Playing=true")
		end
	end)

	sound:GetPropertyChangedSignal("TimePosition"):Connect(function()
		local newPos = sound.TimePosition
		if newPos > 0 and lastTimePos == 0 then
			trigger("TimePosition started")
		end
		lastTimePos = newPos
	end)

	sound.AncestryChanged:Connect(function(_, parent)
		if not parent then
			self.hookedSounds[sound] = nil
		end
	end)

	if sound.Playing or sound.TimePosition > 0 then
		trigger("already active")
	end
end

function Controller:ResolveMashGui()
	local mashingSystem = PlayerGui:FindFirstChild("MashingSystem")
	if not mashingSystem then return nil end

	local container = mashingSystem:FindFirstChild("Container")
	if not container then return nil end

	local circle = container:FindFirstChild("Circle")
	if not circle then return nil end

	local keyLabel = circle:FindFirstChild("KeyLabel")
	if not keyLabel then return nil end

	return {
		mashingSystem = mashingSystem,
		container = container,
		circle = circle,
		keyLabel = keyLabel,
	}
end

function Controller:GetCurrentMashText()
	if not self.mashGuiRefs then return nil end

	local keyLabel = self.mashGuiRefs.keyLabel
	if not keyLabel or not keyLabel.Parent then return nil end
	if not self:IsGuiActuallyVisible(self.mashGuiRefs.container) then return nil end
	if not self:IsGuiActuallyVisible(self.mashGuiRefs.circle) then return nil end

	local text = tostring(keyLabel.Text or "")
	text = text:gsub("%s+", ""):upper()

	if text == "" then return nil end

	return text
end

function Controller:IsMashVisible()
	if not self.mashGuiRefs then return false end
	if not self.mashGuiRefs.keyLabel or not self.mashGuiRefs.keyLabel.Parent then return false end

	return self:IsGuiActuallyVisible(self.mashGuiRefs.container)
		and self:IsGuiActuallyVisible(self.mashGuiRefs.circle)
