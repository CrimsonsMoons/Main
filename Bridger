function Controller:IsBobberPart(part)
	if not part or not part:IsA("BasePart") then return false end
	if not part:IsDescendantOf(workspace) then return false end
	if part.BrickColor ~= self.BOBBER_BRICK_COLOR then return false end

	return part:FindFirstChild("Beam") ~= nil or part:FindFirstChild("Trail") ~= nil
end

function Controller:IsBobberNearMe(part)
	if not self:IsBobberPart(part) then return false end
	if not self.RootPart then return false end

	local offset = part.Position - self.RootPart.Position
	local distance = offset.Magnitude

	if distance > self.MAX_BOBBER_DISTANCE then return false end
	if distance <= 0.001 then return true end

	local direction = offset.Unit
	local look = self.RootPart.CFrame.LookVector
	local dot = look:Dot(direction)

	return dot >= self.BOBBER_FRONT_DOT_MIN
end

function Controller:GetNearbyPartsInBox()
	if not self.RootPart then return {} end

	local overlap = OverlapParams.new()
	overlap.FilterType = Enum.RaycastFilterType.Exclude
	overlap.FilterDescendantsInstances = { self.Character }

	return workspace:GetPartBoundsInBox(self.RootPart.CFrame, self.BOBBER_BOX_SIZE, overlap)
end

function Controller:GetBobberScore(part)
	if not self.RootPart then return math.huge end

	local offset = part.Position - self.RootPart.Position
	local distance = offset.Magnitude

	if distance <= 0.001 then return 0 end

	local direction = offset.Unit
	local look = self.RootPart.CFrame.LookVector
	local dot = look:Dot(direction)

	return distance - (dot * 5)
end

function Controller:FindNearestNearbyBobber()
	if not self:IsAlive() or not self.RootPart then return nil end

	local bestPart = nil
	local bestScore = math.huge

	for _, obj in ipairs(self:GetNearbyPartsInBox()) do
		if obj:IsA("BasePart") and self:IsBobberNearMe(obj) then
			local score = self:GetBobberScore(obj)

			if score < bestScore then
				bestScore = score
				bestPart = obj
			end
		end
	end

	return bestPart
end

function Controller:OnCastAttempt()
	self.lastCastAttemptTime = os.clock()
	self.awaitingBobberAfterCast = true
	self:SetStatus("Cast sent, waiting for bobber")
end

function Controller:OnBobberSeen(part)
	self.fishingState.currentBobber = part
	self.awaitingBobberAfterCast = false
	self.lastBobberSeenTime = os.clock()
	self.lastValidFishingAction = os.clock()
end

function Controller:RefreshNearbyBobber()
	if os.clock() - self.lastBobberScan < self.BobberScanRate then
		return
	end

	self.lastBobberScan = os.clock()

	local nearest = self:FindNearestNearbyBobber()

	if nearest then
		self:OnBobberSeen(nearest)
		return
	end

	if self.fishingState.currentBobber and not self:HasNearbyCurrentBobber() then
		self.fishingState.currentBobber = nil
	end
end

function Controller:HasNearbyCurrentBobber()
	local bobber = self.fishingState.currentBobber
	if not bobber then return false end
	if not bobber.Parent or not bobber:IsDescendantOf(workspace) then return false end

	return self:IsBobberNearMe(bobber)
end

function Controller:ClearFarBobberIfNeeded()
	local bobber = self.fishingState.currentBobber
	if not bobber then return end

	if not bobber.Parent or not bobber:IsDescendantOf(workspace) then
		self.fishingState.currentBobber = nil
		return
	end

	if not self:IsBobberNearMe(bobber) then
		self.fishingState.currentBobber = nil
		self.fishingState.biteTriggered = false
	end
end

function Controller:TapClick()
	if self.clickedRecently or not self.AutoFishingEnabled then
		return false
	end

	self.clickedRecently = true
	self.lastCastAttemptTime = os.clock()

	task.spawn(function()
		pcall(function()
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
			local cx, cy = self:GetScreenCenter()
			VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 0)
			VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 0)
		end)

		task.wait(self.CLICK_COOLDOWN)
		self.clickedRecently = false
	end)

	return true
end

function Controller:HoldCastMouse()
	if not self.AutoFishingEnabled then
		return false
	end

	if self.CastInProgress or os.clock() < self.CastLockUntil then
		return false
	end

	local startWait = os.clock()
	while self.clickedRecently and self.AutoFishingEnabled and os.clock() - startWait < self.MaxCastStartWait do
		task.wait(0.03)
	end

	if self.clickedRecently or not self.AutoFishingEnabled then
		return false
	end

	self.CastInProgress = true
	self.clickedRecently = true
	self:OnCastAttempt()
	self.lastValidFishingAction = os.clock()
	self.lastSuccessfulCastTime = os.clock()
	self.CastLockUntil = os.clock() + self.CastHardCooldown

	task.spawn(function()
		pcall(function()
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

			local cx, cy = self:GetScreenCenter()

			VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 0)
			task.wait(self.RECAST_HOLD_TIME)
			VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 0)
		end)

		task.wait(self.CLICK_COOLDOWN)
		self.clickedRecently = false
		self.CastInProgress = false
	end)

	return true
end

