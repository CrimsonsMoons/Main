function Controller:SetCFrameSpeedEnabled(state)
	self.CFrameSpeedEnabled = state and true or false
	self.CFrameSpeed = 65

	-- Do not zero horizontal velocity here.
	-- The Vape-style CFrame method keeps the default Humanoid movement active,
	-- then adds only the extra speed by CFrame so running animations still play.
	self:SetStatus("CFrame Speed " .. (self.CFrameSpeedEnabled and "ON" or "OFF") .. " (65)")
	self:Notify("CFrame Speed " .. (self.CFrameSpeedEnabled and "ON" or "OFF") .. " (65)")
	self:RefreshToggleButtons()
end

function Controller:ToggleCFrameSpeed()
	self:SetCFrameSpeedEnabled(not self.CFrameSpeedEnabled)
end

function Controller:UpdateCFrameSpeed(dt)
	if not self.CFrameSpeedEnabled then
		return
	end

	if not self:IsAlive() then
		return
	end

	local root = self.RootPart
	local hum = self.Humanoid

	if not root or not hum then
		return
	end

	if hum:GetState() == Enum.HumanoidStateType.Climbing then
		return
	end

	-- Vape universal.lua CFrame method, adapted to this controller:
	-- local dest = moveDirection * math.max(speed - Humanoid.WalkSpeed, 0) * dt
	-- root.CFrame += dest
	local moveDirection = hum.MoveDirection
	local dest = (moveDirection * math.max((self.CFrameSpeed or 65) - hum.WalkSpeed, 0) * (dt or 0))

	if self.CFrameSpeedWallCheck then
		self.CFrameSpeedRayParams.FilterDescendantsInstances = { self.Character, Camera }
		self.CFrameSpeedRayParams.CollisionGroup = root.CollisionGroup

		local ray = workspace:Raycast(root.Position, dest, self.CFrameSpeedRayParams)
		if ray then
			dest = ((ray.Position + ray.Normal) - root.Position)
		end
	end

	root.CFrame += dest
end

function Controller:ResolveWorkspacePath(path)
	if type(path) ~= "string" or path == "" then
		return nil
	end

	local current = game

	for token in string.gmatch(path, "[^%.]+") do
		if token == "game" then
			current = game
		elseif token == "workspace" or token == "Workspace" then
			current = workspace
		else
			if not current then
				return nil
			end

			current = current:FindFirstChild(token)
		end
	end

	return current
end

