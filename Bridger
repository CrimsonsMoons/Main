function Controller:ClickAutoSellWoodNPC()
	local _, npcPart = self:GetAutoSellWoodNPC()
	if not npcPart then
		return false
	end

	-- The character is locked in front of ChuckB and the camera is zoomed/faced
	-- toward his torso. Click the torso once at its projected screen position.
	self:FaceAutoSellWoodNPC()
	task.wait(0.1)

	local currentCamera = workspace.CurrentCamera or Camera
	if not currentCamera then
		self:ClickOnce()
		return true
	end

	local screenPoint, onScreen = currentCamera:WorldToViewportPoint(npcPart.Position)
	local x, y

	if onScreen and screenPoint.Z > 0 then
		x = math.floor(screenPoint.X)
		y = math.floor(screenPoint.Y)
	else
		local viewport = currentCamera.ViewportSize
		x = math.floor(viewport.X * 0.5)
		y = math.floor(viewport.Y * 0.5)
	end

	pcall(function()
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		VirtualInputManager:SendMouseMoveEvent(x, y, game)
		task.wait(0.035)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
		task.wait(0.055)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
	end)

	return true
end

function Controller:OpenAutoSellWoodDialogue()
	if not self:TeleportToAutoSellWoodNPC() then
		return false
	end

	-- One setup teleport, then a hard position/camera lock in front of ChuckB.
	if not self:StartAutoSellWoodPositionLock() then
		return false
	end

	self:UnequipAutoSellWoodTools()
	task.wait(0.12)

	local startedAt = os.clock()
	local timeout = self.AutoSellWoodNPCSpamDuration or 5
	local spamRate = self.AutoSellWoodNPCSpamRate or 0.11

	while self.AutoSellWoodBusy and os.clock() - startedAt < timeout do
		if self:GetWoodSellChoiceByName("Choice_2")
			or self:GetWoodSellChoiceByName("Choice_1")
			or self:GetWoodSellChoiceByText(self.AutoSellWoodFirstChoiceText or "I have some wood to sell.")
			or self:GetWoodSellChoiceByText(self.AutoSellWoodSecondChoiceText or "Sell ALL wood") then
			self:SetStatus("ChuckB wood dialogue found")
			return true
		end

		self:ClickAutoSellWoodNPC()
		task.wait(spamRate)
	end

	return self:GetWoodSellChoiceByName("Choice_2") ~= nil
		or self:GetWoodSellChoiceByName("Choice_1") ~= nil
		or self:GetWoodSellChoiceByText(self.AutoSellWoodFirstChoiceText or "I have some wood to sell.") ~= nil
		or self:GetWoodSellChoiceByText(self.AutoSellWoodSecondChoiceText or "Sell ALL wood") ~= nil
end

function Controller:AutoTreeSellWood(force)
	if not self.AutoSellWoodEnabled then
		return
	end

	if self.AutoSellWoodBusy then
		return
	end

	local woodAmount = self:GetWoodQuantity()
	local minimum = self.AutoSellWoodMinimum or 1

	if self.AutoSellWoodInstant and woodAmount < minimum then
		return
	end

	if os.clock() - self.AutoTreeLastSell < self.AutoTreeSellRate then
		return
	end

	self.AutoTreeLastSell = os.clock()
	self.AutoSellWoodBusy = true

	task.spawn(function()
		local woodBefore = woodAmount
		local returnCFrame = nil
		local attemptedDialogue = false

		if self:IsAlive() and self.RootPart then
			returnCFrame = self.RootPart.CFrame
		end

		self:SetAutoSellStatus("Auto Sell Wood: selling " .. tostring(woodBefore) .. " wood at ChuckB", true)

		local ok, err = pcall(function()
			if self:OpenAutoSellWoodDialogue() then
				self.AutoSellWoodLastDialogueClickX = nil
				self.AutoSellWoodLastDialogueClickY = nil

				local clickedDialogue, choice2Clicks = self:RunWoodSellGuiNavigationFlow()
				attemptedDialogue = clickedDialogue

				if choice2Clicks >= 2 then
					self:SetStatus("Waiting for wood sell to finish")
					local soldFinished = self:WaitForAutoSellWoodToFinish(woodBefore, self.AutoSellWoodSoldWaitTimeout or 1.65)
					task.wait(self.AutoSellWoodPostSellAfterSoldDelay or 0.35)
					self:SetStatus(soldFinished and "Wood sold, locking post-sell mouse spot" or "Sell timeout, trying post-sell mouse lock")
					self:ClickAutoSellWoodPostSellSpot()
				else
					task.wait(self.AutoSellWoodAfterSecondClickDelay or 0.25)
				end
			else
				self:SetStatus("ChuckB wood sell choice did not open")
			end
		end)

		self:StopAutoSellWoodPositionLock()

		if self.AutoSellWoodReturnAfterSell and returnCFrame and self:IsAlive() and self.RootPart then
			self.RootPart.CFrame = returnCFrame
			self.RootPart.AssemblyLinearVelocity = Vector3.zero
			self.RootPart.AssemblyAngularVelocity = Vector3.zero
		end

		self.AutoSellWoodBusy = false

		if not ok then
			self:SetAutoSellStatus("Auto Sell Wood error: " .. tostring(err), true)
		elseif attemptedDialogue then
			self.AutoSellLastWoodSoldText = "Sold/attempted " .. tostring(woodBefore) .. " wood"
			self:SetAutoSellStatus("Auto Sell Wood: sold/attempted " .. tostring(woodBefore) .. " wood", true)
		else
			self.AutoSellLastWoodSoldText = "Attempted " .. tostring(woodBefore) .. " wood"
			self:SetAutoSellStatus("Auto Sell Wood: attempted " .. tostring(woodBefore) .. " wood", true)
		end
	end)
end

function Controller:UpdateStandaloneAutoSells(force)
	-- Auto sells are independent now. They do not require Auto Fish or Auto Tree.
	if self.AutoSellFishBusy or self.AutoSellWoodBusy or self.RespawnWalkBusy then
		return
	end

	local now = os.clock()
	if not force and now - (self.LastAutoSellStandaloneCheck or 0) < (self.AutoSellStandaloneCheckRate or 0.35) then
		return
	end

	self.LastAutoSellStandaloneCheck = now

	if self.AutoSellEnabled then
		self:SellFishIfNeeded()
	end

	-- Sell wood even if Auto Tree is OFF, as long as the Sell Wood toggle is ON.
	if not self.AutoSellFishBusy and self.AutoSellWoodEnabled then
		self:AutoTreeSellWood(true)
	end
end

function Controller:AutoTreeUseAxe()
	if self.AutoTreeIsMoving then
		return
	end

	if self.AutoTreeArrivedAtTarget <= 0 then
		return
	end

	if os.clock() - self.AutoTreeArrivedAtTarget < self.AutoTreeArriveSettleTime then
		return
	end

	if os.clock() - self.AutoTreeLastSwing < self.AutoTreeSwingRate then
		return
	end

	if not self:HasAutoTreeAxe() then
		self:SetStatus("LumberAxe missing")
		return
	end

	self.AutoTreeLastSwing = os.clock()
	self:EquipTool(self.AutoTreeToolName)

	-- No swing/release remote anymore. This uses the old center-screen click.
	self:ClickOnce()
end


function Controller:GetAutoTreeLeavesPart(tree)
	if not tree then
		return nil
	end

	local leaves = tree:FindFirstChild(self.AutoTreeSwampLeavesName or "TreeLeaves", true)

	if not leaves then
		return nil
	end

	if leaves:IsA("BasePart") then
		return leaves
	end

	if leaves:IsA("Model") then
		if leaves.PrimaryPart and leaves.PrimaryPart:IsA("BasePart") then
			return leaves.PrimaryPart
		end

		return leaves:FindFirstChildWhichIsA("BasePart", true)
	end

	return nil
end

function Controller:MoveToAutoTreeTarget(dt)
	if not self:IsAlive() or not self.AutoTreeTargetBark then
		return false
	end

	local bark = self.AutoTreeTargetBark

	if not bark.Parent or not bark:IsDescendantOf(workspace) or bark.Transparency >= 1 then
		self:ClearAutoTreeTarget("Tree broke, finding next")
		return false
	end

	local root = self.RootPart
	local targetPosition = bark.Position + self.AutoTreeTargetOffset

	-- Forest and Swamp both use TreeBark now.
	-- This keeps Swamp chopping at the bark instead of teleporting into TreeLeaves.

	local goalCFrame = self:GetAutoTreeLookCFrame(targetPosition, bark.Position, bark.CFrame.LookVector)

	-- New tree target: teleport to the point first, then tween down into the exact hold position.
	if self:StartAutoTreePointTween("tree", bark, goalCFrame) then
		return false
	end

	if self.AutoTreePointTweenActive then
		return self:StepAutoTreePointTween(goalCFrame)
	end

	self.AutoTreeIsMoving = false

	if self.AutoTreeArrivedAtTarget <= 0 then
		self.AutoTreeArrivedAtTarget = os.clock()
	end

	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	root.CFrame = goalCFrame

	return true
end

function Controller:MoveToFallbackTreePoint(dt)
	if not self:IsAlive() or not self.AutoTreeFallbackTargetCFrame then
		return false
	end

	local root = self.RootPart
	local targetPosition = self.AutoTreeFallbackTargetCFrame.Position + self.AutoTreeTargetOffset
	local goalCFrame = self:GetAutoTreeLookCFrame(targetPosition, nil, self.AutoTreeFallbackTargetCFrame.LookVector)
	local ref = self.AutoTreeFallbackIndex or self.AutoTreeFallbackTargetCFrame

	-- New fallback tree point: teleport to that point first, then tween into the exact hold position.
	if self:StartAutoTreePointTween("fallback", ref, goalCFrame) then
		return false
	end

	if self.AutoTreePointTweenActive then
		return self:StepAutoTreePointTween(goalCFrame)
	end

	self.AutoTreeIsMoving = false

	if self.AutoTreeArrivedAtTarget <= 0 then
		self.AutoTreeArrivedAtTarget = os.clock()
	end

	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	root.CFrame = goalCFrame

	return true
end

function Controller:PickAutoTreeTarget(force)
	if self.AutoTreeCFrameOnly then
		local cf

		self.AutoTreeTarget = nil
		self.AutoTreeTargetBark = nil

		if self.AutoTreeCheckCFrameSpawn then
			cf = self:FindSpawnedTreeCFrameFromCurrent()
		else
			cf = self:GetCurrentFallbackTreeCFrame()
		end

		if cf then
			self.AutoTreeUsingFallback = true
			self.AutoTreeFallbackTargetCFrame = cf

			if not self.AutoTreeFallbackLinkedTree or not self.AutoTreeFallbackLinkedBark then
				self:BindFallbackTreeToCurrentCFrame()
			end

			if os.clock() - self.AutoTreeLastStatus >= self.AutoTreeStatusRate then
				self.AutoTreeLastStatus = os.clock()

				if self:IsFallbackLinkedTreeAlive() then
					self:SetStatus("Tree point " .. tostring(self.AutoTreeFallbackIndex) .. " spawned")
				else
					self:SetStatus("Checking tree CFrames for spawns")
				end
			end
		else
			self.AutoTreeUsingFallback = false
			self.AutoTreeFallbackTargetCFrame = nil
			self.AutoTreeFallbackLinkedTree = nil
			self.AutoTreeFallbackLinkedBark = nil

			if os.clock() - self.AutoTreeLastStatus >= self.AutoTreeStatusRate then
				self.AutoTreeLastStatus = os.clock()
				self:SetStatus("No tree CFrames found")
			end
		end

		return
	end

	if self.AutoTreeTarget and not self:IsValidTree(self.AutoTreeTarget) then
		self:ClearAutoTreeTarget("Tree broke, finding next")
	end

	if not force and self.AutoTreeTarget and self:IsValidTree(self.AutoTreeTarget) and self.AutoTreeTargetBark and self.AutoTreeTargetBark.Parent then
		return
	end

	if not force and os.clock() - self.AutoTreeLastScan < self.AutoTreeScanRate then
		return
	end

	self.AutoTreeLastScan = os.clock()

	local tree, bark, distance = self:GetNearestTree()
	self.AutoTreeTarget = tree
	self.AutoTreeTargetBark = bark

	if tree and bark then
		self.AutoTreeUsingFallback = false

		if os.clock() - self.AutoTreeLastStatus >= self.AutoTreeStatusRate then
			self.AutoTreeLastStatus = os.clock()
			self:SetStatus("Tree target: " .. tostring(tree.Name) .. " [" .. tostring(math.floor(distance + 0.5)) .. " studs]")
		end
	else
		if self.AutoTreeUseFallbackCFrames then
			local cf = self:GetCurrentFallbackTreeCFrame()

			if cf then
				self.AutoTreeUsingFallback = true
				self.AutoTreeFallbackTargetCFrame = cf

				if os.clock() - self.AutoTreeLastStatus >= self.AutoTreeStatusRate then
					self.AutoTreeLastStatus = os.clock()
					self:SetStatus("Tree fallback point: " .. tostring(self.AutoTreeFallbackIndex) .. "/" .. tostring(#self.AutoTreeFallbackCFrames))
				end

				return
			end
		end

		if os.clock() - self.AutoTreeLastStatus >= self.AutoTreeStatusRate then
			self.AutoTreeLastStatus = os.clock()
			self:SetStatus("No trees found")
		end
	end
end


