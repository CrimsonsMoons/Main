function Controller:GetGuiObjectClickPoint(guiObject)
	if not guiObject or not guiObject:IsA("GuiObject") then
		return nil, nil
	end

	local absolutePosition = guiObject.AbsolutePosition
	local absoluteSize = guiObject.AbsoluteSize

	if absoluteSize.X <= 0 or absoluteSize.Y <= 0 then
		return nil, nil
	end

	local insetX, insetY = 0, 0
	pcall(function()
		local guiService = game:GetService("GuiService")
		local topLeftInset = guiService:GetGuiInset()
		insetX = topLeftInset.X or 0
		insetY = topLeftInset.Y or 0
	end)

	-- VirtualInputManager uses real screen coordinates while AbsolutePosition can
	-- be inset-space. Adding GuiInset fixes the click landing on the option above.
	local x = math.floor(absolutePosition.X + absoluteSize.X * 0.5 + insetX)
	local y = math.floor(absolutePosition.Y + absoluteSize.Y * 0.5 + insetY)

	return x, y
end

function Controller:ClickGuiObjectAtPoint(guiObject, x, y)
	if not x or not y then
		return false
	end

	local ok = pcall(function()
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		VirtualInputManager:SendMouseMoveEvent(x, y, game)
		task.wait(0.035)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
		task.wait(0.055)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
	end)

	return ok
end

