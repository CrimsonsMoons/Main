function Controller:CanRecast()
	if self.CastInProgress then return false end
	if os.clock() < self.CastLockUntil then return false end
	if self.clickedRecently then return false end
	if self.usingBaitAfterCatch then return false end
	if self.interactState.holding then return false end
	if self.fishingState.minigameActive then return false end
	if self:HasNearbyCurrentBobber() then return false end

	return (os.clock() - self.lastRecastTime) >= self.RECAST_COOLDOWN
end

function Controller:IsCharacterStableForCast()
	if not self:IsAlive() then return false end

	local hum = self.Humanoid
	local root = self.RootPart

	if hum.Health <= 0 then return false end

	local state = hum:GetState()
	if self.BadStatesForCast[state] then return false end
	if hum.PlatformStand or hum.Sit then return false end

	local vel = root.AssemblyLinearVelocity
	local horizontal = Vector3.new(vel.X, 0, vel.Z)

	if horizontal.Magnitude > self.MAX_VELOCITY_FOR_CAST then return false end
	if math.abs(vel.Y) > 6 then return false end

	return true
end

function Controller:WaitUntilCharacterStable()
	local startTime = os.clock()
	local stableSince = nil

	while os.clock() - startTime < self.STABILITY_TIMEOUT do
		if self:IsCharacterStableForCast() then
			if not stableSince then
				stableSince = os.clock()
			end

			if os.clock() - stableSince >= self.STABLE_TIME_REQUIRED then
				return true
			end
		else
			stableSince = nil
		end

		task.wait(0.05)
	end

	return false
end

function Controller:RecountFish()
	local cod = 0
	local snapper = 0
	local bass = 0

	local function scanContainer(container)
		if not container or not container.Parent then
			return
		end

		for _, item in ipairs(container:GetChildren()) do
			local quantityObj = item:FindFirstChild("Quantity")
			local amount = 0

			if quantityObj and quantityObj:IsA("ValueBase") then
				amount = tonumber(quantityObj.Value) or 0
			end

			if item.Name == "Cod" then
				cod += amount
			elseif item.Name == "Snapper" then
				snapper += amount
			elseif item.Name == "Bass" then
				bass += amount
			end
		end
	end

	-- Count both Backpack and Character. If a fish is equipped during selling,
	-- Backpack-only counting can think it is gone and leave Bass behind.
	scanContainer(self.Backpack)
	scanContainer(self.Character)

	self.FishCounts.Cod = cod
	self.FishCounts.Snapper = snapper
	self.FishCounts.Bass = bass
	self.FishCounts.Total = cod + snapper + bass
end

function Controller:BindBackpackWatcher()
	self:DisconnectBackpackConnections()
	self:CacheBackpack()
	self:RecountFish()
	self:BindWoodQuantityWatcher()

	local function watchItem(item)
		if not self.FishNames[item.Name] then return end

		local quantityObj = item:FindFirstChild("Quantity")
		if quantityObj and quantityObj:IsA("ValueBase") then
			table.insert(self.BackpackConnections, quantityObj:GetPropertyChangedSignal("Value"):Connect(function()
				self:RecountFish()
			end))
		end
	end

	for _, item in ipairs(self.Backpack:GetChildren()) do
		watchItem(item)
	end

	table.insert(self.BackpackConnections, self.Backpack.ChildAdded:Connect(function(child)
		if self.FishNames[child.Name] then
			watchItem(child)
			self:RecountFish()
		end
	end))

	table.insert(self.BackpackConnections, self.Backpack.ChildRemoved:Connect(function(child)
		if self.FishNames[child.Name] then
			self:RecountFish()
		end
	end))
end

function Controller:GetDialogueRemoteAndDaniel()
	local replicatedStorage = game:GetService("ReplicatedStorage")
	local remotes = replicatedStorage:FindFirstChild("Remotes")
	if not remotes then return nil, nil end

	local dialogueRemote = remotes:FindFirstChild("DialogueRemote")
	if not dialogueRemote then return nil, nil end

	local npcFolder = workspace:FindFirstChild("NPC")
	if not npcFolder then return nil, nil end

	local daniel = npcFolder:FindFirstChild("Daniel")
	if not daniel then return nil, nil end

	return dialogueRemote, daniel
end

function Controller:HasAutoSellFishThreshold()
	self:RecountFish()

	local minimum = tonumber(self.AutoSellFishMinimumEach) or 15
	return (self.FishCounts.Cod or 0) >= minimum
		and (self.FishCounts.Snapper or 0) >= minimum
		and (self.FishCounts.Bass or 0) >= minimum
end

function Controller:HasAnyFishToSell()
	self:RecountFish()
	return (self.FishCounts.Total or 0) > 0
end

function Controller:GetAutoSellFishNPC()
	local npcFolder = workspace:FindFirstChild("NPC")
	local npc = npcFolder and npcFolder:FindFirstChild(self.AutoSellFishNPCName or "Daniel")

	if not npc then
		return nil, nil
	end

	local npcPart = nil

	if npc:IsA("BasePart") then
		npcPart = npc
	elseif npc:IsA("Model") then
		npcPart = npc:FindFirstChild("Torso", true)
			or npc:FindFirstChild("UpperTorso", true)
			or npc:FindFirstChild("HumanoidRootPart", true)
			or npc.PrimaryPart
			or npc:FindFirstChildWhichIsA("BasePart", true)
	elseif npc:IsA("Folder") then
		npcPart = npc:FindFirstChild("Torso", true)
			or npc:FindFirstChild("UpperTorso", true)
			or npc:FindFirstChild("HumanoidRootPart", true)
			or npc:FindFirstChildWhichIsA("BasePart", true)
	end

	return npc, npcPart
end

function Controller:GetAutoSellFishStandCFrame(npcPart)
	if not npcPart then
		return nil
	end

	local distance = self.AutoSellFishNPCDistance or 2.35
	local heightOffset = self.AutoSellFishNPCHeightOffset or 0
	local behind = -npcPart.CFrame.LookVector
	local targetPosition = npcPart.Position + (behind * distance) + Vector3.new(0, heightOffset, 0)
	local lookAt = npcPart.Position

	if (lookAt - targetPosition).Magnitude > 0.1 then
		return CFrame.lookAt(targetPosition, lookAt)
	end

	return CFrame.new(targetPosition)
end

function Controller:ApplyAutoSellFishCameraLock()
	if not self:IsAlive() then
		return false
	end

	local _, npcPart = self:GetAutoSellFishNPC()
	local camera = workspace.CurrentCamera or Camera

	if not npcPart or not camera then
		return false
	end

	if not self.AutoSellFishSavedCameraState then
		self.AutoSellFishSavedCameraState = {
			CameraType = camera.CameraType,
			CameraSubject = camera.CameraSubject,
			CFrame = camera.CFrame,
			FieldOfView = camera.FieldOfView,
			CameraMode = self.Player.CameraMode,
			CameraMinZoomDistance = self.Player.CameraMinZoomDistance,
			CameraMaxZoomDistance = self.Player.CameraMaxZoomDistance,
			MouseBehavior = UserInputService.MouseBehavior,
		}
	end

	local root = self.RootPart
	local cameraPosition = root.Position + Vector3.new(0, 1.45, 0)
	local torsoPosition = npcPart.Position

	pcall(function()
		self.Player.CameraMinZoomDistance = 0.5
		self.Player.CameraMaxZoomDistance = 0.5
		self.Player.CameraMode = Enum.CameraMode.LockFirstPerson
		camera.CameraType = Enum.CameraType.Scriptable
		camera.FieldOfView = self.AutoSellFishCameraFOV or 45
		camera.CFrame = CFrame.lookAt(cameraPosition, torsoPosition)
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	end)

	return true
end

function Controller:RestoreAutoSellFishCameraLock(applyHalfZoom)
	local state = self.AutoSellFishSavedCameraState
	if not state then
		return
	end

	local camera = workspace.CurrentCamera or Camera
	local oldCameraType = state.CameraType or Enum.CameraType.Custom
	local oldCameraSubject = state.CameraSubject or self.Humanoid
	local oldFOV = state.FieldOfView or 70
	local oldCameraCFrame = state.CFrame
	local oldMouseBehavior = state.MouseBehavior or Enum.MouseBehavior.Default
	local oldCameraMode = state.CameraMode or Enum.CameraMode.Classic
	local oldMinZoom = state.CameraMinZoomDistance or 0.5
	local oldMaxZoom = state.CameraMaxZoomDistance or 128

	pcall(function()
		self.Player.CameraMode = oldCameraMode
		UserInputService.MouseBehavior = oldMouseBehavior

		if camera then
			-- Restore the exact camera angle first while Scriptable, then hand control back.
			camera.CameraType = Enum.CameraType.Scriptable
			camera.CameraSubject = oldCameraSubject
			camera.FieldOfView = oldFOV
			if oldCameraCFrame then
				camera.CFrame = oldCameraCFrame
			end
		end

		if applyHalfZoom and self.AutoSellFishReturnZoomHalf then
			local maxZoom = tonumber(oldMaxZoom) or 128
			local halfZoom = math.max(0.5, maxZoom * 0.5)
			self.Player.CameraMinZoomDistance = halfZoom
			self.Player.CameraMaxZoomDistance = halfZoom
		else
			self.Player.CameraMinZoomDistance = oldMinZoom
			self.Player.CameraMaxZoomDistance = oldMaxZoom
		end
	end)

	-- Let the root return settle first, then restore the normal Roblox camera script.
	task.delay(0.08, function()
		pcall(function()
			local currentCamera = workspace.CurrentCamera or Camera
			if currentCamera then
				currentCamera.CameraSubject = oldCameraSubject or self.Humanoid
				currentCamera.FieldOfView = oldFOV
				if oldCameraCFrame then
					currentCamera.CFrame = oldCameraCFrame
				end
				currentCamera.CameraType = oldCameraType
			end
		end)
	end)

	if applyHalfZoom and self.AutoSellFishReturnZoomHalf then
		-- Keep the zoom forced long enough for the client camera to actually move out,
		-- then restore the user's real zoom limits without snapping the position back in.
		task.delay(0.95, function()
			pcall(function()
				self.Player.CameraMinZoomDistance = oldMinZoom
				self.Player.CameraMaxZoomDistance = oldMaxZoom
			end)
		end)
	else
		task.delay(0.12, function()
			pcall(function()
				self.Player.CameraMinZoomDistance = oldMinZoom
				self.Player.CameraMaxZoomDistance = oldMaxZoom
			end)
		end)
	end

	self.AutoSellFishSavedCameraState = nil
end

function Controller:StopAutoSellFishPositionLock(applyHalfZoom, restoreCameraNow)
	self.AutoSellFishPositionLockActive = false
	self.AutoSellFishPositionLockToken += 1

	if restoreCameraNow == false then
		return
	end

	self:RestoreAutoSellFishCameraLock(applyHalfZoom)
end

function Controller:ForceAutoSellFishReturnCFrame(returnCFrame, duration)
	if not returnCFrame or not self:IsAlive() or not self.RootPart then
		return false
	end

	local untilTime = os.clock() + (duration or self.AutoSellFishReturnLockDuration or 0.85)

	while self:IsAlive() and self.RootPart and os.clock() < untilTime do
		self.RootPart.CFrame = returnCFrame
		self.RootPart.AssemblyLinearVelocity = Vector3.zero
		self.RootPart.AssemblyAngularVelocity = Vector3.zero

		pcall(function()
			if self.Humanoid then
				self.Humanoid:Move(Vector3.zero, false)
				self.Humanoid.AutoRotate = true
			end
		end)

		task.wait(0.03)
	end

	if self:IsAlive() and self.RootPart then
		self.RootPart.CFrame = returnCFrame
		self.RootPart.AssemblyLinearVelocity = Vector3.zero
		self.RootPart.AssemblyAngularVelocity = Vector3.zero
	end

	return true
end

function Controller:StartAutoSellFishPositionLock()
	if not self:IsAlive() then
		return false
	end

	local _, npcPart = self:GetAutoSellFishNPC()
	local standCFrame = npcPart and self:GetAutoSellFishStandCFrame(npcPart)

	if not standCFrame then
		return false
	end

	self.AutoSellFishPositionLockToken += 1
	local token = self.AutoSellFishPositionLockToken
	self.AutoSellFishPositionLockActive = true

	self.RootPart.CFrame = standCFrame
	self.RootPart.AssemblyLinearVelocity = Vector3.zero
	self.RootPart.AssemblyAngularVelocity = Vector3.zero
	self:ApplyAutoSellFishCameraLock()

	task.spawn(function()
		while self.AutoSellFishBusy and self.AutoSellFishPositionLockActive and self.AutoSellFishPositionLockToken == token do
			if not self:IsAlive() then
				break
			end

			local _, liveNpcPart = self:GetAutoSellFishNPC()
			local liveStandCFrame = liveNpcPart and self:GetAutoSellFishStandCFrame(liveNpcPart)

			if not liveStandCFrame then
				break
			end

			self.RootPart.CFrame = liveStandCFrame
			self.RootPart.AssemblyLinearVelocity = Vector3.zero
			self.RootPart.AssemblyAngularVelocity = Vector3.zero
			self:ApplyAutoSellFishCameraLock()
			task.wait(0.015)
		end
	end)

	return true
end

function Controller:TeleportToAutoSellFishNPC()
	if not self:IsAlive() then
		return false
	end

	local npc, npcPart = self:GetAutoSellFishNPC()
	if not npc or not npcPart then
		self:SetStatus("Daniel missing for fish sell")
		return false
	end

	local standCFrame = self:GetAutoSellFishStandCFrame(npcPart)
	if not standCFrame then
		return false
	end

	self.RootPart.CFrame = standCFrame
	self.RootPart.AssemblyLinearVelocity = Vector3.zero
	self.RootPart.AssemblyAngularVelocity = Vector3.zero
	return true
end

function Controller:FaceAutoSellFishNPC()
	if not self:IsAlive() then
		return false
	end

	local _, npcPart = self:GetAutoSellFishNPC()
	if not npcPart then
		return false
	end

	local standCFrame = self:GetAutoSellFishStandCFrame(npcPart)
	if not standCFrame then
		return false
	end

	self.RootPart.CFrame = standCFrame
	self.RootPart.AssemblyLinearVelocity = Vector3.zero
	self.RootPart.AssemblyAngularVelocity = Vector3.zero
	self:ApplyAutoSellFishCameraLock()
	return true
end

function Controller:ClickAutoSellFishNPC()
	local _, npcPart = self:GetAutoSellFishNPC()
	if not npcPart then
		return false
	end

	self:FaceAutoSellFishNPC()
	task.wait(0.08)

	local currentCamera = workspace.CurrentCamera or Camera
	if not currentCamera then
		self:ClickOnce()
		return true
	end

	local screenPoint, onScreen = currentCamera:WorldToViewportPoint(npcPart.Position)
	local x, y

	if onScreen and screenPoint.Z > 0 then
		x = math.floor(screenPoint.X)
		y = math.floor(screenPoint.Y)
	else
		local viewport = currentCamera.ViewportSize
		x = math.floor(viewport.X * 0.5)
		y = math.floor(viewport.Y * 0.5)
	end

	pcall(function()
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		VirtualInputManager:SendMouseMoveEvent(x, y, game)
		task.wait(0.035)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
		task.wait(0.055)
		VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
	end)

	return true
end

function Controller:IsFishSellDialogueOpen()
	return self:IsWoodSellDialogueOpen()
end

function Controller:OpenAutoSellFishDialogue()
	if not self:TeleportToAutoSellFishNPC() then
		return false
	end

	if not self:StartAutoSellFishPositionLock() then
		return false
	end

	self:UnequipAutoSellWoodTools()
	task.wait(0.12)

	local startedAt = os.clock()
	local timeout = self.AutoSellFishNPCSpamDuration or 5
	local spamRate = self.AutoSellFishNPCSpamRate or 0.11

	while self.AutoSellFishBusy and os.clock() - startedAt < timeout do
		if self:GetWoodSellChoiceByName("Choice_2") or self:GetWoodSellChoiceByName("Choice_1") then
			self:SetStatus("Daniel fish dialogue found")
			return true
		end

		self:ClickAutoSellFishNPC()
		task.wait(spamRate)
	end

	return self:GetWoodSellChoiceByName("Choice_2") ~= nil or self:GetWoodSellChoiceByName("Choice_1") ~= nil
end

function Controller:RunFishSellGuiNavigationLoop()
	local clickedAnything = false
	local steps = 0
	local startedAt = os.clock()
	local maxSteps = tonumber(self.AutoSellFishChoiceMaxSteps) or 34
	local timeout = tonumber(self.AutoSellFishChoiceLoopTimeout) or 14
	local previousTotal = self.FishCounts.Total or 0
	local lastProgressAt = os.clock()

	while self.AutoSellFishBusy and os.clock() - startedAt < timeout and steps < maxSteps do
		self:RecountFish()
		local currentTotal = self.FishCounts.Total or 0

		if currentTotal <= 0 then
			return clickedAnything, true, steps
		end

		if currentTotal < previousTotal then
			previousTotal = currentTotal
			lastProgressAt = os.clock()
		end

		if not self:IsFishSellDialogueOpen() then
			self:ClickAutoSellFishNPC()
			task.wait(self.AutoSellFishNPCSpamRate or 0.09)
		end

		-- Daniel's fish dialogue can shift between Choice_2 and Choice_1.
		-- Prefer Choice_2, then use Choice_1 only when Choice_2 is not there.
		local choice, choiceName = self:WaitForDialogueChoicePriority({ "Choice_2", "Choice_1" }, 0.65)

		if choice then
			choiceName = tostring(choiceName or choice.Name)
			self:SetStatus("GUI navigating Daniel " .. choiceName .. " [fish]")

			if self:GuiNavigateAndEnterChoice(choice, {
				Retries = 4,
				ReadyTimeout = 0.8,
				SelectSettle = 0.06,
				AfterEnterWait = 0.13,
			}) then
				clickedAnything = true
				steps += 1
			end

			task.wait(self.AutoSellFishChoiceDelay or 0.72)

			local observeUntil = os.clock() + (self.AutoSellFishPostChoiceObserveTime or 0.42)
			while self.AutoSellFishBusy and os.clock() < observeUntil do
				self:RecountFish()
				if (self.FishCounts.Total or 0) <= 0 then
					return clickedAnything, true, steps
				end
				if (self.FishCounts.Total or 0) < currentTotal then
					lastProgressAt = os.clock()
					break
				end
				task.wait(0.07)
			end
		else
			self:ClickAutoSellFishNPC()
			task.wait(self.AutoSellFishNPCSpamRate or 0.09)
		end

		-- If the dialogue is open but no progress happens for a while, click Daniel again
		-- to refresh the dialogue instead of getting stuck on a stale choice screen.
		if os.clock() - lastProgressAt > 4.2 then
			self:ClickAutoSellFishNPC()
			lastProgressAt = os.clock()
			task.wait(self.AutoSellFishReopenDelay or 0.45)
		end
	end

	self:RecountFish()
	return clickedAnything, (self.FishCounts.Total or 0) <= 0, steps
end

function Controller:WaitForAutoSellFishToFinish(previousTotal, timeout)
	timeout = timeout or self.AutoSellFishSoldWaitTimeout or 9
	local startedAt = os.clock()
	previousTotal = tonumber(previousTotal) or math.huge

	while os.clock() - startedAt < timeout do
		self:RecountFish()
		local currentTotal = self.FishCounts.Total or 0

		if currentTotal <= 0 then
			return true
		end

		if currentTotal < previousTotal then
			previousTotal = currentTotal
			startedAt = os.clock()
		end

		task.wait(0.08)
	end

	return false
end

function Controller:FireDanielFishSellFallback()
	if not self.AutoSellFishRemoteFallbackEnabled then
		return false
	end

	local dialogueRemote, daniel = self:GetDialogueRemoteAndDaniel()
	if not dialogueRemote or not daniel then
		return false
	end

	self:RecountFish()
	local fired = false
	local actions = {
		{ Fish = "Bass", Action = "SellAll_Bass" },
		{ Fish = "Cod", Action = "SellAll_Cod" },
		{ Fish = "Snapper", Action = "SellAll_Snapper" },
	}

	for _, item in ipairs(actions) do
		self:RecountFish()
		local count = self.FishCounts[item.Fish] or 0

		if count > 0 then
			fired = true
			self:SetStatus("Force selling " .. item.Fish .. " [" .. tostring(count) .. "]")
			pcall(function()
				dialogueRemote:FireServer("Action", item.Action, daniel)
			end)
			task.wait(self.AutoSellFishForceActionWait or 0.11)
		end
	end

	return fired
end

function Controller:RunDanielFishSellFallbackCycles()
	if not self.AutoSellFishRemoteFallbackEnabled then
		return false, false
	end

	local usedFallback = false
	local cycles = math.max(1, math.floor(tonumber(self.AutoSellFishFallbackCycles) or 10))
	local waitTime = tonumber(self.AutoSellFishFallbackCycleWait) or 0.16

	for cycle = 1, cycles do
		self:RecountFish()
		local totalBefore = self.FishCounts.Total or 0

		if totalBefore <= 0 then
			return usedFallback, true
		end

		self:SetStatus("Daniel sell force pass " .. tostring(cycle) .. "/" .. tostring(cycles) .. " | B:" .. tostring(self.FishCounts.Bass or 0) .. " C:" .. tostring(self.FishCounts.Cod or 0) .. " S:" .. tostring(self.FishCounts.Snapper or 0))

		if self:FireDanielFishSellFallback() then
			usedFallback = true
		end

		local startedAt = os.clock()
		while os.clock() - startedAt < waitTime do
			self:RecountFish()
			if (self.FishCounts.Total or 0) <= 0 then
				return usedFallback, true
			end
			task.wait(0.04)
		end
	end

	self:RecountFish()
	return usedFallback, (self.FishCounts.Total or 0) <= 0
end

function Controller:SellFishIfNeeded()
	if not self.AutoSellEnabled then return end
	if self.AutoSellFishBusy or self.AutoSellWoodBusy then return end
	if os.clock() - self.lastSellCheck < self.SELL_CHECK_COOLDOWN then return end

	self.lastSellCheck = os.clock()
	self:RecountFish()

	local thresholdReady = self:HasAutoSellFishThreshold()
	local continuingUnfinishedBatch = self.AutoSellFishForceUntilEmpty and self:HasAnyFishToSell()

	if not thresholdReady and not continuingUnfinishedBatch then
		return
	end

	if thresholdReady then
		self.AutoSellFishForceUntilEmpty = true
	end

	self.AutoSellFishBusy = true

	task.spawn(function()
		local returnCFrame = nil
		local fishBefore = {
			Cod = self.FishCounts.Cod or 0,
			Snapper = self.FishCounts.Snapper or 0,
			Bass = self.FishCounts.Bass or 0,
			Total = self.FishCounts.Total or 0,
		}

		if self:IsAlive() and self.RootPart then
			returnCFrame = self.RootPart.CFrame
		end

		self:SetAutoSellStatus("Auto Sell Fish: selling at Daniel [" .. tostring(fishBefore.Total) .. " fish]", true)

		local clickedDialogue = false
		local soldOut = false
		local usedFallback = false
		local ok, err = pcall(function()
			-- First reliability pass: force all three fish sell actions right away.
			-- The GUI can sometimes only activate two choices, so this prevents Bass/Cod/Snapper from being left behind.
			if self.AutoSellFishFastRemoteAfterGui then
				local usedImmediateFallback = false
				usedImmediateFallback, soldOut = self:RunDanielFishSellFallbackCycles()
				usedFallback = usedFallback or usedImmediateFallback
			end

			local attempts = tonumber(self.AutoSellFishDialogueAttempts) or 2

			for attempt = 1, attempts do
				self:RecountFish()
				if (self.FishCounts.Total or 0) <= 0 then
					soldOut = true
					break
				end

				self:SetStatus("Daniel fast fish sell " .. tostring(attempt) .. "/" .. tostring(attempts))

				if self:OpenAutoSellFishDialogue() then
					local clickedThisAttempt = false
					clickedThisAttempt, soldOut = self:RunFishSellGuiNavigationLoop()
					clickedDialogue = clickedDialogue or clickedThisAttempt
				else
					self:SetStatus("Daniel dialogue missed, using fast sell backup")
				end

				self:RecountFish()
				if soldOut or (self.FishCounts.Total or 0) <= 0 then
					soldOut = true
					break
				end

				-- Reliability pass: after each GUI attempt, immediately fire the Daniel sell actions
				-- for every fish type still in inventory. This prevents the dialogue from missing
				-- one stack and makes the whole sell much faster.
				if self.AutoSellFishFastRemoteAfterGui then
					local usedThisCycle = false
					usedThisCycle, soldOut = self:RunDanielFishSellFallbackCycles()
					usedFallback = usedFallback or usedThisCycle
					if soldOut then
						break
					end
				end

				task.wait(self.AutoSellFishReopenDelay or 0.16)
			end

			self:RecountFish()
			if not soldOut and (self.FishCounts.Total or 0) > 0 then
				local usedFinalFallback = false
				usedFinalFallback, soldOut = self:RunDanielFishSellFallbackCycles()
				usedFallback = usedFallback or usedFinalFallback
			end
		end)

		-- Stop the Daniel lock first, then restore the old fishing CFrame/camera after the root is back.
		self:StopAutoSellFishPositionLock(false, false)

		if self.AutoSellFishReturnAfterSell and returnCFrame and self:IsAlive() and self.RootPart then
			self:SetStatus("Returning to fishing point")
			self:ForceAutoSellFishReturnCFrame(returnCFrame, self.AutoSellFishReturnLockDuration or 0.85)
		end

		self:RestoreAutoSellFishCameraLock(true)

		self.AutoSellFishBusy = false
		self:RecountFish()

		if (self.FishCounts.Total or 0) <= 0 then
			self.AutoSellFishForceUntilEmpty = false
		else
			-- If a stack like Bass is left behind, keep retrying on the next tick even though
			-- the original 15/15/15 threshold is no longer true after the first two stacks sold.
			self.AutoSellFishForceUntilEmpty = true
			self.lastSellCheck = 0
		end

		if not ok then
			self:SetAutoSellStatus("Auto Sell Fish error: " .. tostring(err), true)
		elseif soldOut or (self.FishCounts.Total or 0) <= 0 then
			self.AutoSellLastFishSoldText = "Sold " .. tostring(fishBefore.Total or 0) .. " fish at Daniel"
			self:SetAutoSellStatus("Auto Sell Fish: sold all fish", true)
		elseif usedFallback then
			self.AutoSellLastFishSoldText = "Partial sell, remaining " .. tostring(self.FishCounts.Total or 0)
			self:SetAutoSellStatus("Auto Sell Fish: backup ran, remaining " .. tostring(self.FishCounts.Total or 0), true)
		elseif clickedDialogue then
			self.AutoSellLastFishSoldText = "Dialogue clicked, remaining " .. tostring(self.FishCounts.Total or 0)
			self:SetAutoSellStatus("Auto Sell Fish: dialogue clicked, remaining " .. tostring(self.FishCounts.Total or 0), true)
		else
			self.AutoSellLastFishSoldText = "Attempted, remaining " .. tostring(self.FishCounts.Total or 0)
			self:SetAutoSellStatus("Auto Sell Fish: attempted, remaining " .. tostring(self.FishCounts.Total or 0), true)
		end
	end)
end

