	title.TextXAlignment = Enum.TextXAlignment.Left
	title.TextColor3 = Color3.fromRGB(255, 230, 130)
	title.TextStrokeTransparency = 0.75
	title.Text = "Position Lock"
	title.Parent = frame

	local timer = Instance.new("TextLabel")
	timer.Name = "Timer"
	timer.BackgroundTransparency = 1
	timer.Size = UDim2.new(1, -12, 0, 20)
	timer.Position = UDim2.new(0, 6, 0, 25)
	timer.Font = Enum.Font.GothamSemibold
	timer.TextSize = 13
	timer.TextXAlignment = Enum.TextXAlignment.Left
	timer.TextColor3 = Color3.fromRGB(245, 248, 255)
	timer.TextStrokeTransparency = 0.8
	timer.Text = "Next move: 120s"
	timer.Parent = frame

	local point = Instance.new("TextLabel")
	point.Name = "Point"
	point.BackgroundTransparency = 1
	point.Size = UDim2.new(1, -12, 0, 16)
	point.Position = UDim2.new(0, 6, 0, 43)
	point.Font = Enum.Font.GothamMedium
	point.TextSize = 11
	point.TextXAlignment = Enum.TextXAlignment.Left
	point.TextColor3 = Color3.fromRGB(180, 210, 255)
	point.TextStrokeTransparency = 0.85
	point.Text = "Holding: A"
	point.Parent = frame

	local dragging = false
	local dragStart = nil
	local startPosition = nil

	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPosition = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.PositionEnforcerDragConnection = UserInputService.InputChanged:Connect(function(input)
		if not dragging then
			return
		end

		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end

		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPosition.X.Scale,
			startPosition.X.Offset + delta.X,
			startPosition.Y.Scale,
			startPosition.Y.Offset + delta.Y
		)
	end)

	self.PositionEnforcerGuiObjects = {
		ScreenGui = screenGui,
		Frame = frame,
		Title = title,
		Timer = timer,
		Point = point,
	}
end

function Controller:SetPositionEnforcerUIVisible(visible)
	if visible then
		self:CreatePositionEnforcerUI()
	end

	local gui = self.PositionEnforcerGuiObjects.ScreenGui
	if gui then
		gui.Enabled = visible
	end
end

function Controller:UpdatePositionEnforcerUI()
	if not self.PositionEnforcerEnabled then
		local gui = self.PositionEnforcerGuiObjects.ScreenGui
		if gui and gui.Enabled then
			gui.Enabled = false
		end

		local arrowGui = self.PositionEnforcerArrowObjects.Gui
		if arrowGui and arrowGui.Enabled then
			arrowGui.Enabled = false
		end

		return
	end

	local now = tick()
	if now - self.PositionEnforcerLastUIUpdate < self.PositionEnforcerUIUpdateRate then
		return
	end

	self.PositionEnforcerLastUIUpdate = now
	self:SetPositionEnforcerUIVisible(true)

	local timer = self.PositionEnforcerGuiObjects.Timer
	local point = self.PositionEnforcerGuiObjects.Point
	local title = self.PositionEnforcerGuiObjects.Title

	local remaining = math.max(0, math.ceil(self.PositionEnforcerNextMoveTime - now))
	local currentPoint = self.PositionEnforcerMovedToB and "B" or "A"
	local nextPoint = self.PositionEnforcerMovedToB and "A" or "B"

	if title then
		title.Text = "Position Lock: ON"
	end

	if timer then
		timer.Text = "Next move to " .. nextPoint .. ": " .. tostring(remaining) .. "s"
	end

	if point then
		if self.PositionEnforcerReturning then
			point.Text = "Returning to: " .. currentPoint .. " | Key: P"
		else
			point.Text = "Holding: " .. currentPoint .. " | Key: P"
		end
	end
end

function Controller:SetPositionEnforcerEnabled(state)
	local nextState = state and true or false

	if self.PositionEnforcerEnabled == nextState then
		self:UpdatePositionEnforcerUI()
		return
	end

	self.PositionEnforcerEnabled = nextState

	if self.PositionEnforcerEnabled then
		local root = self:GetRootFallback()
		if not root then
			self.PositionEnforcerEnabled = false
			self:SetPositionEnforcerUIVisible(false)
			self:SetStatus("Position lock failed: no root")
			return
		end

		self.PositionEnforcerSavedA = root.CFrame
		self.PositionEnforcerSavedB = self:ComputeLeftCFrameFrom(self.PositionEnforcerSavedA)
		self.PositionEnforcerMovedToB = false
		self.PositionEnforcerNextMoveTime = tick() + self.PositionEnforcerInterval

		if self.PositionEnforcerUseTween then
			self:StartPositionReturnTo(self.PositionEnforcerSavedA)
		else
			self:TeleportToEnforcerCFrame(self.PositionEnforcerSavedA)
		end

		self:SetPositionEnforcerUIVisible(true)
		self:UpdatePositionEnforcerArrow()
		self:SetStatus("Position lock ON")
		self:Notify("Position lock ON")
	else
		self.PositionEnforcerReturning = false
		self.PositionEnforcerReturnTarget = nil
		self.PositionEnforcerPausedEffects = nil
		self:SetPositionEnforcerUIVisible(false)
		self:SetPositionEnforcerArrowVisible(false)
		self:SetStatus("Position lock OFF")
		self:Notify("Position lock OFF")
	end

	self:UpdatePositionEnforcerUI()
end

function Controller:DisablePositionEnforcerOnDeath()
	if not self.PositionEnforcerEnabled then
		return
	end

	self.PositionEnforcerEnabled = false
	self.PositionEnforcerReturning = false
	self.PositionEnforcerReturnTarget = nil
	self.PositionEnforcerPausedEffects = nil
	self.PositionEnforcerSavedA = nil
	self.PositionEnforcerSavedB = nil
	self.PositionEnforcerMovedToB = false

	self:SetPositionEnforcerUIVisible(false)
	self:SetPositionEnforcerArrowVisible(false)
	self:SetStatus("Position lock OFF on death")
	self:RefreshToggleButtons()
end

function Controller:TogglePositionEnforcer()
	self:SetPositionEnforcerEnabled(not self.PositionEnforcerEnabled)
end

function Controller:UpdatePositionEnforcer(dt)
	if not self.PositionEnforcerEnabled then
		local gui = self.PositionEnforcerGuiObjects.ScreenGui
		if gui and gui.Enabled then
			gui.Enabled = false
		end

		local arrowGui = self.PositionEnforcerArrowObjects.Gui
		if arrowGui and arrowGui.Enabled then
			arrowGui.Enabled = false
		end

		self.PositionEnforcerReturning = false
		self.PositionEnforcerReturnTarget = nil
		self:RestoreEffectsAfterPositionReturn()
		return
	end

	if not self:IsAlive() then
		self:UpdatePositionEnforcerUI()
		return
	end

	if self.ChestPositionOverrideActive or self.ChestPositionOverrideReturning then
		self.PositionEnforcerReturning = false
		self.PositionEnforcerReturnTarget = nil
		self:UpdatePositionEnforcerArrow()
		self:UpdatePositionEnforcerUI()
		return
	end

	local current = self:GetCurrentEnforcerCFrame()

	if current then
		if self:GetEnforcerDistanceFromSaved(current) > self.PositionEnforcerTolerance then
			self:StartPositionReturnTo(current)
			self:ReturnToEnforcerCFrame(current, dt)
		elseif not self.PositionEnforcerReturnTarget then
			self.PositionEnforcerReturning = false
		end
	end

	if self.PositionEnforcerSavedA and self.PositionEnforcerSavedB and tick() >= self.PositionEnforcerNextMoveTime then
		if self.PositionEnforcerMovedToB then
			self.PositionEnforcerMovedToB = false
			self:StartPositionReturnTo(self.PositionEnforcerSavedA)
		else
			self.PositionEnforcerMovedToB = true
			self:StartPositionReturnTo(self.PositionEnforcerSavedB)
		end
		self.PositionEnforcerNextMoveTime = tick() + self.PositionEnforcerInterval
	end

	if self.PositionEnforcerReturning and self.PositionEnforcerReturnTarget then
		self:ReturnToEnforcerCFrame(self.PositionEnforcerReturnTarget, dt)
	end

	self:UpdatePositionEnforcerArrow()
	self:UpdatePositionEnforcerUI()
end

