	end

	self.RootPart.CFrame = standCFrame
	self.RootPart.AssemblyLinearVelocity = Vector3.zero
	self.RootPart.AssemblyAngularVelocity = Vector3.zero
	return true
end

function Controller:HoldAutoSellWoodNPCPosition(duration)
	duration = duration or 0.35

	if not self:IsAlive() then
		return
	end

	local _, npcPart = self:GetAutoSellWoodNPC()
	local standCFrame = npcPart and self:GetAutoSellWoodStandCFrame(npcPart)

	if not standCFrame then
		return
	end

	local startedAt = os.clock()

	while self:IsAlive() and self.AutoSellWoodBusy and os.clock() - startedAt < duration do
		self.RootPart.CFrame = standCFrame
		self.RootPart.AssemblyLinearVelocity = Vector3.zero
		self.RootPart.AssemblyAngularVelocity = Vector3.zero
		self:ApplyAutoSellWoodCameraLock()
		task.wait(0.03)
	end
end

