function Controller:IsAlive()
	return self.Character
		and self.Character.Parent
		and self.Humanoid
		and self.Humanoid.Parent
		and self.RootPart
		and self.RootPart.Parent
		and self.Humanoid.Health > 0
end

function Controller:CacheCharacter()
	self.Character = self.Player.Character or self.Player.CharacterAdded:Wait()
	self.Humanoid = self.Character:WaitForChild("Humanoid")
	self.RootPart = self.Character:WaitForChild("HumanoidRootPart")
	self.SafeCFrame = self.RootPart.CFrame
	self.LastGrounded = tick()
end

function Controller:CacheBackpack()
	self.Backpack = self.Player:WaitForChild("Backpack")
end

function Controller:SetBadStatesDisabled()
	if not self.Humanoid then return end

	for state in pairs(self.BlockedStates) do
		pcall(function()
			self.Humanoid:SetStateEnabled(state, false)
		end)
	end
end

function Controller:RemoveForces(forceFullSweep)
	if not self.Character then return end

	local now = os.clock()
	if not forceFullSweep and now - self.lastForceSweep < self.forceSweepInterval then
		return
	end

	self.lastForceSweep = now

	for _, obj in ipairs(self.Character:GetDescendants()) do
		if self.ForceRemovers[obj.ClassName] then
			pcall(function() obj:Destroy() end)
		elseif obj:IsA("BallSocketConstraint") or obj:IsA("HingeConstraint") then
			pcall(function() obj.Enabled = false end)
		end
	end
end

function Controller:ForceStand()
	if not self:IsAlive() then return end

	local hum = self.Humanoid
	local root = self.RootPart

	if hum.PlatformStand then hum.PlatformStand = false end
	if hum.Sit then hum.Sit = false end

	pcall(function()
		hum.AutoRotate = true
	end)

	local state = hum:GetState()
	if self.BlockedStates[state] then
		pcall(function()
			hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end)

		task.defer(function()
			if self:IsAlive() then
				pcall(function()
					hum:ChangeState(Enum.HumanoidStateType.Running)
				end)
			end
		end)
	end

	local pos = root.Position
	root.CFrame = CFrame.new(pos) * CFrame.Angles(0, math.rad(root.Orientation.Y), 0)
end

function Controller:IsGrounded()
	if not self:IsAlive() then return false end

	local hum = self.Humanoid
	local state = hum:GetState()

	if state == Enum.HumanoidStateType.Running
		or state == Enum.HumanoidStateType.RunningNoPhysics
		or state == Enum.HumanoidStateType.Landed
		or state == Enum.HumanoidStateType.Climbing then
		return true
	end

	return hum.FloorMaterial ~= Enum.Material.Air
end

function Controller:UpdateSafePosition()
	if not self:IsAlive() then return end

	if self:IsGrounded() then
		self.LastGrounded = tick()
		self.SafeCFrame = self.RootPart.CFrame
	end
end

function Controller:ClampMovement()
	if not self:IsAlive() then return end

	local root = self.RootPart
	local vel = root.AssemblyLinearVelocity
	local ang = root.AssemblyAngularVelocity

	local horizontal = Vector3.new(vel.X, 0, vel.Z)
	local y = vel.Y

	if horizontal.Magnitude > self.MaxHorizontalVelocity then
		horizontal = horizontal.Unit * self.MaxHorizontalVelocity
	end

	if y > self.MaxUpVelocity then
		y = self.MaxUpVelocity
	elseif y < -self.MaxDownVelocity then
		y = -self.MaxDownVelocity
	end

	root.AssemblyLinearVelocity = Vector3.new(horizontal.X, y, horizontal.Z)

	if ang.Magnitude > self.MaxAngularVelocity then
		root.AssemblyAngularVelocity = Vector3.zero
	end
end

function Controller:HardAntiKnockback()
	if not self:IsAlive() then return end

	local root = self.RootPart
	local vel = root.AssemblyLinearVelocity
	local horizontal = Vector3.new(vel.X, 0, vel.Z)

	if horizontal.Magnitude > self.MaxHorizontalVelocity * 0.9 then
		root.AssemblyLinearVelocity = Vector3.new(0, math.clamp(vel.Y, -18, 18), 0)
		root.AssemblyAngularVelocity = Vector3.zero
		self:SetStatus("Anti knockback correcting")
	end
end

function Controller:AntiFall()
	if not self:IsAlive() then return end

	local root = self.RootPart
	local vel = root.AssemblyLinearVelocity

	if vel.Y < -self.MaxDownVelocity then
		root.AssemblyLinearVelocity = Vector3.new(vel.X * 0.2, -2, vel.Z * 0.2)
	end

	local airborneFor = tick() - self.LastGrounded
	if airborneFor > self.GroundMemory and root.Position.Y <= self.ReturnFallY then
		if self.SafeCFrame then
			root.CFrame = self.SafeCFrame + Vector3.new(0, self.SafeHeightOffset, 0)
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero

			pcall(function()
				self.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
			end)

			self:SetStatus("Anti fall recovery")
		end
	end
end

