local function isPriority(name)
    local lower = string.lower(name)
    for _, word in ipairs(CONFIG.WHITELIST) do
        if string.find(lower, word) then
            return true
        end
    end
    return false
end

local function findRemotes()
    local remotes = {}
    local priority = {}
    
    for _, loc in ipairs({game.ReplicatedStorage, game.ReplicatedFirst, game.Workspace, game.StarterGui, game.Lighting}) do
        pcall(function()
            for _, obj in ipairs(loc:GetDescendants()) do
                if obj:IsA("RemoteEvent") then
                    local safe, category, keyword, matchType = checkSafety(obj.Name)
                    
                    if not safe then
                        Protection.stats.byCategory[category] = Protection.stats.byCategory[category] + 1
                        Protection.stats.totalBlocked = Protection.stats.totalBlocked + 1
                        Analytics.totalBlocked = Analytics.totalBlocked + 1
                        warn(string.format("🛡️ [%s] BLOCKED: %s (keyword: %s, match: %s)", 
                            category, obj.Name, keyword, matchType))
                        continue
                    end
                    
                    -- Check if previously failed
                    if CONFIG.AUTO_SKIP_FAILED and NeuralAI.failedRemotes[obj.Name] then
                        continue
                    end
                    
                    if isPriority(obj.Name) then
                        table.insert(priority, obj)
                    else
                        table.insert(remotes, obj)
                    end
                end
            end
        end)
    end
    
    -- Priority first
    for i = #priority, 1, -1 do
        table.insert(remotes, 1, priority[i])
    end
    
    return remotes
end

local function testRemote(remote)
    Analytics.activeThreads = Analytics.activeThreads + 1
    
    local name = remote.Name
    local path = remote:GetFullName()
    
    GUI.currentRemote.Text = string.format("⚡ Scanning: %s", name)
    
    -- Get smart values
    local values, strategy, strategyData = getSmartTestValues(name, CONFIG.MODE)
    
    if strategy ~= "QUANTUM" and strategy ~= "ADAPTIVE" then
        GUI.aiStatus.Text = string.format("🧠 AI: Using %s strategy for %s", strategy, name)
    end
    
    local findings = {}
    local bestGain = 0
    local bestValue = nil
    local detectedPattern = nil
    
    for i, value in ipairs(values) do
        Analytics.completedTests = Analytics.completedTests + 1
        
        local before = getCurrency()
        
        local success, err = pcall(function()
            remote:FireServer(value)
        end)
        
        if not success then
            Analytics.errors = Analytics.errors + 1
            if CONFIG.AUTO_SKIP_ERRORS then
                NeuralAI.failedRemotes[name] = true
                break
            end
        else
            local batchCheck = CONFIG.SMART_BATCHING and 
                (i % math.max(2, math.floor(CONFIG.BATCH_SIZE / 2)) == 0) or
                (i % CONFIG.BATCH_SIZE == 0)
            
            if batchCheck or i == #values then
                task.wait(CONFIG.DELAY_CHECK)
                
                local after = getCurrency()
                updateCurrency()
                
                for currName, afterVal in pairs(after) do
                    local beforeVal = before[currName] or 0
                    local gain = afterVal - beforeVal
                    
                    if gain > 0 then
                        Analytics.successfulTests = Analytics.successfulTests + 1
                        
                        table.insert(findings, {
                            value = value,
                            gain = gain,
                            currency = currName
                        })
                        
                        if gain > bestGain then
                            bestGain = gain
                            bestValue = value
                        end
                        
                        -- AI Learning
                        local patternType, patternValue = recordSuccess(name, value, gain, currName)
                        
                        if patternType then
                            detectedPattern = patternType
                            Analytics.patternsFound = Analytics.patternsFound + 1
                            
                            if patternType == "LINEAR" then
                                Analytics.linearPatterns = Analytics.linearPatterns + 1
                                GUI.aiStatus.Text = string.format("🧠 BREAKTHROUGH! Linear pattern detected: %.2fx multiplier", patternValue)
                            elseif patternType == "EXPONENTIAL" then
                                Analytics.exponentialPatterns = Analytics.exponentialPatterns + 1
                                GUI.aiStatus.Text = string.format("🧠 BREAKTHROUGH! Exponential pattern: step size %d", patternValue)
                            else
                                Analytics.customPatterns = Analytics.customPatterns + 1
                            end
                            
                            if CONFIG.EARLY_EXIT then
                                -- Test extreme values
                                local extremes = {100000, 500000, 1000000, 5000000}
                                for _, ext in ipairs(extremes) do
                                    Analytics.completedTests = Analytics.completedTests + 1
                                    local b = getCurrency()
                                    pcall(function() remote:FireServer(ext) end)
                                    task.wait(CONFIG.DELAY_CHECK)
                                    local a = getCurrency()
                                    
                                    for cn, av in pairs(a) do
                                        local g = av - (b[cn] or 0)
                                        if g > 0 then
                                            table.insert(findings, {value = ext, gain = g, currency = cn})
                                            if g > bestGain then
                                                bestGain = g
                                                bestValue = ext
                                            end
                                        end
                                    end
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
        
        task.wait(CONFIG.DELAY_QUANTUM)
    end
    
    Analytics.remotesScanned = Analytics.remotesScanned + 1
    Analytics.activeThreads = Analytics.activeThreads - 1
    
    if #findings > 0 then
        Analytics.workingRemotes[path] = {
            name = name,
            path = path,
            findings = findings,
            bestValue = bestValue,
            bestGain = bestGain,
            pattern = detectedPattern
        }
        
        createWorkingRemote(name, path, bestValue, bestGain, findings, detectedPattern)
    end
    
    return #findings > 0
end

local function runScan()
    -- Start protection
    if CONFIG.POSITION_MONITOR then
        startPositionMonitor()
    end
    
    GUI.aiStatus.Text = "🧠 Neural Network: Initializing quantum processors..."
    updateCurrency()
    task.wait(0.3)
    
    GUI.aiStatus.Text = "🧠 AI: Deploying 9-layer protection shield..."
    local remotes = findRemotes()
    
    if #remotes == 0 then
        GUI.aiStatus.Text = string.format("❌ No safe remotes! Blocked %d dangerous remotes.", Analytics.totalBlocked)
        return
    end
    
    GUI.aiStatus.Text = string.format("🧠 AI: Found %d safe remotes | Blocked %d threats | Initializing deep learning...", 
        #remotes, Analytics.totalBlocked)
    
    local testValues = getSmartTestValues("_default", CONFIG.MODE)
    Analytics.totalTests = #remotes * #testValues
    
    task.wait(0.5)
    
    -- Stats updater
    task.spawn(function()
        while Analytics.remotesScanned < #remotes do
            updateStats()
            task.wait(0.05)
        end
        updateStats()
    end)
    
    -- Parallel processing
    local queue = {table.unpack(remotes)}
    local idx = 1
    
    for i = 1, math.min(CONFIG.PARALLEL_THREADS, #remotes) do
        task.spawn(function()
            while idx <= #remotes do
                local myIdx = idx
                idx = idx + 1
                
                if myIdx <= #remotes then
                    testRemote(remotes[myIdx])
                    task.wait(CONFIG.DELAY_REMOTE_SWITCH)
                end
            end
        end)
    end
    
    -- Wait for completion
    while idx <= #remotes or Analytics.activeThreads > 0 do
        task.wait(0.1)
    end
    
    -- Final
    GUI.aiStatus.Text = string.format("✅ Neural scan complete! Found %d working | Patterns: %d | Blocked: %d threats | 100%% SAFE", 
        Analytics.successfulTests, Analytics.patternsFound, Analytics.totalBlocked)
    GUI.currentRemote.Text = "✅ All remotes AI-verified! Zero risk guaranteed."
    GUI.currentRemote.TextColor3 = Color3.fromRGB(100, 255, 100)
    
    -- Summary
    print("═══════════════════════════════════════")
    print("NEURAL SCAN COMPLETE")
    print("═══════════════════════════════════════")
    print(string.format("Remotes scanned: %d", Analytics.remotesScanned))
    print(string.format("Working remotes: %d", Analytics.successfulTests))
    print(string.format("Blocked threats: %d", Analytics.totalBlocked))
    print(string.format("AI patterns found: %d", Analytics.patternsFound))
    print(string.format("  - Linear: %d", Analytics.linearPatterns))
    print(string.format("  - Exponential: %d", Analytics.exponentialPatterns))
    print(string.format("  - Custom: %d", Analytics.customPatterns))
    print(string.format("Speed: %.1f tests/sec", Analytics.testsPerSecond))
    print(string.format("Efficiency: %.1f%%", Analytics.efficiency))
    print(string.format("Time: %.1fs", tick() - Analytics.startTime))
    print("═══════════════════════════════════════")
end

