-- Advanced safety check with fuzzy matching
local function checkSafety(remoteName)
    local lower = string.lower(remoteName)
    
    -- Check each category
    for category, keywords in pairs(Protection.categories) do
        for _, keyword in ipairs(keywords) do
            -- Exact match
            if string.find(lower, string.lower(keyword)) then
                return false, category, keyword, "EXACT"
            end
            
            -- Fuzzy match (allows for small variations)
            local pattern = keyword:gsub(".", "%1?") -- Make each char optional
            if #keyword > 4 and string.find(lower, pattern) then
                return false, category, keyword, "FUZZY"
            end
        end
    end
    
    return true, "SAFE", nil, nil
end

-- Position monitoring system
local function startPositionMonitor()
    if Protection.positionLocked then return end
    
    Protection.positionLocked = true
    
    task.spawn(function()
        while Protection.enabled and Protection.positionLocked do
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = LocalPlayer.Character.HumanoidRootPart
                local currentPos = hrp.Position
                
                if not Protection.originalPosition then
                    Protection.originalPosition = currentPos
                end
                
                local distance = (currentPos - Protection.originalPosition).Magnitude
                
                -- Detect teleportation (moved >500 studs in 0.5 seconds)
                if distance > 500 then
                    Protection.stats.teleportAttempts = Protection.stats.teleportAttempts + 1
                    warn(string.format("🚨 TELEPORT BLOCKED! Distance: %d studs", math.floor(distance)))
                    
                    -- Restore position
                    pcall(function()
                        hrp.CFrame = CFrame.new(Protection.originalPosition)
                        Protection.stats.positionRestores = Protection.stats.positionRestores + 1
                    end)
                end
                
                -- Update every 0.5 seconds
                task.wait(0.5)
                Protection.originalPosition = hrp.Position
            else
                task.wait(1)
            end
        end
    end)
end

