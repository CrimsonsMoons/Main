local function getCurrency()
    local currencies = {}
    if LocalPlayer:FindFirstChild("leaderstats") then
        for _, stat in ipairs(LocalPlayer.leaderstats:GetChildren()) do
            if stat:IsA("IntValue") or stat:IsA("NumberValue") then
                currencies[stat.Name] = stat.Value
            end
        end
    end
    return currencies
end

local function updateCurrency()
    local currencies = getCurrency()
    local text = ""
    for name, value in pairs(currencies) do
        text = text .. string.format("💰 %s: %s  ", name, tostring(value))
    end
    
    if text == "" then
        GUI.currency.Text = "⚠️ No currency detected in leaderstats"
        GUI.currency.Parent.BackgroundColor3 = Color3.fromRGB(45, 10, 10)
    else
        GUI.currency.Text = text
        GUI.currency.Parent.BackgroundColor3 = Color3.fromRGB(10, 45, 10)
    end
end

local function updateShield()
    local parts = {}
    for category, count in pairs(Protection.stats.byCategory) do
        table.insert(parts, string.format("%s(%d)", category:sub(1, 4), count))
    end
    
    GUI.shieldStats.Text = string.format(
        "🛡️ Blocked: %d | %s\nPosition: %s | Restores: %d | Threats Neutralized: %d",
        Protection.stats.totalBlocked,
        table.concat(parts, " "),
        Protection.positionLocked and "LOCKED" or "UNLOCKED",
        Protection.stats.positionRestores,
        Protection.stats.teleportAttempts
    )
end

local function updateStats()
    local elapsed = tick() - Analytics.startTime
    local speed = Analytics.completedTests / math.max(elapsed, 0.1)
    local progress = Analytics.totalTests > 0 and (Analytics.completedTests / Analytics.totalTests) or 0
    
    Analytics.testsPerSecond = speed
    Analytics.efficiency = Analytics.remotesScanned > 0 and (Analytics.successfulTests / Analytics.remotesScanned * 100) or 0
    
    GUI.progressFill.Size = UDim2.new(progress, 0, 1, 0)
    
    GUI.stats.progress.Text = string.format("%d/%d", Analytics.completedTests, Analytics.totalTests)
    GUI.stats.speed.Text = string.format("%.0f/s", speed)
    GUI.stats.found.Text = string.format("Found: %d", Analytics.successfulTests)
    GUI.stats.patterns.Text = string.format("AI: %d", Analytics.patternsFound)
    GUI.stats.remotes.Text = string.format("Safe: %d", Analytics.remotesScanned)
