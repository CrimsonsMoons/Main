-- Machine Learning: Analyze and predict optimal values
local function analyzeValuePattern(remoteName, history)
    if #history < 2 then return nil end
    
    local ratios = {}
    local diffs = {}
    
    for i = 2, #history do
        local ratio = history[i].gain / history[i].value
        local diff = history[i].value - history[i-1].value
        table.insert(ratios, ratio)
        table.insert(diffs, diff)
    end
    
    -- Check for linear pattern (constant ratio)
    local avgRatio = 0
    for _, r in ipairs(ratios) do
        avgRatio = avgRatio + r
    end
    avgRatio = avgRatio / #ratios
    
    local variance = 0
    for _, r in ipairs(ratios) do
        variance = variance + (r - avgRatio) ^ 2
    end
    variance = variance / #ratios
    
    if variance < 0.001 then -- Very low variance = linear pattern
        NeuralAI.linearPatterns[remoteName] = avgRatio
        return "LINEAR", avgRatio
    end
    
    -- Check for exponential pattern
    local avgDiff = 0
    for _, d in ipairs(diffs) do
        avgDiff = avgDiff + d
    end
    avgDiff = avgDiff / #diffs
    
    if avgDiff > 0 and math.abs(avgDiff - diffs[1]) < avgDiff * 0.1 then
        NeuralAI.exponentialPatterns[remoteName] = avgDiff
        return "EXPONENTIAL", avgDiff
    end
    
    return "CUSTOM", nil
end

-- Predict next best values using AI
local function predictOptimalValues(remoteName)
    if NeuralAI.linearPatterns[remoteName] then
        local multiplier = NeuralAI.linearPatterns[remoteName]
        -- Test increasingly large values with this multiplier
        return {50000, 100000, 500000, 1000000, 5000000, 10000000}, "LINEAR", multiplier
    end
    
    if NeuralAI.exponentialPatterns[remoteName] then
        local step = NeuralAI.exponentialPatterns[remoteName]
        local base = NeuralAI.patterns[remoteName][#NeuralAI.patterns[remoteName]].value
        return {
            base + step,
            base + step * 2,
            base + step * 5,
            base + step * 10,
            base + step * 50
        }, "EXPONENTIAL", step
    end
    
    -- Intelligent default progression
    return {1, 10, 50, 100, 500, 1000, 5000, 10000, 50000, 100000}, "ADAPTIVE", nil
end

-- Smart value selection based on success rate
local function getSmartTestValues(remoteName, mode)
    if NeuralAI.remoteProfiles[remoteName] then
        return predictOptimalValues(remoteName)
    end
    
    if mode == "QUANTUM" then
        return {1, 100, 10000}, "QUANTUM", nil
    elseif mode == "HYPER" then
        return {1, 10, 100, 1000, 10000, 100000, 1000000}, "HYPER", nil
    elseif mode == "NEURAL" then
        return {1, 5, 10, 25, 50, 100, 250, 500, 1000, 2500, 5000, 10000, 25000, 50000, 100000}, "NEURAL", nil
    else
        return {1, 10, 100, 1000, 10000, 50000, 100000}, "ADAPTIVE", nil
    end
end

-- Learn from successful test
local function recordSuccess(remoteName, value, gain, currency)
    if not NeuralAI.patterns[remoteName] then
        NeuralAI.patterns[remoteName] = {}
    end
    
    table.insert(NeuralAI.patterns[remoteName], {
        value = value,
        gain = gain,
        currency = currency,
        ratio = gain / value,
        timestamp = tick()
    })
    
    -- Analyze pattern
    local patternType, patternValue = analyzeValuePattern(remoteName, NeuralAI.patterns[remoteName])
    
    if patternType then
        NeuralAI.remoteProfiles[remoteName] = {
            type = patternType,
            value = patternValue,
            confidence = #NeuralAI.patterns[remoteName] / 10 -- Confidence increases with more data
        }
    end
    
    return patternType, patternValue
end

